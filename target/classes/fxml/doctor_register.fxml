<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.web.WebView?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.DoctorRegisterController"
            style="-fx-background-color: linear-gradient(to bottom right, #080e1a 0%, #10182b 52%, #070c16 100%);">
    <center>
        <HBox alignment="CENTER" spacing="0">
            <HBox maxWidth="1200" prefHeight="760"
                  style="-fx-background-color: #0a1220; -fx-background-radius: 24; -fx-border-color: #252c3b; -fx-border-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 30, 0.22, 0, 8);">
                <VBox prefWidth="390" spacing="22"
                      style="-fx-background-color: linear-gradient(to bottom right, #072a27 0%, #091b25 100%); -fx-background-radius: 24 0 0 24; -fx-padding: 36;">
                    <HBox alignment="CENTER_LEFT" spacing="10">
                        <StackPane prefWidth="40" prefHeight="40" maxWidth="40" maxHeight="40"
                                   style="-fx-background-color: rgba(255,255,255,0.14); -fx-background-radius: 10;">
                            <Label text="D" style="-fx-text-fill: #ffffff; -fx-font-size: 16; -fx-font-weight: bold;" />
                        </StackPane>
                        <Label text="PinkShield" style="-fx-text-fill: #ffffff; -fx-font-size: 28; -fx-font-weight: bold;" />
                    </HBox>

                    <StackPane prefWidth="92" prefHeight="92" maxWidth="92" maxHeight="92"
                               style="-fx-background-color: rgba(255,255,255,0.10); -fx-background-radius: 999;">
                        <Label text="DR" style="-fx-text-fill: #5fe1d4; -fx-font-size: 24; -fx-font-weight: bold;" />
                    </StackPane>

                    <VBox spacing="8">
                        <Label text="Join as a Doctor" style="-fx-text-fill: #ffffff; -fx-font-size: 30; -fx-font-weight: bold;" />
                        <Label text="Connect with patients, manage appointments, and grow your clinical presence."
                               wrapText="true" style="-fx-text-fill: rgba(255,255,255,0.72); -fx-font-size: 14;" />
                    </VBox>

                    <VBox spacing="12" style="-fx-padding: 16 0 0 0;">
                        <Label text="Secure and verified access"
                               style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12; -fx-padding: 14 16; -fx-text-fill: #ecf1fb; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Grow your patient base"
                               style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12; -fx-padding: 14 16; -fx-text-fill: #ecf1fb; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Smart appointment scheduling"
                               style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 12; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 12; -fx-padding: 14 16; -fx-text-fill: #ecf1fb; -fx-font-size: 13; -fx-font-weight: bold;" />
                    </VBox>
                </VBox>

                <ScrollPane fitToWidth="true" prefWidth="810"
                            style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-background: transparent;">
                    <VBox spacing="18" style="-fx-padding: 34 40 36 40; -fx-background-color: #08111f; -fx-background-radius: 0 24 24 0;">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Hyperlink text="Change role" onAction="#handleBackToRoleSelect"
                                       style="-fx-text-fill: #63e6da; -fx-font-size: 12; -fx-font-weight: bold; -fx-border-color: transparent; -fx-padding: 0;" />
                            <Label text="Doctor registration" style="-fx-text-fill: #607089; -fx-font-size: 12;" />
                        </HBox>

                        <VBox spacing="6">
                            <Label text="Create your account" style="-fx-text-fill: #ffffff; -fx-font-size: 30; -fx-font-weight: bold;" />
                            <Label text="Register as a licensed practitioner and continue to the doctor workspace."
                                   wrapText="true" style="-fx-text-fill: #92a3bc; -fx-font-size: 13;" />
                        </VBox>

                        <Label fx:id="feedbackLabel" text="" visible="false" managed="false" wrapText="true"
                               style="-fx-background-color: rgba(220,53,69,0.12); -fx-border-color: rgba(255,107,107,0.30); -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 10 12; -fx-text-fill: #ff8f8f; -fx-font-size: 12;" />

                        <VBox spacing="7">
                            <Label text="EMAIL ADDRESS" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                            <TextField fx:id="emailField" promptText="doctor@example.com"
                                       style="-fx-background-color: #121a28; -fx-text-fill: #ffffff; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 16;" />
                        </VBox>

                        <HBox spacing="12">
                            <VBox spacing="7" HBox.hgrow="ALWAYS">
                                <Label text="FIRST NAME" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                                <TextField fx:id="firstNameField" promptText="First name"
                                           style="-fx-background-color: #121a28; -fx-text-fill: #ffffff; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 16;" />
                            </VBox>
                            <VBox spacing="7" HBox.hgrow="ALWAYS">
                                <Label text="LAST NAME" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                                <TextField fx:id="lastNameField" promptText="Last name"
                                           style="-fx-background-color: #121a28; -fx-text-fill: #ffffff; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 16;" />
                            </VBox>
                        </HBox>

                        <VBox spacing="7">
                            <Label text="MEDICAL SPECIALITY" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                            <ComboBox fx:id="specialityCombo" promptText="Select a specialty"
                                      style="-fx-background-color: #121a28; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 8 10;" />
                        </VBox>

                        <Separator style="-fx-opacity: 0.14;" />

                        <VBox spacing="7">
                            <Label text="PASSWORD" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                            <PasswordField fx:id="passwordField" promptText="Minimum 8 characters"
                                           style="-fx-background-color: #121a28; -fx-text-fill: #ffffff; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 16;" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="CONFIRM PASSWORD" style="-fx-text-fill: #95a6bf; -fx-font-size: 11; -fx-font-weight: bold;" />
                            <PasswordField fx:id="confirmPasswordField" promptText="Repeat password"
                                           style="-fx-background-color: #121a28; -fx-text-fill: #ffffff; -fx-border-color: #263243; -fx-border-radius: 12; -fx-background-radius: 12; -fx-padding: 14 16;" />
                        </VBox>

                        <VBox spacing="8" styleClass="captcha-panel">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Security Check" styleClass="captcha-title" />
                                <Label text="reCAPTCHA" styleClass="login-bio-badge" />
                            </HBox>
                            <WebView id="captchaWebView" fx:id="recaptchaWebView"
                                     prefWidth="500" minWidth="500" prefHeight="560" minHeight="560" maxHeight="560" />
                            <Label fx:id="recaptchaStatusLabel" text="" visible="false" managed="false"
                                   wrapText="true" styleClass="captcha-status-label" />
                        </VBox>

                        <Button fx:id="registerButton" text="Register as Doctor" onAction="#handleRegister"
                                style="-fx-background-color: linear-gradient(to right, #1ea79a, #35d1c1); -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 14 24; -fx-effect: dropshadow(gaussian, rgba(30,167,154,0.32), 16, 0.2, 0, 3);" />

                        <HBox alignment="CENTER" spacing="6">
                            <Label text="Already have an account?" style="-fx-text-fill: #7f8fa8; -fx-font-size: 12;" />
                            <Hyperlink text="Sign In" onAction="#handleBackToLogin"
                                       style="-fx-text-fill: #63e6da; -fx-font-size: 12; -fx-font-weight: bold; -fx-border-color: transparent; -fx-padding: 0;" />
                        </HBox>
                    </VBox>
                </ScrollPane>
            </HBox>
        </HBox>
    </center>
</BorderPane>
