<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AppointmentListController" style="-fx-background-color: #f5f5f5;">
    <top>
        <!-- Hero Header -->
        <VBox style="-fx-background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-padding: 32;" spacing="5">
            <Label text="Book an Appointment" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Select a doctor and choose a suitable date and time for your consultation" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 13;" />
        </VBox>
    </top>
    <center>
        <ScrollPane style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" fitToWidth="true">
            <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: transparent; -fx-padding: 40;">
                <!-- Form Card -->
                <VBox style="-fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-padding: 0;" spacing="0" maxWidth="600">
                    <!-- Form Content -->
                    <VBox spacing="20" style="-fx-padding: 36;">
                        <!-- Doctor Selection -->
                        <VBox spacing="8">
                            <Label text="SELECT DOCTOR / SPECIALIST" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <ComboBox fx:id="doctorCombo" promptText="Choose a doctor..." maxWidth="Infinity" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                            <Label text="Only active doctors are available for booking." style="-fx-font-size: 9; -fx-text-fill: #999; -fx-padding: 4 0 0 0;" />
                        </VBox>

                        <!-- Date and Time Selection -->
                        <HBox spacing="20">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="APPOINTMENT DATE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                                <DatePicker fx:id="datePicker" maxWidth="Infinity" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                            </VBox>
                            <VBox spacing="8" prefWidth="150">
                                <Label text="TIME" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                                <TextField fx:id="timeField" promptText="HH:MM" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                            </VBox>
                        </HBox>

                        <!-- Notes -->
                        <VBox spacing="8">
                            <Label text="SYMPTOMS / REASON FOR VISIT" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <TextArea fx:id="notesArea" promptText="Briefly describe your symptoms or reason for this appointment..." prefHeight="120" wrapText="true" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-control-inner-background: white;" />
                        </VBox>
                    </VBox>

                    <!-- Form Actions -->
                    <HBox spacing="12" style="-fx-padding: 22 36; -fx-border-top: 1 solid #ddd; -fx-background-color: #fafafa; -fx-border-radius: 0 0 8 8;" alignment="CENTER_LEFT">
                        <Button fx:id="cancelBtn" text="Cancel" onAction="#handleCancelForm" style="-fx-padding: 10 24; -fx-background-color: #ccc; -fx-text-fill: #333; -fx-font-weight: bold; -fx-border-radius: 6;" />
                        <Button fx:id="confirmBtn" text="Confirm Booking" onAction="#handleConfirmBooking" style="-fx-padding: 10 24; -fx-background-color: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6;" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
