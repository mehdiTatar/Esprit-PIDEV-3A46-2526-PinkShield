<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AppointmentCalendarController"
      alignment="TOP_CENTER"
      maxWidth="1160"
      spacing="20"
      styleClass="content-area">
    <padding>
        <Insets top="0" right="40" bottom="20" left="0" />
    </padding>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Back to appointments" onAction="#handleBackToList" styleClass="button secondary" />
        <Region HBox.hgrow="ALWAYS" />
        <Button text="Refresh" onAction="#handleRefresh" styleClass="button secondary" />
    </HBox>

    <VBox spacing="8" styleClass="hero-panel">
        <Label fx:id="pageTitleLabel" text="Appointment Calendar" styleClass="dashboard-title" />
        <Label fx:id="pageSubtitleLabel" text="Review appointment dates on a monthly schedule." styleClass="dashboard-copy" wrapText="true" />
    </VBox>

    <HBox spacing="12" alignment="CENTER_LEFT">
        <Button text="Previous month" onAction="#handlePreviousMonth" styleClass="button secondary" />
        <Label fx:id="monthLabel" text="Month Year" styleClass="dashboard-title" />
        <Button text="Next month" onAction="#handleNextMonth" styleClass="button secondary" />
    </HBox>

    <GridPane fx:id="calendarGrid" hgap="10" vgap="10" styleClass="panel-card appointment-calendar-grid" maxWidth="1.7976931348623157E308" />
</VBox>
