<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.BlogListController" style="-fx-background-color: #f5f5f5;">
    <top>
        <!-- Hero Header -->
        <VBox style="-fx-background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-padding: 32;" spacing="5">
            <Label fx:id="formTitle" text="Create New Post" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Share your medical knowledge or health tips with the community" style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 13;" />
        </VBox>
    </top>
    <center>
        <ScrollPane style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" fitToWidth="true">
            <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: transparent; -fx-padding: 40;">
                <!-- Form Card -->
                <VBox style="-fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-padding: 0;" spacing="0" maxWidth="800">
                    <!-- Form Content -->
                    <VBox spacing="20" style="-fx-padding: 36;">
                        <!-- Post Title -->
                        <VBox spacing="8">
                            <Label text="POST TITLE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <TextField fx:id="formTitleField" promptText="Enter a catchy title for your post" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                        </VBox>

                        <!-- Post Content -->
                        <VBox spacing="8">
                            <Label text="CONTENT" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <TextArea fx:id="formContentField" promptText="Write your post content here... Use markdown for formatting." prefHeight="250" wrapText="true" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-control-inner-background: white; -fx-font-family: monospace;" />
                        </VBox>

                        <!-- Image Path -->
                        <VBox spacing="8">
                            <Label text="FEATURED IMAGE (OPTIONAL)" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <HBox spacing="10">
                                <TextField fx:id="formImageField" promptText="e.g., /images/blog/health-tips.jpg" HBox.hgrow="ALWAYS" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                                <Button text="Browse" style="-fx-padding: 10 24; -fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold; -fx-border-radius: 6;" />
                            </HBox>
                        </VBox>

                        <!-- Author Role (read-only) -->
                        <VBox spacing="8">
                            <Label text="AUTHOR ROLE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333; -fx-text-transform: uppercase; -fx-letter-spacing: 0.5;" />
                            <TextField fx:id="authorRoleField" promptText="Your role" editable="false" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd; -fx-text-fill: #999;" />
                        </VBox>
                    </VBox>

                    <!-- Form Actions -->
                    <HBox spacing="12" style="-fx-padding: 22 36; -fx-border-top: 1 solid #ddd; -fx-background-color: #fafafa; -fx-border-radius: 0 0 8 8;" alignment="CENTER_LEFT">
                        <Button text="Cancel" onAction="#handleCancelForm" style="-fx-padding: 10 24; -fx-background-color: #ccc; -fx-text-fill: #333; -fx-font-weight: bold; -fx-border-radius: 6;" />
                        <Button text="Save Post" onAction="#handleSavePost" style="-fx-padding: 10 24; -fx-background-color: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6;" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
