<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AppointmentListController"
            styleClass="appointment-page">
    <top>
        <VBox spacing="8" styleClass="hero-panel appointment-hero">
            <padding>
                <Insets top="28" right="32" bottom="28" left="32" />
            </padding>
            <Label fx:id="pageTitleLabel" text="Appointments" styleClass="dashboard-title" />
            <Label fx:id="pageSubtitleLabel" text="Manage consultations and review appointment history." styleClass="dashboard-copy" wrapText="true" />
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="auth-scroll">
            <content>
                <VBox maxWidth="1180" spacing="20" styleClass="content-area">
                    <padding>
                        <Insets top="20" right="40" bottom="24" left="0" />
                    </padding>

                    <VBox spacing="14" styleClass="panel-card appointment-toolbar-card">
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <Label text="Appointments filter" styleClass="section-title" />
                            <Region HBox.hgrow="ALWAYS" />
                            <TextField fx:id="searchField" promptText="Search patient, doctor, notes..." prefWidth="320" />
                        </HBox>
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            <ComboBox fx:id="statusFilter" promptText="All statuses" prefWidth="180" />
                            <Button text="Calendar" onAction="#handleOpenCalendar" styleClass="button secondary" />
                            <Button text="Parapharmacy" onAction="#handleOpenParapharmacy" styleClass="button secondary" />
                            <Button text="Download PDF" onAction="#handleDownloadPdf" styleClass="button secondary" />
                            <Button text="Open clinic map" onAction="#handleOpenClinicMap" styleClass="button secondary" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="bookAppointmentButton" text="Book New Appointment" onAction="#handleNewAppointment" styleClass="button" />
                        </HBox>
                    </VBox>

                    <VBox spacing="14" styleClass="panel-card">
                        <Label text="Appointment history" styleClass="section-title" />
                        <TableView fx:id="appointmentsTable" prefHeight="360" styleClass="dashboard-table" VBox.vgrow="ALWAYS">
                            <columns>
                                <TableColumn fx:id="dateColumn" text="Date &amp; Time" prefWidth="180" />
                                <TableColumn fx:id="doctorPatientColumn" text="Doctor / Patient" prefWidth="280" />
                                <TableColumn fx:id="statusColumn" text="Status" prefWidth="120" />
                                <TableColumn fx:id="notesColumn" text="Notes" prefWidth="320" />
                                <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="180" />
                            </columns>
                        </TableView>
                    </VBox>

                    <HBox spacing="20" styleClass="appointment-insights-row">
                        <VBox spacing="14" styleClass="panel-card appointment-insight-card" HBox.hgrow="ALWAYS">
                            <Label text="E-ticket QR" styleClass="section-title" />
                            <Label fx:id="selectedAppointmentTitleLabel" text="Select an appointment" styleClass="dashboard-title appointment-mini-title" wrapText="true" />
                            <Label fx:id="selectedAppointmentMetaLabel" text="Pick a row to generate the e-ticket QR code and review the visit details." styleClass="dashboard-copy" wrapText="true" />
                            <Label fx:id="selectedAppointmentStatusLabel" text="QR preview ready after selection" alignment="CENTER" maxWidth="1.7976931348623157E308" styleClass="table-meta" wrapText="true" />
                            <ImageView fx:id="qrCodeImageView" fitWidth="220" fitHeight="220" pickOnBounds="true" preserveRatio="true" styleClass="appointment-qr-image" />
                            <Label text="The QR code is generated from the selected appointment details." styleClass="table-meta" wrapText="true" />
                        </VBox>

                        <VBox spacing="14" styleClass="panel-card appointment-insight-card" HBox.hgrow="ALWAYS">
                            <Label text="Clinic location" styleClass="section-title" />
                            <Label fx:id="clinicNameLabel" text="PinkShield Medical Center" styleClass="dashboard-title appointment-mini-title" wrapText="true" />
                            <Label fx:id="clinicAddressLabel" text="Centre Urbain Nord, Tunis, Tunisia" styleClass="dashboard-copy" wrapText="true" />
                            <ImageView fx:id="clinicMapImageView" fitWidth="460" fitHeight="240" pickOnBounds="true" preserveRatio="false" styleClass="appointment-map-image" />
                            <Label fx:id="mapStatusLabel" text="Loading clinic map preview..." styleClass="table-meta" wrapText="true" />
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
