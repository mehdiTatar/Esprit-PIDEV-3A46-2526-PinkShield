<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.shape.Polyline?>
<?import javafx.scene.shape.SVGPath?>
<?import javafx.scene.web.WebView?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.LoginController"
           styleClass="root login-template-root"
           stylesheets="@../css/style.css">
    <Pane fx:id="loginBackgroundPane" mouseTransparent="true" styleClass="login-template-background">
        <Line startX="0" startY="96" endX="1600" endY="96" styleClass="login-grid-line" />
        <Line startX="0" startY="210" endX="1600" endY="210" styleClass="login-grid-line" />
        <Line startX="0" startY="324" endX="1600" endY="324" styleClass="login-grid-line" />
        <Line startX="0" startY="438" endX="1600" endY="438" styleClass="login-grid-line" />
        <Line startX="0" startY="552" endX="1600" endY="552" styleClass="login-grid-line" />
        <Line startX="0" startY="666" endX="1600" endY="666" styleClass="login-grid-line" />

        <Line startX="120" startY="0" endX="120" endY="980" styleClass="login-grid-line" />
        <Line startX="280" startY="0" endX="280" endY="980" styleClass="login-grid-line" />
        <Line startX="440" startY="0" endX="440" endY="980" styleClass="login-grid-line" />
        <Line startX="600" startY="0" endX="600" endY="980" styleClass="login-grid-line" />
        <Line startX="760" startY="0" endX="760" endY="980" styleClass="login-grid-line" />
        <Line startX="920" startY="0" endX="920" endY="980" styleClass="login-grid-line" />
        <Line startX="1080" startY="0" endX="1080" endY="980" styleClass="login-grid-line" />
        <Line startX="1240" startY="0" endX="1240" endY="980" styleClass="login-grid-line" />

        <Region layoutX="78" layoutY="68" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-soft" />
        <Region layoutX="184" layoutY="168" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-primary" />
        <Region layoutX="312" layoutY="82" prefWidth="5" prefHeight="5" styleClass="star-dot star-dot-soft" />
        <Region layoutX="424" layoutY="214" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-secondary" />
        <Region layoutX="578" layoutY="124" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-primary" />
        <Region layoutX="684" layoutY="276" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-soft" />
        <Region layoutX="852" layoutY="108" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-secondary" />
        <Region layoutX="974" layoutY="188" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-primary" />
        <Region layoutX="1136" layoutY="92" prefWidth="5" prefHeight="5" styleClass="star-dot star-dot-soft" />
        <Region layoutX="1248" layoutY="248" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-secondary" />
        <Region layoutX="108" layoutY="544" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-primary" />
        <Region layoutX="248" layoutY="638" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-soft" />
        <Region layoutX="398" layoutY="718" prefWidth="5" prefHeight="5" styleClass="star-dot star-dot-secondary" />
        <Region layoutX="596" layoutY="604" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-primary" />
        <Region layoutX="918" layoutY="676" prefWidth="3" prefHeight="3" styleClass="star-dot star-dot-soft" />
        <Region layoutX="1186" layoutY="582" prefWidth="4" prefHeight="4" styleClass="star-dot star-dot-secondary" />
    </Pane>

    <HBox alignment="CENTER" spacing="56" maxWidth="1180" styleClass="login-template-layout">
        <VBox prefWidth="520" alignment="CENTER" spacing="22" styleClass="login-hero-side">
            <Label text="PinkShield" styleClass="login-brand-title" />
            <Label text="ADVANCED HEALTH INTELLIGENCE" styleClass="login-brand-tagline" />

            <Pane fx:id="loginHeroPane" prefWidth="520" prefHeight="430" styleClass="login-heart-scene">
                <Circle fx:id="orbitRingOuter" layoutX="256" layoutY="186" radius="178"
                        styleClass="login-orbit-ring login-orbit-ring-1"
                        style="-fx-fill: transparent; -fx-stroke: transparent;" />
                <Circle fx:id="orbitRingDashed" layoutX="256" layoutY="186" radius="218"
                        styleClass="login-orbit-ring login-orbit-ring-2"
                        style="-fx-fill: transparent; -fx-stroke: transparent;" />
                <Circle fx:id="orbitRingInner" layoutX="256" layoutY="186" radius="150"
                        styleClass="login-orbit-ring login-orbit-ring-3"
                        style="-fx-fill: transparent; -fx-stroke: transparent;" />

                <Circle fx:id="orbitDotPrimaryTop" layoutX="116" layoutY="96" radius="4.5" styleClass="login-orbit-dot login-orbit-dot-primary" />
                <Circle fx:id="orbitDotSecondaryTop" layoutX="414" layoutY="118" radius="3.5" styleClass="login-orbit-dot login-orbit-dot-secondary" />
                <Circle fx:id="orbitDotSecondaryBottom" layoutX="94" layoutY="284" radius="3.5" styleClass="login-orbit-dot login-orbit-dot-secondary" />
                <Circle fx:id="orbitDotPrimaryBottom" layoutX="430" layoutY="292" radius="4.5" styleClass="login-orbit-dot login-orbit-dot-primary" />

                <SVGPath fx:id="loginHeartShape" content="M256 246 C256 246 186 202 186 146 C186 115 208 96 234 96 C249 96 256 108 256 108 C256 108 263 96 278 96 C304 96 326 115 326 146 C326 202 256 246 256 246 Z"
                         styleClass="login-heart-shape" />

                <Polyline fx:id="loginEkgLine" points="82.0,330.0,148.0,330.0,166.0,302.0,182.0,356.0,198.0,312.0,214.0,330.0,298.0,330.0,316.0,330.0,334.0,302.0,350.0,356.0,366.0,312.0,382.0,330.0,448.0,330.0"
                          styleClass="login-ekg-path" />

                <Label fx:id="pillTopLeft" layoutX="48" layoutY="36" text="72 BPM"
                       styleClass="login-floating-pill login-floating-pill-primary" />
                <Label fx:id="pillTopRight" layoutX="372" layoutY="54" text="AI ACTIVE"
                       styleClass="login-floating-pill login-floating-pill-secondary" />
                <Label fx:id="pillBottomLeft" layoutX="34" layoutY="286" text="PROTECTED"
                       styleClass="login-floating-pill login-floating-pill-soft" />
                <Label fx:id="pillBottomRight" layoutX="382" layoutY="286" text="36.8 C"
                       styleClass="login-floating-pill login-floating-pill-primary" />
            </Pane>
        </VBox>

        <VBox prefWidth="430" maxWidth="430" maxHeight="Infinity" styleClass="login-form-side">
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                        pannable="true" VBox.vgrow="ALWAYS"
                        styleClass="login-form-scroll">
                <VBox spacing="22" styleClass="glass-card login-glass-card">
                    <StackPane>
                        <VBox fx:id="loginContentPane" spacing="22">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="46" prefHeight="46" styleClass="login-card-icon">
                                <Label text="PS" styleClass="login-card-icon-text" />
                            </StackPane>
                            <VBox spacing="4">
                                <Label text="Secure Access" styleClass="login-card-title" />
                                <Label text="Sign in to your health intelligence dashboard"
                                       styleClass="login-card-subtitle" wrapText="true" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="8" styleClass="login-status-bar">
                            <Region prefWidth="8" prefHeight="8" styleClass="login-status-dot" />
                            <Label text="All systems operational. End-to-end encrypted."
                                   styleClass="login-status-text" wrapText="true" />
                        </HBox>

                        <Label fx:id="feedbackLabel" text="" visible="false" managed="false"
                               styleClass="login-alert-label" wrapText="true" />

                        <VBox spacing="7">
                            <Label text="EMAIL ADDRESS" styleClass="login-field-label" />
                            <TextField fx:id="emailField" promptText="you@example.com"
                                       styleClass="login-field-input" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="PASSWORD" styleClass="login-field-label" />
                            <HBox spacing="10" styleClass="login-password-row">
                                <PasswordField fx:id="passwordField" promptText="Enter your password"
                                               styleClass="login-field-input" HBox.hgrow="ALWAYS" />
                                <TextField fx:id="visiblePasswordField" promptText="Enter your password"
                                           styleClass="login-field-input" HBox.hgrow="ALWAYS"
                                           visible="false" managed="false" />
                                <Button fx:id="togglePasswordButton" text="Show" onAction="#handleTogglePassword"
                                        styleClass="login-toggle-button" />
                            </HBox>
                        </VBox>

                        <HBox alignment="CENTER_RIGHT">
                            <Hyperlink text="Forgot password?" onAction="#handleShowForgotPassword"
                                       styleClass="login-inline-link" />
                        </HBox>

                        <VBox spacing="8" styleClass="captcha-panel">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Security Check" styleClass="captcha-title" />
                                <Label text="reCAPTCHA" styleClass="login-bio-badge" />
                            </HBox>
                            <WebView id="captchaWebView" fx:id="recaptchaWebView"
                                     prefHeight="112" minHeight="112" maxHeight="112" />
                            <Label fx:id="recaptchaStatusLabel" text="" visible="false" managed="false"
                                   wrapText="true" styleClass="captcha-status-label" />
                        </VBox>

                        <Button fx:id="loginButton" text="Authenticate and Enter" onAction="#handleLogin"
                                maxWidth="Infinity" styleClass="login-primary-button" />

                        <VBox spacing="12" styleClass="login-biometric-panel">
                            <HBox alignment="CENTER_LEFT" spacing="10">
                                <Label text="Face++ Login" styleClass="login-bio-title" />
                                <Label text="PATIENT" styleClass="login-bio-badge" />
                            </HBox>
                            <Label text="Open the front camera and capture a fresh face image for biometric authentication."
                                   styleClass="login-card-subtitle" wrapText="true" />
                            <Button text="Open Face Login" onAction="#handleShowFaceLogin"
                                    maxWidth="Infinity" styleClass="login-secondary-button" />
                        </VBox>

                        <HBox alignment="CENTER" spacing="6" styleClass="login-register-row">
                            <Label text="Don't have an account?" styleClass="login-register-text" />
                            <Hyperlink text="Create one now" onAction="#handleRegister"
                                       styleClass="login-register-link" />
                        </HBox>
                        </VBox>

                        <VBox fx:id="forgotPasswordContentPane" spacing="18" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="46" prefHeight="46" styleClass="login-card-icon login-card-icon-success">
                                <Label text="R" styleClass="login-card-icon-text" />
                            </StackPane>
                            <VBox spacing="4">
                                <Label text="Forgot Password" styleClass="login-card-title" />
                                <Label text="Request a verification code by email, then use it to set your new password."
                                       styleClass="login-card-subtitle" wrapText="true" />
                            </VBox>
                        </HBox>

                        <Label fx:id="forgotPasswordFeedbackLabel" text="" visible="false" managed="false"
                               styleClass="login-alert-label" wrapText="true" />

                        <VBox spacing="7" styleClass="login-reset-info-card">
                            <Label text="Recovery steps" styleClass="login-reset-info-title" />
                            <Label text="1. Enter the email linked to your account." styleClass="login-reset-info-text" wrapText="true" />
                            <Label text="2. Request the 6-digit verification code sent to that email." styleClass="login-reset-info-text" wrapText="true" />
                            <Label text="3. Enter the code and choose your new password." styleClass="login-reset-info-text" wrapText="true" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="EMAIL ADDRESS" styleClass="login-field-label" />
                            <TextField fx:id="forgotPasswordEmailField" promptText="you@example.com"
                                       styleClass="login-field-input" />
                        </VBox>

                        <VBox spacing="8">
                            <Button fx:id="forgotPasswordSendCodeButton" text="Send Verification Code"
                                    onAction="#handleSendResetCode"
                                    maxWidth="Infinity" styleClass="login-secondary-button" />
                            <Label text="We send a 6-digit code to the address above. The code expires after 10 minutes."
                                   styleClass="login-reset-meta" wrapText="true" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="VERIFICATION CODE" styleClass="login-field-label" />
                            <TextField fx:id="forgotPasswordCodeField" promptText="Enter the 6-digit code"
                                       styleClass="login-field-input" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="NEW PASSWORD" styleClass="login-field-label" />
                            <PasswordField fx:id="forgotPasswordField" promptText="Create a new password"
                                           styleClass="login-field-input" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="CONFIRM PASSWORD" styleClass="login-field-label" />
                            <PasswordField fx:id="forgotPasswordConfirmField" promptText="Repeat the new password"
                                           styleClass="login-field-input" />
                        </VBox>

                        <Button fx:id="forgotPasswordSubmitButton" text="Verify Code and Reset Password" onAction="#handleResetPassword"
                                disable="true"
                                maxWidth="Infinity" styleClass="login-primary-button" />

                        <HBox alignment="CENTER_LEFT">
                            <Hyperlink text="Return to login" onAction="#handleBackToLogin"
                                       styleClass="login-inline-link" />
                        </HBox>
                        </VBox>

                        <VBox fx:id="faceLoginContentPane" spacing="18" visible="false" managed="false">
                        <HBox alignment="CENTER_LEFT" spacing="14">
                            <StackPane prefWidth="46" prefHeight="46" styleClass="login-card-icon">
                                <Label text="F" styleClass="login-card-icon-text" />
                            </StackPane>
                            <VBox spacing="4">
                                <Label text="Face Sign-In" styleClass="login-card-title" />
                                <Label text="Patient biometric access powered by Face++ image comparison."
                                       styleClass="login-card-subtitle" wrapText="true" />
                            </VBox>
                        </HBox>

                        <Label fx:id="faceLoginFeedbackLabel" text="" visible="false" managed="false"
                               styleClass="login-alert-label" wrapText="true" />

                        <VBox spacing="7" styleClass="login-reset-info-card">
                            <Label text="Biometric steps" styleClass="login-reset-info-title" />
                            <Label text="1. Enter the patient email linked to the enrolled face image." styleClass="login-reset-info-text" wrapText="true" />
                            <Label text="2. Capture a clear live photo from the front camera for this sign-in attempt." styleClass="login-reset-info-text" wrapText="true" />
                            <Label text="3. Face++ compares both images and opens the patient dashboard on a strong match." styleClass="login-reset-info-text" wrapText="true" />
                        </VBox>

                        <VBox spacing="7">
                            <Label text="PATIENT EMAIL" styleClass="login-field-label" />
                            <TextField fx:id="faceLoginEmailField" promptText="patient@example.com"
                                       styleClass="login-field-input" />
                        </VBox>

                        <VBox spacing="12" styleClass="login-bio-preview">
                            <Label fx:id="faceLoginImageNameLabel" text="No live front-camera image captured"
                                   styleClass="login-bio-preview-name" wrapText="true" />
                            <Label fx:id="faceLoginImageHelperLabel" text="Open the front camera to capture a live image for comparison."
                                   styleClass="login-bio-preview-text" wrapText="true" />
                            <Button fx:id="faceLoginChooseImageButton" text="Open Front Camera"
                                    onAction="#handleCaptureFaceLoginImage"
                                    maxWidth="Infinity" styleClass="login-secondary-button" />
                        </VBox>

                        <Button fx:id="faceLoginSubmitButton" text="Verify Face and Enter" onAction="#handleFaceLogin"
                                maxWidth="Infinity" styleClass="login-primary-button" />

                        <HBox alignment="CENTER_LEFT">
                            <Hyperlink text="Return to login" onAction="#handleBackToLogin"
                                       styleClass="login-inline-link" />
                        </HBox>
                        </VBox>
                    </StackPane>
                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</StackPane>
