<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.DoctorDashboardController"
            styleClass="root"
            stylesheets="@../css/style.css">

    <!-- LEFT SIDEBAR NAVIGATION -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240">
            <!-- Logo -->
            <VBox spacing="12" style="-fx-padding: 16;">
                <HBox alignment="CENTER" spacing="8">
                    <VBox alignment="CENTER" style="-fx-min-width: 40; -fx-min-height: 40; -fx-background-color: #2dd4bf; -fx-background-radius: 10;">
                        <Label text="P" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="PinkShield" style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Clinic" style="-fx-text-fill: #8aa4c8; -fx-font-size: 10;" />
                    </VBox>
                </HBox>
            </VBox>

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 8;">
                <Button fx:id="navDashboard" text="📊 Dashboard" onAction="#showDashboard"
                       styleClass="nav-button active" style="-fx-min-width: 200;" />
                <Button fx:id="navAppointments" text="📅 Appointments" onAction="#showAppointments"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button fx:id="navProfileEdit" text="👤 Profile Settings" onAction="#showProfileEdit"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button fx:id="navBlog" text="📚 Health Articles" onAction="#showBlog"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button fx:id="navProducts" text="💊 Pharmacy" onAction="#showProducts"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Logout -->
            <VBox style="-fx-padding: 8;">
                <Button text="🚪 Sign Out" onAction="#handleLogout"
                       styleClass="nav-button" style="-fx-min-width: 200; -fx-text-fill: #ff8f8f;" />
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <BorderPane>
            <!-- TOP BAR -->
            <top>
                <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-padding: 16 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label fx:id="welcomeLabel" text="Welcome back, Dr. Smith"
                               style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label fx:id="dashboardRoleLabel" text="Cardiology"
                               style="-fx-text-fill: #8aa4c8; -fx-font-size: 11;" />
                    </VBox>
                </HBox>
            </top>

            <!-- CONTENT AREA -->
            <center>
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <StackPane fx:id="mainContent">
                        <!-- DASHBOARD VIEW -->
                        <fx:define>
                            <VBox fx:id="dashboardView" spacing="20" styleClass="content-area">
                                <!-- Welcome/Hero Panel -->
                                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="hero-panel hero-panel-doctor">
                                    <VBox spacing="8" HBox.hgrow="ALWAYS">
                                        <Label text="Doctor Dashboard" styleClass="dashboard-title" />
                                        <Label text="Manage your appointments, patients, and clinic operations" styleClass="dashboard-copy" wrapText="true" />
                                    </VBox>
                                </HBox>

                                <!-- METRICS ROW -->
                                <GridPane hgap="16" vgap="16">
                                    <columnConstraints>
                                        <ColumnConstraints hgrow="ALWAYS" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                        <ColumnConstraints hgrow="ALWAYS" />
                                    </columnConstraints>

                                    <!-- Total Appointments -->
                                    <VBox spacing="6" styleClass="metric-card metric-card-doctor" GridPane.columnIndex="0">
                                        <Label text="TOTAL APPOINTMENTS" styleClass="metric-label" />
                                        <Label fx:id="totalAppointmentsLabel" text="0" styleClass="metric-value" />
                                        <Label text="All time" styleClass="table-meta" />
                                    </VBox>

                                    <!-- Upcoming Appointments -->
                                    <VBox spacing="6" styleClass="metric-card metric-card-doctor" GridPane.columnIndex="1">
                                        <Label text="UPCOMING" styleClass="metric-label" />
                                        <Label fx:id="upcomingAppointmentsLabel" text="0" styleClass="metric-value" />
                                        <Label text="This month" styleClass="table-meta" />
                                    </VBox>

                                    <!-- Status -->
                                    <VBox spacing="6" styleClass="metric-card metric-card-doctor" GridPane.columnIndex="2">
                                        <Label text="STATUS" styleClass="metric-label" />
                                        <Label text="Active" style="-fx-text-fill: #2dd4bf; -fx-font-size: 18; -fx-font-weight: bold;" />
                                        <Label text="Accepting patients" styleClass="table-meta" />
                                    </VBox>
                                </GridPane>

                                <!-- DOCTOR INFO SUMMARY -->
                                <VBox spacing="12" styleClass="panel-card">
                                    <Label text="Professional Information" styleClass="card-title" />
                                    <Separator style="-fx-opacity: 0.1;" />
                                    <HBox spacing="20">
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <Label text="NAME" styleClass="field-label" />
                                            <Label fx:id="doctorNameSummaryLabel" text="Dr. John Smith" style="-fx-text-fill: #ffffff;" />
                                        </VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <Label text="EMAIL" styleClass="field-label" />
                                            <Label fx:id="doctorEmailSummaryLabel" text="john@example.com" style="-fx-text-fill: #ffffff;" />
                                        </VBox>
                                        <VBox spacing="6" HBox.hgrow="ALWAYS">
                                            <Label text="SPECIALITY" styleClass="field-label" />
                                            <Label fx:id="doctorSpecialitySummaryLabel" text="Cardiology" style="-fx-text-fill: #2dd4bf; -fx-font-weight: bold;" />
                                        </VBox>
                                    </HBox>
                                </VBox>

                                <!-- QUICK ACTIONS -->
                                <VBox spacing="12">
                                    <Label text="Quick Actions" styleClass="section-title" />
                                    <HBox spacing="12">
                                        <Button text="📅 View All Appointments" onAction="#showAppointments"
                                               HBox.hgrow="ALWAYS" styleClass="button secondary"
                                               style="-fx-min-height: 44;" />
                                        <Button text="📚 Health Articles" onAction="#showBlog"
                                               HBox.hgrow="ALWAYS" styleClass="button secondary"
                                               style="-fx-min-height: 44;" />
                                    </HBox>
                                </VBox>
                            </VBox>
                        </fx:define>

                        <!-- PROFILE EDIT VIEW -->
                        <fx:define>
                            <ScrollPane fitToWidth="true" styleClass="page-scroll">
                                <VBox fx:id="profileEditView" spacing="20" styleClass="content-area">
                                    <!-- Header -->
                                    <HBox alignment="CENTER_LEFT" spacing="16" styleClass="hero-panel hero-panel-doctor">
                                        <VBox spacing="8" HBox.hgrow="ALWAYS">
                                            <Label text="Edit Profile" styleClass="dashboard-title" />
                                            <Label text="Update your professional information and preferences" styleClass="dashboard-copy" wrapText="true" />
                                        </VBox>
                                    </HBox>

                                    <!-- Form Card -->
                                    <VBox spacing="16" styleClass="panel-card profile-card">
                                        <!-- Feedback -->
                                        <Label fx:id="feedbackLabel" text="" visible="false" managed="false"
                                               styleClass="feedback-label" wrapText="true" />

                                        <!-- Name Fields -->
                                        <HBox spacing="14">
                                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                <Label text="FIRST NAME" styleClass="field-label" />
                                                <TextField fx:id="firstNameField" styleClass="text-field" />
                                            </VBox>
                                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                                <Label text="LAST NAME" styleClass="field-label" />
                                                <TextField fx:id="lastNameField" styleClass="text-field" />
                                            </VBox>
                                        </HBox>

                                        <!-- Email -->
                                        <VBox spacing="6">
                                            <Label text="EMAIL ADDRESS" styleClass="field-label" />
                                            <TextField fx:id="emailField" styleClass="text-field" />
                                        </VBox>

                                        <!-- Speciality -->
                                        <VBox spacing="6">
                                            <Label text="SPECIALITY" styleClass="field-label" />
                                            <TextField fx:id="specialityField" styleClass="text-field" />
                                        </VBox>

                                        <!-- Buttons -->
                                        <Separator style="-fx-opacity: 0.1;" />
                                        <HBox spacing="12">
                                            <Button text="💾 Save Changes" onAction="#handleSaveProfile"
                                                   HBox.hgrow="ALWAYS" styleClass="button"
                                                   style="-fx-min-height: 44;" />
                                            <Button text="↻ Reset" onAction="#handleResetProfile"
                                                   HBox.hgrow="ALWAYS" styleClass="button secondary"
                                                   style="-fx-min-height: 44;" />
                                        </HBox>
                                    </VBox>
                                </VBox>
                            </ScrollPane>
                        </fx:define>

                        <!-- Display dashboard by default -->
                        <VBox fx:id="dashboardView" />
                    </StackPane>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>

