<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<!-- REUSABLE BASE DASHBOARD LAYOUT TEMPLATE
     This template is designed to be used as a reference for all dashboard pages.
     Each dashboard (patient, doctor, admin) should follow this exact structure for consistency.

     Key Features:
     - Sidebar navigation on the left
     - Top action bar with user info
     - Main content area
     - Consistent spacing and styling
-->

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="root"
            stylesheets="@../css/style.css">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240">
            <!-- Logo Area -->
            <VBox spacing="12" style="-fx-padding: 16;">
                <HBox alignment="CENTER" spacing="8">
                    <VBox alignment="CENTER" style="-fx-min-width: 40; -fx-min-height: 40; -fx-background-color: #c0396b; -fx-background-radius: 10;">
                        <Label text="P" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="PinkShield" style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Dashboard" style="-fx-text-fill: #8aa4c8; -fx-font-size: 10;" />
                    </VBox>
                </HBox>
            </VBox>

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Navigation Items -->
            <VBox spacing="4" style="-fx-padding: 8;">
                <!-- Dashboard -->
                <Button text="📊 Dashboard" onAction="#showDashboard"
                       styleClass="nav-button" style="-fx-min-width: 200;" />

                <!-- Appointments -->
                <Button text="📅 Appointments" onAction="#showAppointments"
                       styleClass="nav-button" style="-fx-min-width: 200;" />

                <!-- Profile -->
                <Button text="👤 Profile" onAction="#showProfileEdit"
                       styleClass="nav-button" style="-fx-min-width: 200;" />

                <!-- Blog/Health Articles -->
                <Button text="📚 Resources" onAction="#showBlog"
                       styleClass="nav-button" style="-fx-min-width: 200;" />

                <!-- Pharmacy/Products -->
                <Button text="💊 Pharmacy" onAction="#showProducts"
                       styleClass="nav-button" style="-fx-min-width: 200;" />

                <!-- Health Tracking (Patient only) -->
                <Button text="📈 Tracking" onAction="#showDailyCheckIn"
                       styleClass="nav-button" style="-fx-min-width: 200;" visible="false" managed="false" />
            </VBox>

            <!-- Spacer -->
            <Region VBox.vgrow="ALWAYS" />

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Logout Button -->
            <VBox style="-fx-padding: 8;">
                <Button text="🚪 Sign Out" onAction="#handleLogout"
                       styleClass="nav-button logout-button" style="-fx-min-width: 200;" />
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT AREA -->
    <center>
        <BorderPane>
            <!-- Top Header Bar -->
            <top>
                <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-padding: 16 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                    <!-- User Info -->
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label fx:id="welcomeLabel" text="Welcome, Dr. Smith"
                               style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label fx:id="dashboardRoleLabel" text="Cardiologist"
                               style="-fx-text-fill: #8aa4c8; -fx-font-size: 11;" />
                    </VBox>
                </HBox>
            </top>

            <!-- Content Area -->
            <center>
                <ScrollPane style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <StackPane fx:id="mainContent">
                        <!-- Dashboard Content Goes Here -->
                        <VBox spacing="20" styleClass="content-area">
                            <!-- Hero Panel -->
                            <VBox alignment="CENTER_LEFT" spacing="8" styleClass="hero-panel">
                                <Label fx:id="welcomeLabelMain" text="Welcome back!"
                                       styleClass="dashboard-title" />
                                <Label text="Your personalized health dashboard is ready to use"
                                       styleClass="dashboard-copy" wrapText="true" />
                            </VBox>

                            <!-- Metrics/Stats Cards Row -->
                            <HBox spacing="16">
                                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <Label text="TOTAL APPOINTMENTS" styleClass="metric-label" />
                                    <Label text="12" styleClass="metric-value" />
                                </VBox>
                                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <Label text="UPCOMING" styleClass="metric-label" />
                                    <Label text="3" styleClass="metric-value" />
                                </VBox>
                                <VBox spacing="6" styleClass="metric-card" HBox.hgrow="ALWAYS">
                                    <Label text="COMPLETED" styleClass="metric-label" />
                                    <Label text="9" styleClass="metric-value" />
                                </VBox>
                            </HBox>

                            <!-- Main Content Sections -->
                            <VBox spacing="12">
                                <Label text="Recent Activity" styleClass="section-title" />
                                <VBox styleClass="panel-card">
                                    <Label text="Your recent activity will appear here"
                                           styleClass="dashboard-copy" />
                                </VBox>
                            </VBox>
                        </VBox>
                    </StackPane>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>

