<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            styleClass="root"
            stylesheets="@../css/style.css">

    <!-- LEFT SIDEBAR NAVIGATION -->
    <left>
        <VBox styleClass="sidebar" prefWidth="240">
            <!-- Logo -->
            <VBox spacing="12" style="-fx-padding: 16;">
                <HBox alignment="CENTER" spacing="8">
                    <VBox alignment="CENTER" style="-fx-min-width: 40; -fx-min-height: 40; -fx-background-color: #60a5fa; -fx-background-radius: 10;">
                        <Label text="P" style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="PinkShield" style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Patient" style="-fx-text-fill: #8aa4c8; -fx-font-size: 10;" />
                    </VBox>
                </HBox>
            </VBox>

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Navigation -->
            <VBox spacing="4" style="-fx-padding: 8;">
                <Button text="📊 Dashboard" onAction="#showDashboard"
                       styleClass="nav-button active" style="-fx-min-width: 200;" />
                <Button text="📅 Appointments" onAction="#showAppointments"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button text="👤 My Profile" onAction="#showProfileEdit"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button text="📚 Health Articles" onAction="#showBlog"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button text="💊 Pharmacy" onAction="#showProducts"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
                <Button text="📈 Health Tracking" onAction="#showDailyCheckIn"
                       styleClass="nav-button" style="-fx-min-width: 200;" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />

            <Separator style="-fx-opacity: 0.1;" />

            <!-- Logout -->
            <VBox style="-fx-padding: 8;">
                <Button text="🚪 Sign Out" onAction="#handleLogout"
                       styleClass="nav-button" style="-fx-min-width: 200; -fx-text-fill: #ff8f8f;" />
            </VBox>
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <BorderPane>
            <!-- TOP BAR -->
            <top>
                <HBox alignment="CENTER_RIGHT" spacing="20" style="-fx-padding: 16 24; -fx-border-color: rgba(255,255,255,0.05); -fx-border-width: 0 0 1 0;">
                    <VBox alignment="CENTER_RIGHT" spacing="2">
                        <Label text="Welcome back"
                               style="-fx-text-fill: #ffffff; -fx-font-size: 13; -fx-font-weight: bold;" />
                        <Label text="Patient Dashboard"
                               style="-fx-text-fill: #8aa4c8; -fx-font-size: 11;" />
                    </VBox>
                </HBox>
            </top>

            <!-- CONTENT AREA -->
            <center>
                <ScrollPane fitToWidth="true" styleClass="page-scroll">
                    <VBox spacing="20" styleClass="content-area">
                        <!-- Welcome/Hero Panel -->
                        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="hero-panel hero-panel-user">
                            <VBox spacing="8" HBox.hgrow="ALWAYS">
                                <Label text="Your Health Dashboard" styleClass="dashboard-title" />
                                <Label text="Manage appointments, track health metrics, and access healthcare resources" styleClass="dashboard-copy" wrapText="true" />
                            </VBox>
                        </HBox>

                        <!-- METRICS ROW -->
                        <GridPane hgap="16" vgap="16">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                                <ColumnConstraints hgrow="ALWAYS" />
                            </columnConstraints>

                            <!-- Total Appointments -->
                            <VBox spacing="6" styleClass="metric-card metric-card-user" GridPane.columnIndex="0">
                                <Label text="TOTAL APPOINTMENTS" styleClass="metric-label" />
                                <Label text="8" styleClass="metric-value" />
                                <Label text="All time" styleClass="table-meta" />
                            </VBox>

                            <!-- Upcoming -->
                            <VBox spacing="6" styleClass="metric-card metric-card-user" GridPane.columnIndex="1">
                                <Label text="UPCOMING" styleClass="metric-label" />
                                <Label text="2" styleClass="metric-value" />
                                <Label text="Next 30 days" styleClass="table-meta" />
                            </VBox>

                            <!-- Health Score -->
                            <VBox spacing="6" styleClass="metric-card metric-card-user" GridPane.columnIndex="2">
                                <Label text="HEALTH STATUS" styleClass="metric-label" />
                                <Label text="Good" style="-fx-text-fill: #10b981; -fx-font-size: 18; -fx-font-weight: bold;" />
                                <Label text="All metrics normal" styleClass="table-meta" />
                            </VBox>
                        </GridPane>

                        <!-- QUICK ACTIONS -->
                        <VBox spacing="12">
                            <Label text="Quick Actions" styleClass="section-title" />
                            <HBox spacing="12">
                                <Button text="🔗 Book Appointment" HBox.hgrow="ALWAYS" styleClass="button"
                                       style="-fx-min-height: 44;" />
                                <Button text="📊 View Tracking" HBox.hgrow="ALWAYS" styleClass="button secondary"
                                       style="-fx-min-height: 44;" />
                                <Button text="💬 Message Doctor" HBox.hgrow="ALWAYS" styleClass="button secondary"
                                       style="-fx-min-height: 44;" />
                            </HBox>
                        </VBox>

                        <!-- RECENT APPOINTMENTS -->
                        <VBox spacing="12">
                            <Label text="Upcoming Appointments" styleClass="section-title" />
                            <VBox spacing="10" styleClass="panel-card">
                                <HBox spacing="12" alignment="CENTER_LEFT">
                                    <VBox spacing="4" HBox.hgrow="ALWAYS">
                                        <Label text="Dr. Jane Smith - Cardiology" style="-fx-text-fill: #ffffff; -fx-font-weight: bold;" />
                                        <Label text="📅 March 15, 2026 at 2:00 PM" styleClass="dashboard-copy" />
                                    </VBox>
                                    <Label text="✓ Confirmed" style="-fx-text-fill: #10b981; -fx-font-weight: bold;" />
                                </HBox>
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </center>
        </BorderPane>
    </center>
</BorderPane>

