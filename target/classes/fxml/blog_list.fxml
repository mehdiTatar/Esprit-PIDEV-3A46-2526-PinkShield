<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.BlogListController" style="-fx-background-color: #f5f5f5;">
    <top>
        <!-- Hero Header -->
        <VBox style="-fx-background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-padding: 40;" spacing="12">
            <Label text="Medical Blog &amp; Community" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Discover the latest health trends, medical insights, and wellness tips shared by our healthcare professionals." style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 13; -fx-wrap-text: true;" />
        </VBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 40; -fx-background-color: transparent;">
            <!-- Toolbar -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 12 16; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <TextField fx:id="searchField" promptText="Search posts..." prefWidth="300" style="-fx-padding: 8; -fx-border-width: 0; -fx-background-color: transparent;" />
                    <Button text="🔍 Search" onAction="#handleSearch" style="-fx-padding: 8 16; -fx-background-color: #e8e8e8; -fx-text-fill: #333; -fx-font-weight: bold; -fx-border-radius: 6;" />
                </HBox>
                <Button fx:id="addPostBtn" text="✎ Create New Post" onAction="#handleNewPost" style="-fx-padding: 10 24; -fx-background-color: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6;" />
            </HBox>

            <!-- Posts Grid -->
            <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" VBox.vgrow="ALWAYS">
                <FlowPane fx:id="postsContainer" hgap="20" vgap="20" style="-fx-padding: 0;">
                    <!-- Blog post cards will be injected by controller -->
                </FlowPane>
            </ScrollPane>
        </VBox>
    </center>
</BorderPane>
