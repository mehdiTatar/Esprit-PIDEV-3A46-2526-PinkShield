<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="org.example.HealthAnalysisController"
            stylesheets="@style.css" styleClass="module-root">
    <top>
        <ToolBar>
            <Button text="← Back to Wishlist" onAction="#handleBackToWishlist" styleClass="btn-secondary"/>
            <Label text="Risk Analyser" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #e84393;"/>
        </ToolBar>
    </top>

    <center>
        <VBox spacing="16" style="-fx-padding: 24;">
            <Label text="Enter patient notes to evaluate the symptom risk level." styleClass="label-subtitle" wrapText="true"/>
            <Label fx:id="statusLabel" text="Ready to scan." styleClass="label-subtitle" wrapText="true"/>

            <TextArea fx:id="notesArea" promptText="Example: fever, cough, chest pain, rash..." prefRowCount="8" wrapText="true"/>

            <HBox spacing="10">
                <Button fx:id="analyzeButton" text="Analyse" onAction="#handleAnalyze" styleClass="btn-primary"/>
            </HBox>

            <VBox fx:id="resultBox" spacing="8" styleClass="risk-analysis-card"/>
        </VBox>
    </center>
</BorderPane>

