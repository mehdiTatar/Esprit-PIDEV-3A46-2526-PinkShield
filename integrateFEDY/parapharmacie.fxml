<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.ParapharmacieController" spacing="15" style="-fx-padding: 20; -fx-background-color: #f4f4f9;" stylesheets="@style.css" styleClass="module-root day-mode-para">

    <Label text="🌿 Gestion Parapharmacie" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2d3436;"/>

    <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-padding: 15; -fx-background-radius: 10;">
        <TextField fx:id="txtNom" promptText="Nom du produit" styleClass="day-mode-input"/>
        <TextField fx:id="txtPrix" promptText="Prix (TND)" styleClass="day-mode-input"/>
        <TextField fx:id="txtStock" promptText="Stock" styleClass="day-mode-input"/>
        <Button text="➕ Ajouter / Sauver" onAction="#handleAjouter" styleClass="day-mode-primary-button"/>
        <Button text="🔄 Réinitialiser" onAction="#handleRefresh" styleClass="day-mode-secondary-button"/>
    </HBox>

    <Label text="Tip: click Edit on a product card to modify it, then click Ajouter / Sauver." style="-fx-text-fill: #666; -fx-font-size: 12;"/>

    <HBox spacing="15" alignment="CENTER_LEFT">
        <TextField fx:id="searchBar" promptText="🔍 Rechercher un produit..." prefWidth="300" styleClass="day-mode-input"/>
        <ComboBox fx:id="sortComboBox" promptText="Trier par..." prefWidth="150" styleClass="day-mode-combo"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;" VBox.vgrow="ALWAYS">
        <FlowPane fx:id="productFlowPane" hgap="20" vgap="20" style="-fx-padding: 10;"/>
    </ScrollPane>

</VBox>