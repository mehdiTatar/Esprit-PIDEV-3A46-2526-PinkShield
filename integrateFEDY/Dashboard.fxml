<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.DashboardController" stylesheets="@style.css">

    <!-- Main BorderPane -->
    <BorderPane fx:id="rootPane">

        <!-- ===== TOP: Header + Weather Widget ===== -->
        <top>
            <VBox spacing="10">
                <HBox styleClass="header" alignment="CENTER_LEFT">
                <!-- Logo -->
                <Label text="💊 PinkShield" styleClass="header-logo"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Header Search Bar (Optional) -->
                <TextField promptText="🔍 Quick search..." prefWidth="250" styleClass="text-field"/>

                <!-- Notification Bell Icon -->
                <StackPane fx:id="notificationBellContainer" style="-fx-cursor: hand;" onMouseClicked="#handleToggleNotifications">
                    <!-- Bell Icon -->
                    <Label text="🔔" style="-fx-font-size: 20px; -fx-cursor: hand;"/>

                    <!-- Unread Count Badge -->
                    <StackPane fx:id="notificationBadge" alignment="TOP_RIGHT" managed="false" translateX="-5" translateY="2">
                        <Circle radius="12" fill="#dc3545"/>
                        <Label fx:id="notificationCountLabel" text="0" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 11px;"/>
                    </StackPane>
                </StackPane>

                <ToggleButton fx:id="nightModeToggle" text="Night Mode" styleClass="btn-secondary" onAction="#handleToggleNightMode"/>

                    <!-- User Menu (Optional) -->
                    <Button text="👤" style="-fx-font-size: 18; -fx-background-color: transparent; -fx-border-color: transparent; -fx-cursor: hand;"/>
                </HBox>

                <HBox fx:id="weatherWarningBox" alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 12 18; -fx-background-radius: 12; -fx-border-radius: 12;">
                    <Label text="🌍 Loading weather data..." fx:id="weatherLabel" style="-fx-font-size: 13px; -fx-font-weight: 600;" wrapText="true"/>
                </HBox>
            </VBox>
        </top>

        <!-- ===== LEFT: Sidebar ===== -->
        <left>
            <VBox styleClass="sidebar" minWidth="220" prefWidth="220">
                <!-- Sidebar Title -->
                <Label text="Navigation" styleClass="sidebar-title"/>

                <Separator/>

                <!-- Navigation Buttons -->
                <Button text="📊 Dashboard" styleClass="sidebar-button" onAction="#handleDashboard" wrapText="true" graphicTextGap="15"/>
                <Button text="📅 Appointments" styleClass="sidebar-button" onAction="#handleAppointments" wrapText="true" graphicTextGap="15"/>
                <Button text="💊 Parapharmacie" styleClass="sidebar-button" onAction="#handleParapharmacie" wrapText="true" graphicTextGap="15"/>
                <Button text="❤️ Wishlist" styleClass="sidebar-button" onAction="#handleWishlist" wrapText="true" graphicTextGap="15"/>
                <Button text="🛡️ Risk Analyser" styleClass="sidebar-button" onAction="#handleRiskAnalyser" wrapText="true" graphicTextGap="15"/>

                <!-- Spacer -->
                <Region VBox.vgrow="ALWAYS"/>

                <!-- Logout Button at Bottom -->
                <Separator/>
                <Button text="🚪 Logout" styleClass="sidebar-button" onAction="#handleLogout" wrapText="true" graphicTextGap="15"/>
            </VBox>
        </left>

        <!-- ===== CENTER: Main Content Area ===== -->
        <center>
            <StackPane fx:id="contentArea" styleClass="module-root">
                <!-- This will be where sub-windows are dynamically loaded -->
                <VBox alignment="CENTER" spacing="20" styleClass="module-root" style="-fx-padding: 40;">
                    <Label text="Welcome to PinkShield" styleClass="label-title" alignment="CENTER"/>
                    <Label text="Select an option from the sidebar to get started" styleClass="label-subtitle" alignment="CENTER"/>
                </VBox>
            </StackPane>
        </center>

    </BorderPane>

    <!-- Notification Dropdown Panel (as overlay) -->
    <VBox fx:id="notificationDropdown" managed="false" visible="false" alignment="TOP_CENTER" StackPane.alignment="TOP_RIGHT" style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 8; -fx-padding: 0; -fx-effect: dropshadow(gaussian, rgba(0, 0, 0, 0.2), 12, 0, 2, 4);" prefWidth="350" maxHeight="400">
        <!-- Header -->
        <HBox spacing="10" style="-fx-padding: 15; -fx-background-color: #f5f5f5; -fx-border-radius: 8 8 0 0;" alignment="CENTER_LEFT">
            <Label text="🔔 Notifications" style="-fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" style="-fx-background-color: transparent; -fx-cursor: hand; -fx-font-size: 12px;" onAction="#handleToggleNotifications"/>
        </HBox>

        <!-- Notifications List -->
        <ListView fx:id="notificationsList" prefHeight="350" VBox.vgrow="ALWAYS" style="-fx-padding: 0; -fx-border-radius: 0;"/>
    </VBox>

</StackPane>
