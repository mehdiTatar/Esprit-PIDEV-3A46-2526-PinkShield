<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.AppointmentUserController" spacing="20" style="-fx-padding: 30;">
    <Label text="📅 Gérer vos Rendez-vous" style="-fx-font-size: 24; -fx-font-weight: bold;"/>

    <GridPane hgap="10" vgap="10">
        <TextField fx:id="txtPatientName" promptText="Nom Patient" GridPane.columnIndex="0"/>
        <TextField fx:id="txtPatientEmail" promptText="Email Patient" GridPane.columnIndex="1"/>
        <TextField fx:id="txtDoctorName" promptText="Nom Docteur" GridPane.rowIndex="1"/>
        <DatePicker fx:id="datePicker" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <TextArea fx:id="txtNotes" promptText="Notes" GridPane.columnSpan="2" GridPane.rowIndex="2" prefHeight="50"/>
    </GridPane>

    <HBox spacing="10">
        <Button text="✅ Ajouter" onAction="#handleAjouter" style="-fx-background-color: #2ecc71; -fx-text-fill: white;"/>
        <Button text="✏️ Modifier" onAction="#handleModifier" style="-fx-background-color: #f39c12; -fx-text-fill: white;"/>
        <Button text="🗑️ Supprimer" onAction="#handleSupprimer" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>

    <TableView fx:id="table" onMouseClicked="#handleRowSelect" prefHeight="200">
        <columns>
            <TableColumn fx:id="colDate" text="Date" prefWidth="150"/>
            <TableColumn fx:id="colDoctor" text="Docteur" prefWidth="100"/>
            <TableColumn fx:id="colStatus" text="Status" prefWidth="100"/>
            <TableColumn fx:id="colNotes" text="Notes" prefWidth="150"/>
        </columns>
    </TableView>
</VBox>