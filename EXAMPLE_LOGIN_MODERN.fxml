<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.shape.Circle?>
<?import javafx.geometry.Insets?>

<!--
  PinkShield Modern Login Screen - FXML Example

  Features:
  - Glassmorphic card design
  - Status indicator
  - Form validation
  - Modern typography
  - Responsive layout
  - Role-based login

  To use:
  1. Replace your login.fxml with this file
  2. Update LoginController to use FormValidator (see quick reference)
  3. Run: mvn javafx:run
-->

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.LoginController"
      styleClass="root"
      spacing="0"
      alignment="CENTER"
      prefWidth="800"
      prefHeight="600">

    <!-- Main container with padding -->
    <VBox VBox.vgrow="ALWAYS"
          spacing="30"
          alignment="CENTER"
          padding="40">

        <!-- Header: Logo + Title -->
        <VBox spacing="12" alignment="CENTER">
            <HBox alignment="CENTER" spacing="14">
                <ImageView fitWidth="50"
                           fitHeight="50"
                           preserveRatio="true">
                    <Image url="@../images/colored-logo.png"/>
                </ImageView>
                <Label text="PinkShield"
                       styleClass="title"/>
            </HBox>
            <Label text="Advanced Health Intelligence"
                   styleClass="tagline"
                   textAlignment="CENTER"/>
        </VBox>

        <!-- Main Glass Card -->
        <VBox styleClass="glass-card"
              spacing="20"
              maxWidth="480"
              prefWidth="480">

            <!-- Card Header -->
            <VBox spacing="8">
                <HBox spacing="12" alignment="CENTER_LEFT">
                    <Label text="🔐" styleClass="title"/>
                    <Label text="Secure Access" styleClass="card-title"/>
                </HBox>
                <Label text="Sign in to your health dashboard"
                       styleClass="subtitle"/>
            </VBox>

            <!-- Divider -->
            <Separator opacity="0.2"/>

            <!-- Status Bar -->
            <HBox styleClass="status-bar"
                  spacing="8"
                  alignment="CENTER_LEFT"
                  padding="10 14">
                <Circle radius="4" styleClass="status-dot"/>
                <Label text="All systems operational · Encrypted connection"
                       styleClass="status-text"
                       wrapText="true"/>
            </HBox>

            <!-- Email Field -->
            <VBox styleClass="field-group" spacing="6">
                <Label text="📧 EMAIL ADDRESS"
                       styleClass="field-label"/>
                <TextField fx:id="emailField"
                           promptText="your@email.com"
                           styleClass="text-field"
                           wrapText="false"/>
            </VBox>

            <!-- Password Field -->
            <VBox styleClass="field-group" spacing="6">
                <Label text="🔑 PASSWORD"
                       styleClass="field-label"/>
                <PasswordField fx:id="passwordField"
                               promptText="Enter your password"
                               styleClass="password-field"/>
            </VBox>

            <!-- Forgot Password Link -->
            <HBox alignment="CENTER_RIGHT">
                <Hyperlink text="Forgot password?"
                           style="-fx-text-fill: #c0396b; -fx-font-size: 11; -fx-underline: false;"
                           onAction="#handleForgotPassword"/>
            </HBox>

            <!-- Sign In Button -->
            <Button fx:id="loginButton"
                    text="🔓 Authenticate &amp; Enter"
                    styleClass="button"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    prefHeight="48"
                    style="-fx-font-size: 14; -fx-font-weight: bold;"/>

            <!-- Divider -->
            <Separator opacity="0.2"/>

            <!-- Register Link -->
            <HBox alignment="CENTER" spacing="6">
                <Label text="Don't have an account?"
                       styleClass="subtitle"
                       textAlignment="CENTER"/>
                <Hyperlink text="Create Account"
                           style="-fx-text-fill: #ff6ba8; -fx-font-weight: bold; -fx-underline: true; -fx-font-size: 12;"
                           onAction="#handleRegister"/>
            </HBox>
        </VBox>

        <!-- Footer Info -->
        <Label text="© 2026 PinkShield. All rights reserved."
               styleClass="subtitle"
               textAlignment="CENTER"
               wrapText="true"/>
    </VBox>

    <!-- Loading Overlay (hidden by default) -->
    <StackPane fx:id="loadingOverlay"
               style="-fx-background-color: rgba(0,0,0,0.3);"
               prefWidth="800"
               prefHeight="600"
               visible="false"
               managed="false">
        <VBox alignment="CENTER" spacing="16">
            <ProgressIndicator progress="-1"
                              style="-fx-font-size: 24;"/>
            <Label text="Authenticating..."
                   styleClass="subtitle"/>
        </VBox>
    </StackPane>

</VBox>

