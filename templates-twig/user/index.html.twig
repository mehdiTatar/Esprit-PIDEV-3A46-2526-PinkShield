{% extends "base.html.twig" %}

{% block title %}Patient Management — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    :root {
        --adm-navy:      #1e293b;
        --adm-blue:      #3b82f6;
        --adm-blue-lt:   rgba(59,130,246,0.1);
        --adm-green:     #22c55e;
        --adm-amber:     #f59e0b;
        --adm-red:       #ef4444;
        --adm-border:    #e2e8f0;
        --adm-surface:   #f8fafc;
    }

    body { background: var(--adm-surface) !important; }

    .page-wrap { display: flex; flex-direction: column; gap: 22px; }

    /* ── Header ── */
    .page-header {
        background: linear-gradient(135deg, #1e293b, #334155);
        color: #fff; border-radius: 16px; padding: 30px 36px;
        display: flex; align-items: center; justify-content: space-between;
        flex-wrap: wrap; gap: 16px;
        box-shadow: 0 8px 32px rgba(30,41,59,0.22);
        position: relative; overflow: hidden;
    }

    .page-header::before {
        content: '';
        position: absolute; inset: 0;
        background-image:
            linear-gradient(rgba(59,130,246,0.07) 1px, transparent 1px),
            linear-gradient(90deg, rgba(59,130,246,0.07) 1px, transparent 1px);
        background-size: 28px 28px;
        pointer-events: none;
    }

    .page-header > * { position: relative; z-index: 1; }
    .page-header h1  { font-size: 1.7rem; font-weight: 800; margin: 0 0 4px; }
    .page-header p   { margin: 0; opacity: 0.65; font-size: 0.88rem; }

    .header-actions { display: flex; gap: 10px; align-items: center; }

    .btn-add {
        display: inline-flex; align-items: center; gap: 8px;
        background: var(--adm-blue); color: #fff;
        padding: 10px 20px; border-radius: 10px;
        font-weight: 700; font-size: 0.88rem;
        text-decoration: none; transition: all 0.2s;
        border: none; cursor: pointer;
    }

    .btn-add:hover { background: #2563eb; color: #fff; transform: translateY(-1px); }

    /* ── Search bar ── */
    .search-card {
        background: #fff; border-radius: 12px; padding: 16px 22px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06);
        display: flex; align-items: center; gap: 12px; flex-wrap: wrap;
    }

    .search-input-wrap { display: flex; flex: 1; min-width: 220px; gap: 8px; }

    .search-input {
        flex: 1; padding: 9px 14px; border-radius: 9px;
        border: 1.5px solid var(--adm-border);
        font-size: 0.88rem; transition: border-color 0.2s;
        outline: none;
    }

    .search-input:focus { border-color: var(--adm-blue); }

    .btn-search {
        padding: 9px 18px; background: var(--adm-blue); color: #fff;
        border: none; border-radius: 9px; font-weight: 600;
        font-size: 0.85rem; cursor: pointer; transition: background 0.2s;
    }

    .btn-search:hover { background: #2563eb; }

    .btn-reset {
        padding: 9px 14px; background: #f1f5f9; color: #64748b;
        border: none; border-radius: 9px; font-weight: 600;
        font-size: 0.85rem; cursor: pointer; text-decoration: none;
        transition: background 0.2s;
    }

    .btn-reset:hover { background: #e2e8f0; color: #334155; }

    /* ── Table card ── */
    .table-card {
        background: #fff; border-radius: 14px;
        box-shadow: 0 1px 6px rgba(0,0,0,0.06); overflow: hidden;
    }

    .table-header {
        background: var(--adm-navy); color: #fff;
        padding: 15px 22px; display: flex; align-items: center;
        justify-content: space-between;
        font-weight: 700; font-size: 0.9rem;
    }

    .table-header i { color: var(--adm-blue); }

    .table-count {
        font-size: 0.75rem; font-weight: 700;
        background: rgba(59,130,246,0.2); color: #93c5fd;
        padding: 2px 9px; border-radius: 10px;
    }

    .users-table { width: 100%; border-collapse: collapse; }

    .users-table th {
        text-align: left; font-size: 0.7rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 0.5px;
        color: #94a3b8; padding: 14px 18px;
        border-bottom: 1px solid var(--adm-border);
        background: #f8fafc;
    }

    .users-table td {
        padding: 13px 18px; border-bottom: 1px solid #f1f5f9;
        font-size: 0.87rem; vertical-align: middle; color: #334155;
    }

    .users-table tr:last-child td { border-bottom: none; }
    .users-table tr:hover td { background: #f8fafc; }

    /* ── Avatar ── */
    .user-avatar {
        width: 38px; height: 38px; border-radius: 50%;
        background: var(--adm-blue-lt); color: var(--adm-blue);
        display: inline-flex; align-items: center; justify-content: center;
        font-weight: 700; font-size: 0.88rem; flex-shrink: 0;
    }

    .user-info { display: flex; align-items: center; gap: 10px; }
    .user-name  { font-weight: 600; color: #1e293b; }
    .user-email { font-size: 0.75rem; color: #94a3b8; }

    /* ── Status pills ── */
    .status-pill {
        display: inline-block; padding: 3px 11px;
        border-radius: 20px; font-size: 0.72rem; font-weight: 700;
    }

    .pill-active    { background: rgba(34,197,94,0.12);  color: #15803d; }
    .pill-inactive  { background: rgba(245,158,11,0.12); color: #92400e; }
    .pill-suspended { background: rgba(239,68,68,0.12);  color: #991b1b; }

    /* ── Action buttons ── */
    .action-btns { display: flex; align-items: center; gap: 6px; }

    .action-btn {
        display: inline-flex; align-items: center; gap: 5px;
        padding: 5px 12px; border-radius: 8px; font-size: 0.78rem;
        font-weight: 600; text-decoration: none; transition: all 0.18s;
        border: none; cursor: pointer;
    }

    .btn-view  { background: rgba(59,130,246,0.1);  color: #3b82f6; }
    .btn-view:hover  { background: #3b82f6; color: #fff; }

    .btn-edit  { background: rgba(245,158,11,0.1);  color: #d97706; }
    .btn-edit:hover  { background: #f59e0b; color: #fff; }

    .btn-on    { background: rgba(34,197,94,0.1);   color: #16a34a; }
    .btn-on:hover    { background: #22c55e; color: #fff; }

    .btn-off   { background: rgba(239,68,68,0.1);   color: #dc2626; }
    .btn-off:hover   { background: #ef4444; color: #fff; }

    .btn-del   { background: rgba(239,68,68,0.08);  color: #dc2626; }
    .btn-del:hover   { background: #ef4444; color: #fff; }

    /* ── Empty state ── */
    .empty-state {
        text-align: center; padding: 60px 20px; color: #94a3b8;
    }

    .empty-state i { font-size: 3rem; margin-bottom: 12px; display: block; }
    .empty-state p { font-size: 0.9rem; }
</style>
{% endblock %}

{% block body %}
<div class="page-wrap">

    {# ── Page Header ── #}
    <div class="page-header">
        <div>
            <h1><i class="fas fa-users me-2" style="color:#60a5fa;"></i>Patient Management</h1>
            <p>Admin · View, manage and monitor all registered patients</p>
        </div>
        <div class="header-actions">
            <a href="{{ path('admin_dashboard') }}" style="color:rgba(255,255,255,0.6); font-size:0.85rem; text-decoration:none;">
                <i class="fas fa-arrow-left me-1"></i> Dashboard
            </a>
            <a href="{{ path('user_new') }}" class="btn-add">
                <i class="fas fa-user-plus"></i> Add Patient
            </a>
        </div>
    </div>

    {# ── Flash messages ── #}
    {% for msg in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i>{{ msg }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% for msg in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i>{{ msg }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {# ── Search ── #}
    <div class="search-card">
        <i class="fas fa-search" style="color:#94a3b8; font-size:1rem;"></i>
        <form method="GET" action="{{ path('user_index') }}" class="search-input-wrap">
            <input type="number" name="search_id" class="search-input"
                   placeholder="Search by patient ID…" value="{{ searchId ?? '' }}" min="1">
            <button type="submit" class="btn-search"><i class="fas fa-search me-1"></i> Search</button>
        </form>
        {% if searchId %}
            <a href="{{ path('user_index') }}" class="btn-reset"><i class="fas fa-times me-1"></i> Clear</a>
        {% endif %}
    </div>

    {# ── Table ── #}
    <div class="table-card">
        <div class="table-header">
            <span><i class="fas fa-table me-2"></i>All Patients</span>
            <span class="table-count">{{ users|length }} record{{ users|length != 1 ? 's' : '' }}</span>
        </div>

        {% if users is empty %}
            <div class="empty-state">
                <i class="fas fa-user-slash"></i>
                <p>No patients found{% if searchId %} for ID #{{ searchId }}{% endif %}.</p>
                {% if searchId %}
                    <a href="{{ path('user_index') }}" class="btn-reset mt-2">← Show all patients</a>
                {% endif %}
            </div>
        {% else %}
            <table class="users-table">
                <thead>
                    <tr>
                        <th>#ID</th>
                        <th>Patient</th>
                        <th>Phone</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    {% for user in users %}
                    <tr>
                        <td style="font-weight:700; color:#94a3b8;">#{{ user.id }}</td>
                        <td>
                            <div class="user-info">
                                <div class="user-avatar">
                                    {{ user.firstName ? user.firstName|first|upper : user.email|first|upper }}
                                </div>
                                <div>
                                    <div class="user-name">{{ user.firstName ?? '' }} {{ user.lastName ?? '' }}</div>
                                    <div class="user-email">{{ user.email }}</div>
                                </div>
                            </div>
                        </td>
                        <td>{{ user.phone ?? '—' }}</td>
                        <td>
                            <span class="status-pill pill-{{ user.status ?? 'active' }}">
                                {{ user.status ?? 'active' }}
                            </span>
                        </td>
                        <td>
                            <div class="action-btns">
                                <a href="{{ path('user_show', {id: user.id}) }}" class="action-btn btn-view">
                                    <i class="fas fa-eye"></i> View
                                </a>
                                <a href="{{ path('user_edit', {id: user.id}) }}" class="action-btn btn-edit">
                                    <i class="fas fa-pen"></i> Edit
                                </a>

                                {% if user.status != 'active' %}
                                    <button type="button" class="action-btn btn-on"
                                            onclick="postAction('{{ path('user_activate', {id: user.id}) }}', 'Activate this account?', '{{ csrf_token('activate' ~ user.id) }}')">
                                        <i class="fas fa-check"></i> Activate
                                    </button>
                                {% else %}
                                    <button type="button" class="action-btn btn-off"
                                            onclick="postAction('{{ path('user_deactivate', {id: user.id}) }}', 'Deactivate this account?', '{{ csrf_token('deactivate' ~ user.id) }}')">
                                        <i class="fas fa-ban"></i> Deactivate
                                    </button>
                                {% endif %}

                                <button type="button" class="action-btn btn-del"
                                        onclick="postAction('{{ path('user_delete', {id: user.id}) }}', 'Delete patient #{{ user.id }}? This cannot be undone.', '{{ csrf_token('delete' ~ user.id) }}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        {% endif %}
    </div>

</div>
{% endblock %}
