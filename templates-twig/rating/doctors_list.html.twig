{% extends "base.html.twig" %}

{% block title %}Rate Our Doctors — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    .rating-hero {
        background: linear-gradient(135deg, var(--primary) 0%, #e8557a 100%);
        border-radius: 16px;
        padding: 36px 40px;
        color: #fff;
        margin-bottom: 28px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
        box-shadow: 0 8px 30px rgba(192,57,107,0.22);
        position: relative;
        overflow: hidden;
    }

    .rating-hero::after {
        content: '★';
        position: absolute;
        right: -10px; top: -20px;
        font-size: 10rem;
        opacity: 0.06;
        color: #fff;
        line-height: 1;
    }

    .rating-hero h1 { font-size: 1.85rem; font-weight: 800; margin: 0 0 6px; letter-spacing: -0.4px; }
    .rating-hero p  { margin: 0; opacity: 0.85; font-size: 0.92rem; }

    .hero-stat {
        background: rgba(255,255,255,0.18);
        border-radius: 12px;
        padding: 14px 24px;
        text-align: center;
        backdrop-filter: blur(6px);
    }

    .hero-stat .stat-val { font-size: 1.6rem; font-weight: 800; display: block; }
    .hero-stat .stat-lbl { font-size: 0.76rem; opacity: 0.82; }

    /* Doctor Cards Grid */
    .doctors-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
        gap: 20px;
    }

    .doctor-card {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid var(--border);
        overflow: hidden;
        transition: all 0.24s ease;
        display: flex;
        flex-direction: column;
    }

    .doctor-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 12px 32px rgba(192,57,107,0.14);
        border-color: #f3c6d8;
    }

    .doctor-card-head {
        background: linear-gradient(135deg, var(--primary), #e8557a);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        color: #fff;
    }

    .doctor-card-head .doc-name-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
    }

    .doc-avatar {
        width: 42px; height: 42px;
        border-radius: 50%;
        background: rgba(255,255,255,0.25);
        display: flex; align-items: center; justify-content: center;
        font-weight: 800;
        font-size: 1.1rem;
        border: 2px solid rgba(255,255,255,0.4);
        flex-shrink: 0;
    }

    .doc-name { font-weight: 700; font-size: 0.95rem; }
    .doc-spec { font-size: 0.78rem; opacity: 0.82; }

    .status-chip {
        display: inline-flex;
        align-items: center;
        gap: 4px;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.72rem;
        font-weight: 700;
        background: rgba(255,255,255,0.2);
        border: 1px solid rgba(255,255,255,0.3);
    }

    .doctor-card-body { padding: 20px; flex: 1; display: flex; flex-direction: column; gap: 12px; }

    .doc-detail {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 0.85rem;
        color: var(--text-gray);
    }

    .doc-detail i { width: 16px; text-align: center; color: var(--primary); opacity: 0.7; }

    /* Stars */
    .rating-row {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px;
        background: #fff5f8;
        border-radius: 10px;
        margin-top: 4px;
    }

    .star-group { display: flex; gap: 2px; }

    .star-group i { font-size: 1rem; }
    .star-on  { color: #f59e0b; }
    .star-off { color: #e5e7eb; }

    .rating-score {
        font-weight: 800;
        font-size: 1.1rem;
        color: var(--text-dark);
    }

    .rating-count { font-size: 0.78rem; color: var(--text-muted); }

    .doctor-card-actions { padding: 16px 20px; border-top: 1px solid var(--border); }

    /* no doctors */
    .no-doctors {
        text-align: center;
        padding: 64px 0;
        color: var(--text-muted);
    }

    .no-doctors i { font-size: 3.5rem; color: var(--primary); opacity: 0.3; margin-bottom: 16px; display: block; }
</style>
{% endblock %}

{% block body %}
<div>
    {# Hero #}
    <div class="rating-hero">
        <div>
            <h1><i class="fas fa-star me-2" style="opacity:0.85;"></i>Rate Our Doctors</h1>
            <p>Your honest reviews help other patients find the right care</p>
        </div>
        {% if doctors|length > 0 %}
            <div class="hero-stat">
                <span class="stat-val">{{ doctors|length }}</span>
                <span class="stat-lbl">Doctors Available</span>
            </div>
        {% endif %}
    </div>

    {% if doctors|length > 0 %}
        <div class="doctors-grid">
            {% for doctor in doctors %}
                {% set dr = doctorRatings[doctor.id] %}
                <div class="doctor-card">
                    {# Header #}
                    <div class="doctor-card-head">
                        <div class="doc-name-wrap">
                            <div class="doc-avatar">{{ doctor.fullName|first|upper }}</div>
                            <div>
                                <div class="doc-name">Dr. {{ doctor.fullName }}</div>
                                <div class="doc-spec">{{ doctor.speciality }}</div>
                            </div>
                        </div>
                        <div class="status-chip">
                            {% if doctor.status == 'active' %}
                                <i class="fas fa-circle" style="font-size:0.5rem;color:#86efac;"></i> Active
                            {% else %}
                                <i class="fas fa-circle" style="font-size:0.5rem;color:#f87171;"></i> {{ doctor.status|capitalize }}
                            {% endif %}
                        </div>
                    </div>

                    {# Body #}
                    <div class="doctor-card-body">
                        {% if doctor.email %}
                            <div class="doc-detail">
                                <i class="fas fa-envelope"></i>
                                <span>{{ doctor.email }}</span>
                            </div>
                        {% endif %}
                        {% if doctor.phone %}
                            <div class="doc-detail">
                                <i class="fas fa-phone"></i>
                                <span>{{ doctor.phone }}</span>
                            </div>
                        {% endif %}
                        {% if doctor.address %}
                            <div class="doc-detail">
                                <i class="fas fa-map-marker-alt"></i>
                                <span>{{ doctor.address }}</span>
                            </div>
                        {% endif %}

                        {# Rating display #}
                        <div class="rating-row">
                            {% if dr.average %}
                                <div class="star-group">
                                    {% for i in 1..5 %}
                                        <i class="fas fa-star {% if i <= dr.average|round %}star-on{% else %}star-off{% endif %}"></i>
                                    {% endfor %}
                                </div>
                                <div>
                                    <span class="rating-score">{{ dr.average|round(1) }}</span>
                                    <span style="color:var(--text-muted);font-size:0.8rem;">/5</span>
                                    <div class="rating-count">{{ dr.count }} review{{ dr.count != 1 ? 's' : '' }}</div>
                                </div>
                            {% else %}
                                <div class="star-group">
                                    {% for i in 1..5 %}<i class="fas fa-star star-off"></i>{% endfor %}
                                </div>
                                <div class="rating-count">No reviews yet — be the first!</div>
                            {% endif %}
                        </div>
                    </div>

                    {# Action button #}
                    <div class="doctor-card-actions">
                        {% if dr.userRating %}
                            <a href="{{ path('rating_rate_doctor', {id: doctor.id}) }}"
                               class="btn btn-warning w-100 d-flex align-items-center justify-content-center gap-2 fw-600">
                                <i class="fas fa-edit"></i> Update Your Rating
                            </a>
                        {% else %}
                            <a href="{{ path('rating_rate_doctor', {id: doctor.id}) }}"
                               class="btn btn-primary w-100 d-flex align-items-center justify-content-center gap-2">
                                <i class="fas fa-star"></i> Rate This Doctor
                            </a>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="no-doctors">
            <i class="fas fa-user-md d-block"></i>
            <h5>No doctors available yet</h5>
            <p>Check back later to rate our healthcare professionals.</p>
        </div>
    {% endif %}
</div>
{% endblock %}
