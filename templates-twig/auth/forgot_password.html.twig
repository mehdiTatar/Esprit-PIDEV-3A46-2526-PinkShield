{% extends "base.html.twig" %}

{% block title %}Mot de passe oublié — PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ── Override base layout for auth pages ── */
    .navbar { position: static !important; }

    body {
        background: linear-gradient(135deg, #d4f0e6 0%, #b8e6db 100%) !important;
        min-height: 100vh;
    }

    aside.sidebar,
    .sidebar-toggle-btn { display: none !important; }

    main {
        margin-left: 0 !important;
        margin-top: 0 !important;
        width: 100% !important;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: calc(100vh - 64px);
        padding: 60px 24px !important;
        background: radial-gradient(circle at 10% 20%, rgba(45, 138, 98, 0.05) 0%, transparent 40%),
                    radial-gradient(circle at 90% 80%, rgba(45, 138, 98, 0.05) 0%, transparent 40%);
    }

    footer, .site-footer {
        margin-left: 0 !important;
        width: 100% !important;
    }

    .container-desktop {
        max-width: 100% !important;
        padding: 0 !important;
        width: 100%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        flex-grow: 1;
    }

    /* ── Card ── */
    .auth-wrapper {
        width: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding-bottom: 20px;
        margin: auto;
    }

    .auth-container {
        display: grid;
        grid-template-columns: 1.1fr 1fr;
        max-width: 1000px;
        width: 100%;
        background: #fff;
        border-radius: 20px;
        box-shadow: 0 24px 64px rgba(0,0,0,0.12);
        overflow: hidden;
        animation: cardAppear 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes cardAppear {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    /* ── Branding panel ── */
    .auth-branding {
        background: linear-gradient(145deg, #2d8a62 0%, #1e5e43 100%);
        color: #fff;
        padding: 64px 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        position: relative;
        overflow: hidden;
        min-height: 440px;
    }

    .auth-branding::before,
    .auth-branding::after {
        content: '';
        position: absolute;
        border-radius: 50%;
        opacity: 0.08;
        background: #fff;
    }
    .auth-branding::before { width: 350px; height: 350px; top: -100px; right: -100px; }
    .auth-branding::after  { width: 220px; height: 220px; bottom: -80px; left: -80px; }
    .auth-branding > * { position: relative; z-index: 1; }

    .logo-svg {
        width: 85px; height: 85px;
        margin-bottom: 24px;
        filter: drop-shadow(0 8px 16px rgba(0,0,0,0.15));
        animation: float 4s ease-in-out infinite;
    }

    @keyframes float {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-10px); }
    }

    .auth-branding h2 {
        font-size: 2.2rem; font-weight: 850; margin: 0 0 10px;
        letter-spacing: -0.5px;
    }

    .auth-branding .tagline {
        font-size: 1rem; opacity: 0.9; margin: 0 0 36px;
        font-weight: 500;
    }

    .info-box {
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.15);
        border-radius: 16px;
        padding: 24px;
        text-align: left;
        backdrop-filter: blur(8px);
        font-size: 0.9rem;
        line-height: 1.65;
        max-width: 320px;
    }

    .info-box i { margin-right: 10px; color: #a8d5c2; }
    .info-box p { margin-bottom: 8px; }
    .info-box p:last-child { margin-bottom: 0; }

    /* ── Form panel ── */
    .auth-form-wrapper {
        padding: 64px 48px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        background: #fff;
    }

    .auth-form-wrapper h3 {
        font-size: 1.7rem; font-weight: 800;
        color: #1e293b;
        margin-bottom: 8px;
        letter-spacing: -0.3px;
    }

    .auth-form-wrapper .subtitle {
        color: #64748b;
        font-size: 0.93rem;
        margin-bottom: 32px;
        line-height: 1.6;
    }

    .form-group { margin-bottom: 22px; }

    .form-label {
        font-weight: 650;
        color: #334155;
        margin-bottom: 8px;
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 0.9rem;
    }

    .form-label i { color: #2d8a62; font-size: 0.95rem; }

    .form-control {
        border: 1.5px solid #e2e8f0;
        border-radius: 12px;
        padding: 13px 16px;
        font-size: 0.95rem;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        background: #f8fafc;
        width: 100%;
        color: #1e293b;
    }

    .form-control::placeholder { color: #94a3b8; }
    .form-control:hover { border-color: #cbd5e1; }
    .form-control:focus {
        border-color: #2d8a62;
        box-shadow: 0 0 0 4px rgba(45, 138, 98, 0.1);
        outline: none;
        background: #fff;
    }

    .btn-submit {
        background: linear-gradient(135deg, #2d8a62 0%, #1e5e43 100%);
        border: none;
        color: #fff;
        font-weight: 700;
        padding: 14px 24px;
        border-radius: 12px;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        margin-top: 12px;
        font-size: 1rem;
        width: 100%;
        cursor: pointer;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 12px rgba(45, 138, 98, 0.2);
    }

    .btn-submit:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(45, 138, 98, 0.3);
        filter: brightness(1.05);
    }

    .btn-submit:active { transform: translateY(0); }

    .back-link {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        margin: 24px auto 0;
        color: #2d8a62;
        font-size: 0.9rem;
        font-weight: 650;
        text-decoration: none;
        transition: all 0.2s;
        gap: 6px;
    }

    .back-link:hover { color: #1e5e43; transform: translateX(-3px); }

    .alert {
        margin-bottom: 24px;
        border-radius: 12px;
        padding: 14px 18px;
        font-size: 0.9rem;
        display: flex;
        align-items: center;
        gap: 10px;
        font-weight: 500;
    }

    .alert-success {
        background: #ecfdf5;
        border: 1px solid #d1fae5;
        color: #065f46;
    }

    .alert-danger {
        background: #fef2f2;
        border: 1px solid #fee2e2;
        color: #991b1b;
    }

    @keyframes fadeUp {
        from { opacity: 0; transform: translateY(12px); }
        to   { opacity: 1; transform: translateY(0); }
    }

    .auth-form-wrapper > * { animation: fadeUp 0.6s ease both; }
    .auth-form-wrapper h3 { animation-delay: 0.1s; }
    .auth-form-wrapper .subtitle { animation-delay: 0.15s; }
    .alert { animation-delay: 0.2s; }
    .form-group { animation-delay: 0.25s; }
    .btn-submit  { animation-delay: 0.3s; }
    .back-link   { animation-delay: 0.35s; }

    @media (max-width: 900px) {
        .auth-container { grid-template-columns: 1fr; max-width: 500px; }
        .auth-branding { padding: 48px 32px; min-height: auto; }
        .auth-form-wrapper { padding: 48px 32px; }
    }
</style>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-container">

        {# ── Left: Branding ── #}
        <div class="auth-branding">
            <svg class="logo-svg" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <defs>
                    <linearGradient id="shieldGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%"   style="stop-color:#ffffff;stop-opacity:0.95"/>
                        <stop offset="100%" style="stop-color:#d4f0e6;stop-opacity:0.95"/>
                    </linearGradient>
                </defs>
                <path d="M100 20 C100 20 60 40 60 90 C60 130 100 170 100 170 C100 170 140 130 140 90 C140 40 100 20 100 20Z"
                      fill="url(#shieldGrad)" stroke="rgba(255,255,255,0.6)" stroke-width="2"/>
                <path d="M100 75 C100 75 92 68 86 68 C80 68 76 72 76 78 C76 85 85 95 100 110 C115 95 124 85 124 78 C124 72 120 68 114 68 C108 68 100 75 100 75Z"
                      fill="#2d8a62"/>
            </svg>

            <h2>PinkShield</h2>
            <p class="tagline">Récupération de compte sécurisée</p>

            <div class="info-box">
                <p><i class="fas fa-info-circle"></i><strong>Comment ça marche ?</strong></p>
                <p>1. Entrez votre adresse email</p>
                <p>2. Recevez un lien sécurisé par email</p>
                <p>3. Choisissez un nouveau mot de passe</p>
                <p style="margin-top:10px; opacity:0.8; font-size:0.82rem;">
                    <i class="fas fa-clock"></i> Le lien expire après <strong>1 heure</strong>
                </p>
            </div>
        </div>

        {# ── Right: Form ── #}
        <div class="auth-form-wrapper">
            <h3><i class="fas fa-shield-alt" style="color:#2d8a62; margin-right:8px;"></i>Mot de passe oublié</h3>
            <p class="subtitle">Saisissez votre email et nous vous enverrons un lien pour réinitialiser votre mot de passe.</p>

            {% for flash_type, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ flash_type }}">
                        <i class="fas fa-{{ flash_type == 'success' ? 'check-circle' : 'exclamation-circle' }} me-2"></i>
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            <form method="post" action="{{ path('forgot_password') }}" novalidate id="forgotForm">
                <div class="form-group">
                    <label for="email" class="form-label">
                        <i class="fas fa-envelope"></i> Adresse email
                    </label>
                    <input type="email"
                           name="email"
                           id="email"
                           class="form-control"
                           placeholder="votre@email.com"
                           autocomplete="email"
                           data-ajax-validate="email"
                           required>
                </div>

                <button type="submit" class="btn-submit" id="submitBtn">
                    <i class="fas fa-paper-plane me-2"></i> Envoyer le lien de réinitialisation
                </button>
            </form>

            <a href="{{ path('login') }}" class="back-link">
                <i class="fas fa-arrow-left me-1"></i> Retour à la connexion
            </a>
        </div>

    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('forgotForm');
    if (!form) return;
    AjaxValidator.attachBlur(form);
    AjaxValidator.attachSubmit(form);
});
</script>
{% endblock %}
