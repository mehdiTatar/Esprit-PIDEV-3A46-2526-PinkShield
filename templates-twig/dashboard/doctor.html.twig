{% extends "base.html.twig" %}

{% block title %}Doctor Portal · PinkShield{% endblock %}

{% block stylesheets %}
<style>
    /* ─── Doctor Clinical Portal ───────────────────────────── */
    :root {
        --doc-teal:      #14b8a6;
        --doc-teal-d:    #0d9488;
        --doc-emerald:   #10b981;
        --doc-sky:       #38bdf8;
        --doc-indigo:    #6366f1;
        --doc-amber:     #f59e0b;
    }

    body {
        background: #030f0e !important;
        background-image:
            radial-gradient(ellipse at 0% 0%, rgba(20,184,166,0.1) 0%, transparent 55%),
            radial-gradient(ellipse at 100% 100%, rgba(16,185,129,0.06) 0%, transparent 50%) !important;
    }

    [data-sidebar-role='doctor'] .sidebar {
        background: linear-gradient(180deg, #030f0e 0%, #071a16 100%);
        border-right-color: rgba(20,184,166,0.15);
    }
    [data-sidebar-role='doctor'] .sidebar-toggle-btn {
        background: linear-gradient(135deg, #0d9488, #14b8a6) !important;
        box-shadow: 0 4px 16px rgba(20,184,166,0.45) !important;
    }

    /* ─── Stethoscope Watermark ─────────────────────────────── */
    .doc-watermark {
        position: fixed; right: -60px; bottom: -60px;
        font-size: 28rem; color: rgba(20,184,166,0.02);
        pointer-events: none !important; z-index: -1;
        transform: rotate(-20deg);
    }

    /* ─── Page Header ────────────────────────────────────────── */
    .doc-header {
        display: flex; align-items: flex-start;
        justify-content: space-between; margin-bottom: 32px;
        flex-wrap: wrap; gap: 16px;
        padding-bottom: 24px;
        border-bottom: 1px solid rgba(20,184,166,0.12);
        position: relative; z-index: 1;
    }
    .doc-greeting {
        font-size: 0.75rem; font-weight: 700;
        text-transform: uppercase; letter-spacing: 2px;
        color: var(--doc-teal); margin-bottom: 4px;
    }
    .doc-title {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.8rem; font-weight: 900; color: #fff;
        text-shadow: 0 0 40px rgba(20,184,166,0.3);
    }
    .doc-title span { color: var(--doc-teal); }
    .doc-subtitle { color: rgba(255,255,255,0.35); font-size: 0.84rem; margin-top: 4px; }
    .doc-btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 10px 18px; border-radius: 10px;
        font-weight: 600; font-size: 0.84rem;
        cursor: pointer; transition: all 0.22s;
        text-decoration: none; border: none;
    }
    .doc-btn-primary {
        background: linear-gradient(135deg, #0d9488, #14b8a6);
        color: #fff; box-shadow: 0 4px 16px rgba(20,184,166,0.35);
    }
    .doc-btn-primary:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(20,184,166,0.5); color: #fff; }
    .doc-btn-ghost {
        background: rgba(20,184,166,0.08);
        border: 1px solid rgba(20,184,166,0.25);
        color: var(--doc-teal);
    }
    .doc-btn-ghost:hover { background: rgba(20,184,166,0.15); color: #fff; }

    /* ─── Stat Cards ─────────────────────────────────────────── */
    .doc-stats {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 16px; margin-bottom: 28px;
        position: relative; z-index: 1;
    }
    .doc-stat {
        background: rgba(255,255,255,0.025);
        border: 1px solid rgba(20,184,166,0.1);
        border-radius: 16px; padding: 20px;
        position: relative; overflow: hidden;
        transition: all 0.25s;
    }
    .doc-stat::before {
        content: ''; position: absolute;
        top: 0; left: 0; right: 0; height: 2px;
        background: linear-gradient(90deg, var(--doc-teal), var(--doc-emerald));
    }
    .doc-stat:hover { transform: translateY(-3px); border-color: rgba(20,184,166,0.25); box-shadow: 0 10px 32px rgba(0,0,0,0.4); }
    .doc-stat-icon {
        width: 40px; height: 40px; border-radius: 10px;
        background: rgba(20,184,166,0.12); color: var(--doc-teal);
        display: flex; align-items: center; justify-content: center;
        font-size: 1rem; margin-bottom: 12px;
    }
    .doc-stat-val {
        font-family: 'Orbitron', sans-serif;
        font-size: 1.8rem; font-weight: 900; color: #fff;
    }
    .doc-stat-lbl { font-size: 0.74rem; color: rgba(255,255,255,0.35); text-transform: uppercase; letter-spacing: 0.8px; margin-top: 2px; }
    .doc-stat-sub {
        font-size: 0.7rem; color: var(--doc-teal);
        margin-top: 8px; font-weight: 600;
        display: flex; align-items: center; gap: 4px;
    }
    .doc-stat-bg {
        position: absolute; right: -5px; bottom: -10px;
        font-size: 4.5rem; opacity: 0.04;
        color: var(--doc-teal);
    }

    /* ─── Main layout ──────────────────────────────────────── */
    .doc-grid { display: grid; grid-template-columns: 1.5fr 1fr; gap: 20px; margin-bottom: 24px; position: relative; z-index: 1; }
    .doc-grid-3 { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; margin-bottom: 24px; position: relative; z-index: 1; }

    /* ─── Panel ──────────────────────────────────────────────── */
    .doc-panel {
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(20,184,166,0.1);
        border-radius: 16px; overflow: hidden;
    }
    .doc-panel-header {
        display: flex; align-items: center; justify-content: space-between;
        padding: 16px 20px 14px;
        border-bottom: 1px solid rgba(255,255,255,0.05);
        background: rgba(20,184,166,0.03);
    }
    .doc-panel-title {
        font-size: 0.84rem; font-weight: 700; color: #fff;
        display: flex; align-items: center; gap: 8px;
    }
    .doc-panel-title i { color: var(--doc-teal); }
    .doc-panel-action {
        font-size: 0.74rem; color: var(--doc-teal); text-decoration: none;
        font-weight: 600; padding: 4px 10px;
        background: rgba(20,184,166,0.08); border-radius: 6px;
        transition: all 0.2s;
    }
    .doc-panel-action:hover { background: rgba(20,184,166,0.18); }
    .doc-panel-body { padding: 18px 20px; }

    /* ─── Appointment List ──────────────────────────────────── */
    .appt-list { display: flex; flex-direction: column; gap: 10px; }
    .appt-item {
        display: flex; align-items: center; gap: 14px;
        padding: 13px 16px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        border-radius: 12px; transition: all 0.2s;
        border-left: 3px solid var(--doc-teal);
    }
    .appt-item:hover { background: rgba(20,184,166,0.06); border-color: rgba(20,184,166,0.2); }
    .appt-time {
        min-width: 52px; text-align: center;
        font-family: 'Orbitron', sans-serif;
        font-size: 0.7rem; font-weight: 700; color: var(--doc-teal);
        background: rgba(20,184,166,0.1); border-radius: 8px; padding: 6px 8px;
    }
    .appt-info { flex: 1; min-width: 0; }
    .appt-name { font-weight: 600; color: #fff; font-size: 0.84rem; }
    .appt-reason { font-size: 0.72rem; color: rgba(255,255,255,0.35); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .appt-status {
        font-size: 0.68rem; font-weight: 700; text-transform: uppercase;
        padding: 3px 9px; border-radius: 12px; letter-spacing: 0.5px;
        white-space: nowrap;
    }
    .appt-status.confirmed { background: rgba(20,184,166,0.12); color: var(--doc-teal); }
    .appt-status.pending   { background: rgba(245,158,11,0.12); color: #fbbf24; }
    .appt-status.done      { background: rgba(255,255,255,0.06); color: rgba(255,255,255,0.3); }

    /* ─── Patient Card ──────────────────────────────────────── */
    .patient-card {
        display: flex; align-items: center; gap: 12px;
        padding: 12px; border-radius: 12px;
        background: rgba(255,255,255,0.02);
        border: 1px solid rgba(255,255,255,0.05);
        transition: all 0.2s; margin-bottom: 8px;
    }
    .patient-card:hover { background: rgba(20,184,166,0.05); border-color: rgba(20,184,166,0.15); }
    .patient-card:last-child { margin-bottom: 0; }
    .patient-avatar {
        width: 36px; height: 36px; border-radius: 50%;
        background: linear-gradient(135deg, #0d9488, #14b8a6);
        color: #fff; display: flex; align-items: center; justify-content: center;
        font-size: 0.8rem; font-weight: 700; flex-shrink: 0;
    }
    .patient-name { font-weight: 600; color: #fff; font-size: 0.82rem; }
    .patient-detail { font-size: 0.7rem; color: rgba(255,255,255,0.35); }
    .patient-action { margin-left: auto; }

    /* ─── Feature Panels ────────────────────────────────────── */
    .doc-feature {
        background: rgba(255,255,255,0.025);
        border: 1px solid rgba(20,184,166,0.1);
        border-radius: 16px; padding: 22px;
        text-align: center; transition: all 0.25s;
        position: relative; z-index: 1;
        text-decoration: none; display: block;
    }
    .doc-feature:hover {
        transform: translateY(-4px);
        border-color: rgba(20,184,166,0.3);
        box-shadow: 0 12px 40px rgba(0,0,0,0.4);
        background: rgba(20,184,166,0.06);
    }
    .doc-feature-icon {
        width: 56px; height: 56px; border-radius: 16px;
        margin: 0 auto 14px;
        display: flex; align-items: center; justify-content: center; font-size: 1.4rem;
    }
    .doc-feature-title { font-weight: 700; color: #fff; font-size: 0.9rem; margin-bottom: 4px; }
    .doc-feature-desc { font-size: 0.75rem; color: rgba(255,255,255,0.35); line-height: 1.5; }
    .doc-feature-badge {
        display: inline-flex; align-items: center; gap: 4px;
        margin-top: 12px; padding: 3px 10px; border-radius: 12px;
        font-size: 0.7rem; font-weight: 700;
    }

    /* ─── EKG line ──────────────────────────────────────────── */
    .ekg-line {
        height: 2px; overflow: hidden;
        background: rgba(20,184,166,0.05);
        margin-bottom: 28px; border-radius: 2px;
        position: relative; z-index: 1;
    }
    .ekg-line::after {
        content: '';
        position: absolute; top: 0; left: -200%;
        width: 200%; height: 100%;
        background: linear-gradient(90deg, transparent 0%, var(--doc-teal) 40%, rgba(16,185,129,0.8) 50%, transparent 60%);
        animation: ekgSweep 4s linear infinite;
    }
    @keyframes ekgSweep { 0%{left:-200%} 100%{left:100%} }

    @media (max-width: 1100px) { .doc-stats { grid-template-columns: repeat(2,1fr); } }
    @media (max-width: 900px)  { .doc-grid, .doc-grid-3 { grid-template-columns: 1fr; } }
    @media (max-width: 600px)  { .doc-stats { grid-template-columns: 1fr; } }
</style>
{% endblock %}

{% block body %}
<!-- Stethoscope watermark -->
<div class="doc-watermark"><i class="fas fa-stethoscope"></i></div>

<!-- EKG divider -->
<div class="ekg-line"></div>

<!-- ── Header ──────────────────────────────────────────── -->
<div class="doc-header">
    <div>
        <div class="doc-greeting">🩺 Clinical Portal — Physician Access</div>
        <h1 class="doc-title">Doctor <span>Hub</span></h1>
        <div class="doc-subtitle">
            Welcome back, <strong style="color:#fff;">Dr. {{ app.user.userIdentifier|split('@')|first }}</strong>
            · {{ "now"|date("l, d F Y") }}
        </div>
    </div>
    <div style="display:flex;gap:10px;align-items:center;flex-wrap:wrap;">
        <a href="{{ path('appointment_index') }}" class="doc-btn doc-btn-ghost">
            <i class="fas fa-calendar-plus"></i> Appointments
        </a>
        <a href="{{ path('parapharmacy_index') }}" class="doc-btn doc-btn-primary">
            <i class="fas fa-pills"></i> Pharmacy
        </a>
    </div>
</div>

<!-- ── Stats ───────────────────────────────────────────── -->
<div class="doc-stats">
    <div class="doc-stat">
        <div class="doc-stat-icon"><i class="fas fa-calendar-day"></i></div>
        <div class="doc-stat-val">{{ todayAppointments ?? '—' }}</div>
        <div class="doc-stat-lbl">Today's Appointments</div>
        <div class="doc-stat-sub"><i class="fas fa-clock"></i> Next in 30 min</div>
        <i class="fas fa-calendar doc-stat-bg"></i>
    </div>
    <div class="doc-stat">
        <div class="doc-stat-icon"><i class="fas fa-users"></i></div>
        <div class="doc-stat-val">{{ myPatients ?? '—' }}</div>
        <div class="doc-stat-lbl">My Patients</div>
        <div class="doc-stat-sub"><i class="fas fa-user-plus"></i> 2 new this week</div>
        <i class="fas fa-user-friends doc-stat-bg"></i>
    </div>
    <div class="doc-stat">
        <div class="doc-stat-icon"><i class="fas fa-pills"></i></div>
        <div class="doc-stat-val">{{ prescriptions ?? '—' }}</div>
        <div class="doc-stat-lbl">Prescriptions</div>
        <div class="doc-stat-sub"><i class="fas fa-check"></i> 3 pending review</div>
        <i class="fas fa-prescription-bottle doc-stat-bg"></i>
    </div>
    <div class="doc-stat">
        <div class="doc-stat-icon"><i class="fas fa-star"></i></div>
        <div class="doc-stat-val">{{ rating ?? '4.9' }}</div>
        <div class="doc-stat-lbl">Avg Rating</div>
        <div class="doc-stat-sub"><i class="fas fa-star" style="color:#f59e0b;"></i> Based on 48 reviews</div>
        <i class="fas fa-star doc-stat-bg"></i>
    </div>
</div>

<!-- ── Main Content ────────────────────────────────────── -->
<div class="doc-grid">
    <!-- Today's Schedule -->
    <div class="doc-panel">
        <div class="doc-panel-header">
            <div class="doc-panel-title"><i class="fas fa-calendar-alt"></i> Today's Schedule</div>
            <a href="{{ path('appointment_index') }}" class="doc-panel-action">Full Calendar →</a>
        </div>
        <div class="doc-panel-body">
            <div class="appt-list">
                {% if appointments is defined and appointments %}
                    {% for appt in appointments|slice(0,5) %}
                    <div class="appt-item">
                        <div class="appt-time">
                            {{ appt.appointmentDate is defined ? appt.appointmentDate|date('H:i') : '10:00' }}
                        </div>
                        <div class="appt-info">
                            <div class="appt-name">
                                {{ appt.user is defined ? appt.user.email|split('@')|first : 'Patient' }}
                            </div>
                            <div class="appt-reason">
                                {{ appt.reason is defined ? appt.reason : 'General Consultation' }}
                            </div>
                        </div>
                        <span class="appt-status {{ appt.status is defined and appt.status == 'confirmed' ? 'confirmed' : 'pending' }}">
                            {{ appt.status is defined ? appt.status|capitalize : 'Pending' }}
                        </span>
                    </div>
                    {% endfor %}
                {% else %}
                    <div class="appt-item">
                        <div class="appt-time">09:00</div>
                        <div class="appt-info"><div class="appt-name">Morning Rounds</div><div class="appt-reason">General check-up</div></div>
                        <span class="appt-status confirmed">Confirmed</span>
                    </div>
                    <div class="appt-item">
                        <div class="appt-time">11:30</div>
                        <div class="appt-info"><div class="appt-name">Follow-up Visit</div><div class="appt-reason">Post-surgery review</div></div>
                        <span class="appt-status pending">Pending</span>
                    </div>
                    <div class="appt-item">
                        <div class="appt-time">14:00</div>
                        <div class="appt-info"><div class="appt-name">Initial Consultation</div><div class="appt-reason">New patient intake</div></div>
                        <span class="appt-status confirmed">Confirmed</span>
                    </div>
                    <div class="appt-item" style="opacity:0.5;">
                        <div class="appt-time">16:00</div>
                        <div class="appt-info"><div class="appt-name">Lab Results Review</div><div class="appt-reason">Blood work analysis</div></div>
                        <span class="appt-status done">Done</span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>

    <!-- My Patients -->
    <div class="doc-panel">
        <div class="doc-panel-header">
            <div class="doc-panel-title"><i class="fas fa-user-injured"></i> Recent Patients</div>
            <a href="{{ path('appointment_index') }}" class="doc-panel-action">View All →</a>
        </div>
        <div class="doc-panel-body">
            {% if recentPatients is defined and recentPatients %}
                {% for patient in recentPatients|slice(0,4) %}
                <div class="patient-card">
                    <div class="patient-avatar">{{ patient.email|first|upper }}</div>
                    <div>
                        <div class="patient-name">{{ patient.email|split('@')|first }}</div>
                        <div class="patient-detail">Last visit: Recent</div>
                    </div>
                    <div class="patient-action">
                        <a href="#" class="doc-btn doc-btn-ghost" style="padding:5px 11px;font-size:0.72rem;">
                            <i class="fas fa-notes-medical"></i>
                        </a>
                    </div>
                </div>
                {% endfor %}
            {% else %}
                <div class="patient-card">
                    <div class="patient-avatar">A</div>
                    <div><div class="patient-name">Alice Tremblay</div><div class="patient-detail">Last: 2 days ago · Cardiology</div></div>
                    <div class="patient-action"><a href="#" class="doc-btn doc-btn-ghost" style="padding:5px 11px;font-size:0.72rem;"><i class="fas fa-file-medical"></i></a></div>
                </div>
                <div class="patient-card">
                    <div class="patient-avatar">M</div>
                    <div><div class="patient-name">Mohamed Ben Ali</div><div class="patient-detail">Last: 3 days ago · Neurology</div></div>
                    <div class="patient-action"><a href="#" class="doc-btn doc-btn-ghost" style="padding:5px 11px;font-size:0.72rem;"><i class="fas fa-file-medical"></i></a></div>
                </div>
                <div class="patient-card">
                    <div class="patient-avatar">S</div>
                    <div><div class="patient-name">Sarah Mansour</div><div class="patient-detail">Last: 1 week ago · General</div></div>
                    <div class="patient-action"><a href="#" class="doc-btn doc-btn-ghost" style="padding:5px 11px;font-size:0.72rem;"><i class="fas fa-file-medical"></i></a></div>
                </div>
            {% endif %}
        </div>
    </div>
</div>

<!-- ── Feature Tiles ──────────────────────────────────── -->
<div class="doc-grid-3">
    <a href="{{ path('parapharmacy_index') }}" class="doc-feature">
        <div class="doc-feature-icon" style="background:rgba(20,184,166,0.12);color:#14b8a6;">
            <i class="fas fa-pills"></i>
        </div>
        <div class="doc-feature-title">Parapharmacy</div>
        <div class="doc-feature-desc">Browse and prescribe medical products from the integrated pharmacy.</div>
        <div class="doc-feature-badge" style="background:rgba(20,184,166,0.1);color:#14b8a6;">
            <i class="fas fa-arrow-right"></i> Open
        </div>
    </a>
    <a href="{{ path('blog_index') }}" class="doc-feature">
        <div class="doc-feature-icon" style="background:rgba(56,189,248,0.12);color:#38bdf8;">
            <i class="fas fa-comments"></i>
        </div>
        <div class="doc-feature-title">Medical Forum</div>
        <div class="doc-feature-desc">Share insights, answer patient questions, and engage with the community.</div>
        <div class="doc-feature-badge" style="background:rgba(56,189,248,0.1);color:#38bdf8;">
            <i class="fas fa-arrow-right"></i> Open
        </div>
    </a>
    <a href="{{ path('appointment_index') }}" class="doc-feature">
        <div class="doc-feature-icon" style="background:rgba(99,102,241,0.12);color:#6366f1;">
            <i class="fas fa-calendar-check"></i>
        </div>
        <div class="doc-feature-title">Schedule Manager</div>
        <div class="doc-feature-desc">Review, confirm, or reschedule patient appointments efficiently.</div>
        <div class="doc-feature-badge" style="background:rgba(99,102,241,0.1);color:#6366f1;">
            <i class="fas fa-arrow-right"></i> Open
        </div>
    </a>
</div>
{% endblock %}
