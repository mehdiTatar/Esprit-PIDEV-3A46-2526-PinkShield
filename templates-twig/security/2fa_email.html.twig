<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        body { font-family: 'Segoe UI', Arial, sans-serif; background-color: #f8f9fa; margin: 0; padding: 0; }
        .container { max-width: 500px; margin: 40px auto; background: #fff; border-radius: 12px; box-shadow: 0 4px 20px rgba(0,0,0,0.08); overflow: hidden; }
        .header { background: linear-gradient(135deg, #c0396b, #e8557a); padding: 30px 20px; text-align: center; }
        .header h1 { color: #fff; margin: 0; font-size: 22px; font-weight: 600; }
        .body { padding: 30px; text-align: center; }
        .code-box { display: inline-block; background: #f8f9fa; border: 2px dashed #c0396b; border-radius: 10px; padding: 18px 40px; margin: 20px 0; }
        .code { font-size: 36px; font-weight: 700; letter-spacing: 8px; color: #c0396b; font-family: 'Courier New', monospace; }
        .text { color: #555; font-size: 14px; line-height: 1.6; }
        .footer { background: #f8f9fa; padding: 16px; text-align: center; font-size: 12px; color: #999; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>🔒 PinkShield Security</h1>
        </div>
        <div class="body">
            <p class="text">Your verification code is:</p>
            <div class="code-box">
                <span class="code">{{ authCode }}</span>
            </div>
            <p class="text">Enter this code on the login page to complete your sign-in.<br>This code will expire shortly.</p>
            <p class="text" style="margin-top: 20px; font-size: 12px; color: #999;">If you did not request this code, please ignore this email.</p>
        </div>
        <div class="footer">
            &copy; PinkShield — Secure Health Platform
        </div>
    </div>
</body>
</html>
