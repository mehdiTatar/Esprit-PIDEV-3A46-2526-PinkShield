{% extends 'base.html.twig' %}

{% block title %}My Appointments — PinkShield{% endblock %}

{% block stylesheets %}
<link href='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.9/index.global.min.css' rel='stylesheet' />
<style>
    .appt-hero {
        background: linear-gradient(135deg, #1e1b34 0%, #2d1b3d 100%);
        border-radius: 16px;
        padding: 32px 40px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 28px;
        box-shadow: 0 8px 30px rgba(30,27,52,0.28);
    }

    .appt-hero h1 { font-size: 1.75rem; font-weight: 800; margin: 0 0 4px; letter-spacing: -0.3px; }
    .appt-hero p  { margin: 0; opacity: 0.7; font-size: 0.9rem; }

    /* ─── Tabs ─── */
    .view-tabs {
        display: flex;
        gap: 8px;
        margin-bottom: 24px;
    }
    .view-tab {
        padding: 10px 22px;
        border-radius: 10px;
        border: 1px solid var(--border);
        background: #fff;
        font-weight: 600;
        font-size: 0.85rem;
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s;
    }
    .view-tab:hover { border-color: var(--primary); color: var(--primary); }
    .view-tab.active { background: var(--primary); color: #fff; border-color: var(--primary); }

    /* ─── Panel ─── */
    .appt-panel {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        overflow: hidden;
        border: 1px solid var(--border);
    }

    .appt-panel-header {
        padding: 18px 24px;
        border-bottom: 1px solid var(--border);
        display: flex;
        align-items: center;
        justify-content: space-between;
        background: #fff;
    }

    .appt-panel-header h6 {
        margin: 0;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-dark);
    }

    /* ─── Table ─── */
    .appt-table { width: 100%; border-collapse: collapse; }

    .appt-table thead th {
        background: #fafafa;
        padding: 13px 18px;
        font-size: 0.75rem;
        font-weight: 700;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
        border-bottom: 1px solid var(--border);
        white-space: nowrap;
    }

    .appt-table tbody td {
        padding: 14px 18px;
        border-bottom: 1px solid #f8f4f6;
        font-size: 0.88rem;
        color: var(--text-dark);
        vertical-align: middle;
    }

    .appt-table tbody tr:last-child td { border-bottom: none; }
    .appt-table tbody tr:hover { background: #fff5f8; }

    .status-pill {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        padding: 4px 12px;
        border-radius: 20px;
        font-size: 0.77rem;
        font-weight: 700;
    }

    .status-confirmed { background: #dcfce7; color: #166534; }
    .status-pending   { background: #fef3c7; color: #92400e; }
    .status-cancelled { background: #fee2e2; color: #b91c1c; }
    .status-completed { background: #dbeafe; color: #1e40af; }

    .appt-empty {
        text-align: center;
        padding: 60px 0;
        color: var(--text-muted);
    }

    .appt-empty i { font-size: 3rem; color: var(--primary); opacity: 0.3; margin-bottom: 16px; display: block; }
    .appt-empty h5 { color: var(--text-dark); }
    .appt-empty p  { font-size: 0.88rem; }

    .date-cell .date-main { font-weight: 700; font-size: 0.9rem; }
    .date-cell .date-time { font-size: 0.77rem; color: var(--text-muted); }

    /* ─── Calendar ─── */
    .calendar-container {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid var(--border);
        padding: 24px;
        margin-bottom: 28px;
    }
    .calendar-container h6 {
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-dark);
        margin-bottom: 16px;
    }
    #fullCalendar {
        min-height: 500px;
    }
    .fc .fc-toolbar-title { font-size: 1.1rem !important; font-weight: 700; }
    .fc .fc-button-primary {
        background: var(--primary) !important;
        border-color: var(--primary) !important;
        font-size: 0.8rem !important;
    }
    .fc .fc-button-primary:hover { opacity: 0.85; }
    .fc .fc-daygrid-event { border-radius: 6px; padding: 2px 6px; font-size: 0.75rem; }

    /* ─── AI Suggestions ─── */
    .ai-section {
        background: #fff;
        border-radius: 14px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid var(--border);
        padding: 24px;
        margin-bottom: 28px;
    }
    .ai-section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
    }
    .ai-section-header h6 {
        margin: 0;
        font-weight: 700;
        font-size: 0.9rem;
        color: var(--text-dark);
    }
    .ai-badge {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 0.7rem;
        font-weight: 700;
        letter-spacing: 0.5px;
    }
    .ai-card {
        background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
        border: 1px solid #ddd6fe;
        border-radius: 12px;
        padding: 18px;
        margin-bottom: 12px;
        transition: transform 0.2s, box-shadow 0.2s;
    }
    .ai-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(99, 102, 241, 0.15);
    }
    .ai-card-title {
        font-weight: 700;
        font-size: 0.9rem;
        color: #4338ca;
        margin-bottom: 6px;
    }
    .ai-card-appt {
        font-size: 0.78rem;
        color: var(--text-muted);
        margin-bottom: 10px;
    }
    .ai-product {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 8px 12px;
        background: #fff;
        border-radius: 8px;
        margin-bottom: 6px;
        border: 1px solid #e9e5f5;
    }
    .ai-product-icon {
        width: 32px;
        height: 32px;
        border-radius: 8px;
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #fff;
        font-size: 0.8rem;
        flex-shrink: 0;
    }
    .ai-product-name { font-weight: 600; font-size: 0.85rem; color: var(--text-dark); }
    .ai-product-desc { font-size: 0.75rem; color: var(--text-muted); }
    .ai-product-price {
        margin-left: auto;
        font-weight: 700;
        color: #6366f1;
        font-size: 0.85rem;
        white-space: nowrap;
    }
    .ai-product-buy {
        background: linear-gradient(135deg, #6366f1, #8b5cf6);
        color: #fff;
        border: none;
        padding: 4px 12px;
        border-radius: 6px;
        font-size: 0.75rem;
        font-weight: 600;
        cursor: pointer;
        transition: opacity 0.2s;
        white-space: nowrap;
    }
    .ai-product-buy:hover { opacity: 0.85; }
    .ai-empty {
        text-align: center;
        padding: 30px;
        color: var(--text-muted);
        font-size: 0.88rem;
    }
    .ai-empty i { font-size: 2rem; opacity: 0.3; display: block; margin-bottom: 10px; color: #6366f1; }

    .view-section { display: none; }
    .view-section.active { display: block; }

    /* Ensure action buttons are always clickable */
    .appt-table td .d-flex { position: relative; z-index: 2; }
    .appt-table td a.btn { position: relative; z-index: 3; pointer-events: auto; }
</style>
{% endblock %}

{% block body %}
<div>
    {# Hero #}
    <div class="appt-hero">
        <div>
            <h1><i class="fas fa-calendar-check me-2" style="opacity:0.8;"></i>
                {% if is_granted('ROLE_ADMIN') %}All Appointments
                {% elseif is_granted('ROLE_DOCTOR') %}My Patient Appointments
                {% else %}My Appointments{% endif %}
            </h1>
            <p>Manage and track your medical consultations</p>
        </div>
        {% if is_granted('ROLE_USER') and not is_granted('ROLE_DOCTOR') and not is_granted('ROLE_ADMIN') %}
            <a href="{{ path('appointment_new') }}" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="fas fa-calendar-plus"></i> Book Appointment
            </a>
        {% endif %}
    </div>

    {# View Tabs #}
    <div class="view-tabs">
        <button class="view-tab active" data-target="list-view">
            <i class="fas fa-list me-1"></i> List View
        </button>
        <button class="view-tab" data-target="calendar-view">
            <i class="fas fa-calendar-alt me-1"></i> Calendar View
        </button>
        {% if is_granted('ROLE_USER') and not is_granted('ROLE_DOCTOR') and not is_granted('ROLE_ADMIN') %}
        <button class="view-tab" data-target="ai-view">
            <i class="fas fa-brain me-1"></i> AI Suggestions
        </button>
        {% endif %}
    </div>

    {# ═══════════════ LIST VIEW ═══════════════ #}
    <div id="list-view" class="view-section active">
        <div class="appt-panel">
            <div class="appt-panel-header">
                <h6><i class="fas fa-list me-2" style="color:var(--primary);"></i>Appointment List</h6>
                <span style="font-size:0.8rem;color:var(--text-muted);">{{ appointments|length }} record(s)</span>
            </div>

            {% if appointments|length > 0 %}
                <div class="table-responsive">
                    <table class="appt-table">
                        <thead>
                            <tr>
                                <th>Date & Time</th>
                                {% if is_granted('ROLE_DOCTOR') or is_granted('ROLE_ADMIN') %}<th>Patient</th>{% endif %}
                                {% if not is_granted('ROLE_DOCTOR') or is_granted('ROLE_ADMIN') %}<th>Doctor</th>{% endif %}
                                <th>Status</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for appointment in appointments %}
                                <tr>
                                    <td class="date-cell">
                                        <div class="date-main">{{ appointment.appointmentDate|date('M d, Y') }}</div>
                                        <div class="date-time"><i class="far fa-clock me-1"></i>{{ appointment.appointmentDate|date('H:i') }}</div>
                                    </td>
                                    {% if is_granted('ROLE_DOCTOR') or is_granted('ROLE_ADMIN') %}
                                        <td><i class="fas fa-user-injured me-1" style="color:var(--primary);opacity:0.7;"></i>{{ appointment.patientName }}</td>
                                    {% endif %}
                                    {% if not is_granted('ROLE_DOCTOR') or is_granted('ROLE_ADMIN') %}
                                        <td><i class="fas fa-user-md me-1" style="color:var(--primary);opacity:0.7;"></i>{{ appointment.doctorName }}</td>
                                    {% endif %}
                                    <td>
                                        <span class="status-pill status-{{ appointment.status }}">
                                            {% if appointment.status == 'confirmed' %}<i class="fas fa-check-circle"></i>
                                            {% elseif appointment.status == 'pending' %}<i class="fas fa-hourglass-half"></i>
                                            {% elseif appointment.status == 'completed' %}<i class="fas fa-clipboard-check"></i>
                                            {% else %}<i class="fas fa-times-circle"></i>{% endif %}
                                            {{ appointment.status|capitalize }}
                                        </span>
                                    </td>
                                    <td style="color:var(--text-muted);font-style:{{ appointment.notes ? 'normal' : 'italic' }};">
                                        {{ appointment.notes|default('—')|slice(0, 50) }}{% if appointment.notes|default('')|length > 50 %}…{% endif %}
                                    </td>
                                    <td>
                                        <div class="d-flex gap-2 flex-wrap">
                                            <a href="{{ path('appointment_invoice', {'id': appointment.id}) }}"
                                               class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1">
                                                <i class="fas fa-file-pdf"></i> PDF
                                            </a>
                                            {% if appointment.status == 'pending' %}
                                                {% if is_granted('ROLE_DOCTOR') or is_granted('ROLE_ADMIN') %}
                                                    <a href="{{ path('appointment_confirm', {'id': appointment.id}) }}"
                                                       class="btn btn-sm btn-success d-flex align-items-center gap-1">
                                                        <i class="fas fa-check"></i> Confirm
                                                    </a>
                                                {% endif %}
                                                <a href="{{ path('appointment_cancel', {'id': appointment.id}) }}"
                                                   class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                                   onclick="return confirm('Cancel this appointment?')">
                                                    <i class="fas fa-times"></i> Cancel
                                                </a>
                                            {% elseif appointment.status == 'confirmed' %}
                                                <a href="{{ path('appointment_cancel', {'id': appointment.id}) }}"
                                                   class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                                   onclick="return confirm('Cancel this appointment?')">
                                                    <i class="fas fa-times"></i> Cancel
                                                </a>
                                            {% endif %}
                                            {% if appointment.status == 'confirmed' or appointment.status == 'completed' %}
                                                <a href="{{ path('appointment_invoice', {'id': appointment.id}) }}"
                                                   class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1">
                                                    <i class="fas fa-file-invoice"></i> Invoice
                                                </a>
                                            {% endif %}
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <div class="appt-empty">
                    <i class="fas fa-calendar-times"></i>
                    <h5>No appointments found</h5>
                    <p>
                        {% if is_granted('ROLE_USER') and not is_granted('ROLE_DOCTOR') %}
                            Ready to see a doctor?
                        {% else %}
                            No appointments scheduled yet.
                        {% endif %}
                    </p>
                    {% if is_granted('ROLE_USER') and not is_granted('ROLE_DOCTOR') and not is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('appointment_new') }}" class="btn btn-primary mt-2">
                            <i class="fas fa-calendar-plus me-2"></i>Book an Appointment
                        </a>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

    {# ═══════════════ CALENDAR VIEW ═══════════════ #}
    <div id="calendar-view" class="view-section">
        <div class="calendar-container">
            <h6><i class="fas fa-calendar-alt me-2" style="color:var(--primary);"></i>Appointment Calendar</h6>
            <div id="fullCalendar"></div>
        </div>
    </div>

    {# ═══════════════ AI SUGGESTIONS VIEW ═══════════════ #}
    {% if is_granted('ROLE_USER') and not is_granted('ROLE_DOCTOR') and not is_granted('ROLE_ADMIN') %}
    <div id="ai-view" class="view-section">
        <div class="ai-section">
            <div class="ai-section-header">
                <h6><i class="fas fa-brain me-2" style="color:#6366f1;"></i>AI Pharmacist Suggestions</h6>
                <span class="ai-badge"><i class="fas fa-sparkles me-1"></i>AI Powered</span>
            </div>

            {% if aiSuggestions|length > 0 %}
                {% for appointmentId, suggestions in aiSuggestions %}
                    {% set apt = null %}
                    {% for a in appointments %}
                        {% if a.id == appointmentId %}
                            {% set apt = a %}
                        {% endif %}
                    {% endfor %}
                    <div class="ai-card">
                        <div class="ai-card-title">
                            <i class="fas fa-notes-medical me-1"></i>
                            Suggestions for Appointment #{{ appointmentId }}
                        </div>
                        {% if apt %}
                        <div class="ai-card-appt">
                            <i class="fas fa-user-md me-1"></i> Dr. {{ apt.doctorName }} —
                            <i class="far fa-calendar me-1"></i> {{ apt.appointmentDate|date('M d, Y H:i') }}
                            {% if apt.notes %}
                                — <em>"{{ apt.notes|slice(0, 80) }}{% if apt.notes|length > 80 %}…{% endif %}"</em>
                            {% endif %}
                        </div>
                        {% endif %}

                        {% for product in suggestions %}
                        <div class="ai-product">
                            <div class="ai-product-icon">
                                <i class="fas fa-pills"></i>
                            </div>
                            <div>
                                <div class="ai-product-name">{{ product.name|default('Product') }}</div>
                                <div class="ai-product-desc">{{ product.description|default('') }}</div>
                            </div>
                            {% if product.price is defined %}
                            <span class="ai-product-price">${{ product.price|number_format(2) }}</span>
                            {% endif %}
                            <button class="ai-product-buy" onclick="buyProduct('{{ product.name|default('Product')|e('js') }}')">
                                <i class="fas fa-shopping-cart me-1"></i> Buy
                            </button>
                        </div>
                        {% endfor %}
                    </div>
                {% endfor %}
            {% else %}
                <div class="ai-empty">
                    <i class="fas fa-robot"></i>
                    <p>No AI suggestions available yet.<br>
                    <small>Suggestions appear when your appointments have doctor notes.</small></p>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}
</div>
{% endblock %}

{% block javascripts %}
<script src='https://cdn.jsdelivr.net/npm/fullcalendar@6.1.9/index.global.min.js'></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // ─── Tab Switching ───
    document.querySelectorAll('.view-tab').forEach(function(tab) {
        tab.addEventListener('click', function() {
            document.querySelectorAll('.view-tab').forEach(t => t.classList.remove('active'));
            document.querySelectorAll('.view-section').forEach(s => s.classList.remove('active'));
            this.classList.add('active');
            document.getElementById(this.dataset.target).classList.add('active');

            // Initialize calendar when shown (FullCalendar needs visible container)
            if (this.dataset.target === 'calendar-view' && !window._calendarInitialized) {
                initCalendar();
                window._calendarInitialized = true;
            }
        });
    });

    // ─── FullCalendar ───
    function initCalendar() {
        var calendarEl = document.getElementById('fullCalendar');
        var calendar = new FullCalendar.Calendar(calendarEl, {
            initialView: 'dayGridMonth',
            headerToolbar: {
                left: 'prev,next today',
                center: 'title',
                right: 'dayGridMonth,timeGridWeek,timeGridDay,listWeek'
            },
            height: 'auto',
            navLinks: true,
            editable: false,
            selectable: false,
            eventClick: function(info) {
                window.location.href = '/appointment/' + info.event.id;
            },
            events: function(fetchInfo, successCallback, failureCallback) {
                fetch('{{ path("fc_load_events") }}')
                    .then(function(response) { return response.json(); })
                    .then(function(data) { successCallback(data); })
                    .catch(function(error) {
                        console.error('Error loading events:', error);
                        failureCallback(error);
                    });
            }
        });
        calendar.render();
    }
});

// ─── Buy Product (Stripe checkout) ───
function buyProduct(productName) {
    if (!confirm('Purchase ' + productName + '?')) return;

    fetch('{{ path("appointment_checkout_product") }}', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ productName: productName })
    })
    .then(function(r) { return r.json(); })
    .then(function(data) {
        if (data.checkoutUrl) {
            window.location.href = data.checkoutUrl;
        } else {
            alert(data.error || 'Could not start checkout.');
        }
    })
    .catch(function(e) {
        alert('Error: ' + e.message);
    });
}
</script>
{% endblock %}
