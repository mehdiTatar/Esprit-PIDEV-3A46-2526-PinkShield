{% extends "base.html.twig" %}

{% block title %}Appointment Calendar{% endblock %}

{% block content %}
<div class="container-fluid mt-4">
    <div class="row">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Appointments Calendar</h2>
                </div>
                <div class="card-body">
                    {# Initialize the calendar with the event data #}
                    {{ calendar_macro(calendar) }}
                </div>
            </div>
        </div>
    </div>

    {# Legend #}
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">Status Legend</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <span class="badge" style="background-color: #28a745;">Confirmed</span>
                        </div>
                        <div class="col-md-3">
                            <span class="badge" style="background-color: #ffc107; color: #000;">Pending</span>
                        </div>
                        <div class="col-md-3">
                            <span class="badge" style="background-color: #dc3545;">Cancelled</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

{# CSS for calendar styling #}
<style>
    .calendar-container {
        background: #fff;
        border-radius: 0.375rem;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    }

    .calendar-event {
        cursor: pointer;
        padding: 2px 4px;
        margin: 1px 0;
        border-radius: 3px;
        font-size: 0.85rem;
    }

    .calendar-event:hover {
        opacity: 0.8;
    }
</style>
{% endblock %}
