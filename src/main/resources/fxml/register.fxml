<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.RegisterRoleController"
            style="-fx-background-color: linear-gradient(to bottom right, #080e1a 0%, #10182b 52%, #070c16 100%);">
    <center>
        <HBox alignment="CENTER" spacing="0">
            <HBox maxWidth="980" prefHeight="620"
                  style="-fx-background-color: #0a1220; -fx-background-radius: 24; -fx-border-color: #252c3b; -fx-border-radius: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 28, 0.2, 0, 8);">
                <VBox prefWidth="470" spacing="22"
                      style="-fx-background-color: linear-gradient(to bottom right, #5a2145 0%, #241a44 100%); -fx-background-radius: 24 0 0 24; -fx-padding: 40;">
                    <StackPane prefWidth="86" prefHeight="86" maxWidth="86" maxHeight="86"
                               style="-fx-background-color: rgba(255,92,150,0.18); -fx-background-radius: 999; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 999;">
                        <Label text="PS" style="-fx-text-fill: #ff72ab; -fx-font-size: 22; -fx-font-weight: bold;" />
                    </StackPane>

                    <VBox spacing="8">
                        <Label text="PinkShield" style="-fx-text-fill: #ffffff; -fx-font-size: 34; -fx-font-weight: bold;" />
                        <Label text="Your secure digital health platform"
                               style="-fx-text-fill: rgba(255,255,255,0.64); -fx-font-size: 14;" />
                    </VBox>

                    <VBox spacing="12" style="-fx-padding: 20 0 6 0;">
                        <VBox spacing="4"
                              style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 14; -fx-padding: 16 18;">
                            <Label text="End-to-end security" style="-fx-text-fill: #ffd0e2; -fx-font-size: 14; -fx-font-weight: bold;" />
                            <Label text="2FA-ready, encrypted data, protected sessions"
                                   style="-fx-text-fill: rgba(255,255,255,0.52); -fx-font-size: 11;" />
                        </VBox>

                        <VBox spacing="4"
                              style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 14; -fx-padding: 16 18;">
                            <Label text="AI-assisted healthcare tools" style="-fx-text-fill: #ffd0e2; -fx-font-size: 14; -fx-font-weight: bold;" />
                            <Label text="Appointments, tracking, blogs, and pharmacy access"
                                   style="-fx-text-fill: rgba(255,255,255,0.52); -fx-font-size: 11;" />
                        </VBox>

                        <VBox spacing="4"
                              style="-fx-background-color: rgba(255,255,255,0.05); -fx-background-radius: 14; -fx-border-color: rgba(255,255,255,0.08); -fx-border-radius: 14; -fx-padding: 16 18;">
                            <Label text="Built for patients and doctors" style="-fx-text-fill: #ffd0e2; -fx-font-size: 14; -fx-font-weight: bold;" />
                            <Label text="Choose the role that fits your workflow and continue"
                                   style="-fx-text-fill: rgba(255,255,255,0.52); -fx-font-size: 11;" />
                        </VBox>
                    </VBox>
                </VBox>

                <VBox prefWidth="510" spacing="18"
                      style="-fx-background-color: #08111f; -fx-background-radius: 0 24 24 0; -fx-padding: 44;">
                    <VBox spacing="6">
                        <Label text="Create Account" style="-fx-text-fill: #ffffff; -fx-font-size: 28; -fx-font-weight: bold;" />
                        <Label text="Choose your role to get started with PinkShield"
                               style="-fx-text-fill: #92a3bc; -fx-font-size: 13;" />
                    </VBox>

                    <VBox spacing="10" style="-fx-padding: 12 0 0 0;">
                        <Label text="I am a..." style="-fx-text-fill: #8fa2bd; -fx-font-size: 12; -fx-font-weight: bold;" />
                        <HBox spacing="12">
                            <ToggleButton fx:id="patientOptionButton" text="Patient" />
                            <ToggleButton fx:id="doctorOptionButton" text="Doctor" />
                        </HBox>
                    </VBox>

                    <VBox spacing="8"
                          style="-fx-background-color: #101827; -fx-background-radius: 16; -fx-border-color: #253247; -fx-border-radius: 16; -fx-padding: 18 20;">
                        <Label fx:id="roleSummaryTitle" text="Patient Account"
                               style="-fx-text-fill: #ff78af; -fx-font-size: 14; -fx-font-weight: bold;" />
                        <Label fx:id="roleSummaryDescription"
                               text="Book appointments, track your health data, and access your personal dashboard."
                               wrapText="true"
                               style="-fx-text-fill: #c8d3e3; -fx-font-size: 12;" />
                    </VBox>

                    <Button fx:id="continueButton" text="Register as Patient" onAction="#handleContinue"
                            style="-fx-background-color: linear-gradient(to right, #d54480, #ec5d99); -fx-text-fill: white; -fx-font-size: 15; -fx-font-weight: bold; -fx-background-radius: 14; -fx-padding: 14 24;" />

                    <Separator style="-fx-opacity: 0.18;" />

                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Already have an account?" style="-fx-text-fill: #7f8fa8; -fx-font-size: 12;" />
                        <Hyperlink text="Sign In" onAction="#handleBackToLogin"
                                   style="-fx-text-fill: #ff6ba8; -fx-font-size: 12; -fx-font-weight: bold; -fx-border-color: transparent; -fx-padding: 0;" />
                    </HBox>
                </VBox>
            </HBox>
        </HBox>
    </center>
</BorderPane>
