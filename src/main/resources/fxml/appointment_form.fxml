<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.AppointmentListController"
            styleClass="appointment-page">
    <top>
        <VBox spacing="8" styleClass="hero-panel appointment-hero">
            <padding>
                <Insets top="28" right="32" bottom="28" left="32" />
            </padding>
            <Label fx:id="formTitle" text="Book an Appointment" styleClass="dashboard-title" />
            <Label text="Choose a doctor, check the clinic conditions, and confirm the best consultation slot." styleClass="dashboard-copy" wrapText="true" />
        </VBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" styleClass="auth-scroll">
            <content>
                <VBox maxWidth="1180" spacing="20" styleClass="content-area">
                    <padding>
                        <Insets top="20" right="40" bottom="24" left="0" />
                    </padding>

                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <Button text="Calendar" onAction="#handleOpenCalendar" styleClass="button secondary" />
                        <Button text="Parapharmacy" onAction="#handleOpenParapharmacy" styleClass="button secondary" />
                        <Button text="Open clinic map" onAction="#handleOpenClinicMap" styleClass="button secondary" />
                        <Button text="Refresh weather" onAction="#handleRefreshWeather" styleClass="button secondary" />
                    </HBox>

                    <HBox alignment="TOP_LEFT" spacing="20">
                        <VBox spacing="18" styleClass="panel-card appointment-form-card" HBox.hgrow="ALWAYS">
                            <VBox spacing="8">
                                <Label text="Doctor / specialist" styleClass="section-title" />
                                <ComboBox fx:id="doctorCombo" promptText="Choose a doctor" maxWidth="1.7976931348623157E308" />
                                <Label text="Only active doctors are available for booking." styleClass="table-meta" />
                            </VBox>

                            <HBox spacing="16">
                                <VBox spacing="8" HBox.hgrow="ALWAYS">
                                    <Label text="Appointment date" styleClass="section-title" />
                                    <DatePicker fx:id="datePicker" maxWidth="1.7976931348623157E308" />
                                </VBox>
                                <VBox spacing="8" prefWidth="170">
                                    <Label text="Time" styleClass="section-title" />
                                    <TextField fx:id="timeField" promptText="HH:mm" />
                                </VBox>
                            </HBox>

                            <VBox spacing="8">
                                <Label text="Symptoms / reason for visit" styleClass="section-title" />
                                <TextArea fx:id="notesArea" prefHeight="150" promptText="Briefly describe your symptoms or reason for this appointment..." wrapText="true" />
                            </VBox>

                            <Label fx:id="feedbackLabel" managed="false" visible="false" wrapText="true" />

                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Button text="Cancel" onAction="#handleCancelForm" styleClass="button secondary" />
                                <Button text="Download PDF Proof" onAction="#handleDownloadPdf" styleClass="button secondary" />
                                <Button text="Confirm Booking" onAction="#handleConfirmBooking" styleClass="button" />
                                <Region HBox.hgrow="ALWAYS" />
                            </HBox>
                        </VBox>

                        <VBox prefWidth="330" spacing="18">
                            <VBox spacing="10" styleClass="panel-card appointment-weather-card">
                                <Label text="Clinic weather" styleClass="section-title" />
                                <Label fx:id="weatherSummaryLabel" text="Loading clinic weather..." styleClass="dashboard-title appointment-mini-title" wrapText="true" />
                                <Label fx:id="weatherMetaLabel" text="Fetching the latest conditions for the appointment location." styleClass="dashboard-copy" wrapText="true" />
                            </VBox>

                            <VBox spacing="10" styleClass="panel-card appointment-weather-card">
                                <Label text="Clinic location" styleClass="section-title" />
                                <Label fx:id="clinicSummaryLabel" text="PinkShield Medical Center - Centre Urbain Nord, Tunis, Tunisia" styleClass="dashboard-copy" wrapText="true" />
                                <Label text="The weather, map preview, and QR features need internet access at runtime." styleClass="table-meta" wrapText="true" />
                            </VBox>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
