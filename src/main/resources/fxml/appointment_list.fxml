<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.AppointmentListController" style="-fx-background-color: #f5f5f5;">
    <top>
        <!-- Hero Header -->
        <VBox style="-fx-background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-padding: 40;" spacing="8">
            <Label text="My Appointments" style="-fx-font-size: 32; -fx-font-weight: bold; -fx-text-fill: white;" />
            <Label text="Manage your upcoming medical consultations and view your appointment history." style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 13;" />
        </VBox>
    </top>
    <center>
        <VBox spacing="20" style="-fx-padding: 40; -fx-background-color: transparent;">
            <!-- Actions Toolbar -->
            <HBox spacing="15" alignment="CENTER_LEFT">
                <HBox spacing="10" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 12 16; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <Label text="Filter by status:" style="-fx-text-fill: #333; -fx-font-weight: bold; -fx-font-size: 12;" />
                    <ComboBox fx:id="statusFilter" promptText="All statuses" prefWidth="150" style="-fx-padding: 8; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                </HBox>
                <Button fx:id="bookAppointmentButton" text="+ Book New Appointment" onAction="#handleNewAppointment" style="-fx-padding: 10 24; -fx-background-color: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6;" />
            </HBox>

            <!-- Appointments Table -->
            <VBox style="-fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);" VBox.vgrow="ALWAYS">
                <TableView fx:id="appointmentsTable" VBox.vgrow="ALWAYS" style="-fx-font-size: 12;">
                    <columns>
                        <TableColumn fx:id="dateColumn" text="📅 Date &amp; Time" prefWidth="180" />
                        <TableColumn fx:id="doctorPatientColumn" text="👨‍⚕️ Doctor/Patient" prefWidth="250" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="120" />
                        <TableColumn fx:id="notesColumn" text="Notes" prefWidth="250" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="100" />
                    </columns>
                </TableView>
            </VBox>
        </VBox>
    </center>
</BorderPane>
