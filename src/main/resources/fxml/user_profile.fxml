<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.UserProfileController" style="-fx-background-color: #f5f5f5;">
    <top>
        <!-- Hero Header -->
        <VBox style="-fx-background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-padding: 32;" spacing="10">
            <HBox spacing="20">
                <Label fx:id="avatarLabel" style="-fx-border-radius: 50%; -fx-background-color: rgba(255,255,255,0.2); -fx-padding: 20; -fx-font-size: 24; -fx-text-fill: white; -fx-border-width: 3; -fx-border-color: rgba(255,255,255,0.4);" text="?" />
                <VBox spacing="5">
                    <Label fx:id="titleLabel" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;" text="User Profile" />
                    <Label text="Update your personal information and account settings" style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 12;" />
                </VBox>
            </HBox>
        </VBox>
    </top>
    <center>
        <ScrollPane style="-fx-background-color: transparent; -fx-control-inner-background: transparent;" fitToWidth="true">
            <VBox alignment="TOP_CENTER" spacing="0" style="-fx-background-color: transparent; -fx-padding: 40;">
                <!-- Form Card -->
                <VBox style="-fx-background-color: white; -fx-border-radius: 8; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4); -fx-padding: 0;" spacing="0" maxWidth="680">
                    <!-- Form Content -->
                    <VBox spacing="20" style="-fx-padding: 36;">
                        <!-- Personal Information Section -->
                        <VBox spacing="12">
                            <Label text="PERSONAL INFORMATION" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-transform: uppercase; -fx-letter-spacing: 1; -fx-text-fill: #666; -fx-border-bottom: 1 solid #ddd; -fx-padding: 0 0 8 0;" />
                            <HBox spacing="15">
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="FIRST NAME" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                    <TextField fx:id="firstNameField" promptText="First name" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                                </VBox>
                                <VBox spacing="5" HBox.hgrow="ALWAYS">
                                    <Label text="LAST NAME" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                    <TextField fx:id="lastNameField" promptText="Last name" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- Contact Details Section -->
                        <VBox spacing="12">
                            <Label text="CONTACT DETAILS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-transform: uppercase; -fx-letter-spacing: 1; -fx-text-fill: #666; -fx-border-bottom: 1 solid #ddd; -fx-padding: 0 0 8 0;" />
                            <VBox spacing="5">
                                <Label text="EMAIL ADDRESS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                <TextField fx:id="emailField" promptText="your@email.com" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                            </VBox>
                            <VBox spacing="5">
                                <Label text="PHONE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                <TextField fx:id="phoneField" promptText="+216 XX XXX XXX" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                                <Label text="Used for appointment reminders" style="-fx-font-size: 9; -fx-text-fill: #999; -fx-padding: 4 0 0 0;" />
                            </VBox>
                            <VBox spacing="5">
                                <Label text="ADDRESS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                <TextField fx:id="addressField" promptText="Your address" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                            </VBox>
                        </VBox>

                        <!-- Security Section -->
                        <VBox spacing="12">
                            <Label text="CHANGE PASSWORD" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-transform: uppercase; -fx-letter-spacing: 1; -fx-text-fill: #666; -fx-border-bottom: 1 solid #ddd; -fx-padding: 0 0 8 0;" />
                            <VBox spacing="5">
                                <Label text="NEW PASSWORD" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #333;" />
                                <PasswordField fx:id="passwordField" promptText="Leave blank to keep your current password" style="-fx-padding: 10; -fx-border-radius: 6; -fx-border-color: #ddd;" />
                                <Label text="Minimum 8 characters recommended" style="-fx-font-size: 9; -fx-text-fill: #999; -fx-padding: 4 0 0 0;" />
                            </VBox>
                        </VBox>
                    </VBox>

                    <!-- Form Actions -->
                    <HBox spacing="12" style="-fx-padding: 22 36; -fx-border-top: 1 solid #ddd; -fx-background-color: #fafafa; -fx-border-radius: 0 0 8 8;" alignment="CENTER_LEFT">
                        <Button text="Save Changes" onAction="#handleSave" style="-fx-padding: 10 24; -fx-background-color: linear-gradient(135deg, #c0396b 0%, #e8557a 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-border-radius: 6;" />
                        <Button text="Cancel" onAction="#handleCancel" style="-fx-padding: 10 24; -fx-background-color: #ccc; -fx-text-fill: #333; -fx-font-weight: bold; -fx-border-radius: 6;" />
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>

