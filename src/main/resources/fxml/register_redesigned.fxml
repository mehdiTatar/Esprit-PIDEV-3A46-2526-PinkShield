<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.RegisterController"
            styleClass="root"
            stylesheets="@../css/style.css">
    <center>
        <HBox alignment="CENTER" spacing="0" styleClass="auth-screen">
            <!-- Left Side: Brand & Benefits -->
            <VBox alignment="CENTER" spacing="24" prefWidth="380" styleClass="auth-brand-side">
                <!-- Logo Section -->
                <HBox alignment="CENTER" spacing="12" styleClass="auth-logo-row">
                    <VBox alignment="CENTER" style="-fx-min-width: 48; -fx-min-height: 48;" styleClass="auth-logo-mark">
                        <Label text="P" styleClass="auth-logo-mark-text" />
                    </VBox>
                    <VBox spacing="2">
                        <Label text="PinkShield" styleClass="auth-wordmark" />
                        <Label text="CREATE YOUR ACCOUNT" styleClass="auth-wordmark-subtitle" />
                    </VBox>
                </HBox>

                <!-- Benefits -->
                <VBox alignment="CENTER" spacing="20">
                    <Label text="Join Our Platform" styleClass="auth-hero-title" />
                    <Label text="Get 24/7 access to quality healthcare"
                           styleClass="auth-hero-copy" wrapText="true" />
                </VBox>

                <!-- Feature Cards -->
                <VBox spacing="12" styleClass="auth-feature-list">
                    <VBox spacing="8" styleClass="auth-feature-card">
                        <Label text="✓ Seamless Booking" styleClass="auth-feature-title" />
                        <Label text="Schedule appointments with trusted healthcare professionals"
                               styleClass="auth-feature-subtitle" wrapText="true" />
                    </VBox>
                    <VBox spacing="8" styleClass="auth-feature-card">
                        <Label text="✓ Health Records" styleClass="auth-feature-title" />
                        <Label text="Keep your medical history securely stored"
                               styleClass="auth-feature-subtitle" wrapText="true" />
                    </VBox>
                    <VBox spacing="8" styleClass="auth-feature-card">
                        <Label text="✓ Doctor Network" styleClass="auth-feature-title" />
                        <Label text="Connect with verified healthcare experts"
                               styleClass="auth-feature-subtitle" wrapText="true" />
                    </VBox>
                </VBox>
            </VBox>

            <!-- Right Side: Registration Form -->
            <ScrollPane fitToWidth="true" styleClass="auth-scroll">
                <VBox alignment="TOP_CENTER" spacing="24" prefWidth="380" styleClass="auth-form-side" style="-fx-padding: 32;">
                    <!-- Header -->
                    <VBox spacing="8">
                        <Label text="Create Account" styleClass="auth-form-title" />
                        <Label text="Choose your role to access PinkShield" styleClass="auth-form-subtitle" wrapText="true" />
                    </VBox>

                    <!-- Feedback Label -->
                    <Label text="" visible="false" managed="false" styleClass="auth-alert-label" wrapText="true" />

                    <!-- Role Selection -->
                    <VBox spacing="10">
                        <Label text="I am a:" styleClass="auth-section-label" />
                        <HBox spacing="10">
                            <RadioButton fx:id="patientRadio" text="Patient" selected="true"
                                        styleClass="role-toggle" style="-fx-padding: 12 16;" />
                            <RadioButton fx:id="doctorRadio" text="Healthcare Professional"
                                        styleClass="role-toggle" style="-fx-padding: 12 16;" />
                        </HBox>
                    </VBox>

                    <!-- Patient Fields -->
                    <VBox fx:id="patientFields" spacing="14">
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="FULL NAME" styleClass="auth-field-label" />
                            <TextField fx:id="fullNameField" promptText="John Doe" styleClass="text-field" />
                        </VBox>
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="PHONE NUMBER" styleClass="auth-field-label" />
                            <TextField fx:id="phoneField" promptText="+216 XX XXX XXX" styleClass="text-field" />
                        </VBox>
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="ADDRESS" styleClass="auth-field-label" />
                            <TextField fx:id="addressField" promptText="Your address" styleClass="text-field" />
                        </VBox>
                    </VBox>

                    <!-- Doctor Fields -->
                    <VBox fx:id="doctorFields" spacing="14" visible="false" managed="false">
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="FIRST NAME" styleClass="auth-field-label" />
                            <TextField fx:id="firstNameField" promptText="John" styleClass="text-field" />
                        </VBox>
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="LAST NAME" styleClass="auth-field-label" />
                            <TextField fx:id="lastNameField" promptText="Doe" styleClass="text-field" />
                        </VBox>
                        <VBox spacing="7" styleClass="auth-field-block">
                            <Label text="SPECIALITY" styleClass="auth-field-label" />
                            <TextField fx:id="specialityField" promptText="e.g. Cardiology" styleClass="text-field" />
                        </VBox>
                    </VBox>

                    <!-- Email Field -->
                    <VBox spacing="7" styleClass="auth-field-block">
                        <Label text="EMAIL ADDRESS" styleClass="auth-field-label" />
                        <TextField fx:id="emailField" promptText="you@example.com" styleClass="text-field" />
                    </VBox>

                    <!-- Password Field -->
                    <VBox spacing="7" styleClass="auth-field-block">
                        <Label text="PASSWORD" styleClass="auth-field-label" />
                        <PasswordField fx:id="passwordField" promptText="Min 8 characters" styleClass="text-field" />
                        <Label text="Must be at least 8 characters long" styleClass="auth-feature-subtitle" />
                    </VBox>

                    <!-- Confirm Password -->
                    <VBox spacing="7" styleClass="auth-field-block">
                        <Label text="CONFIRM PASSWORD" styleClass="auth-field-label" />
                        <PasswordField fx:id="confirmPasswordField" promptText="Repeat password" styleClass="text-field" />
                    </VBox>

                    <!-- Register Button -->
                    <Button text="Create Account" onAction="#handleRegister"
                           style="-fx-min-height: 48; -fx-font-size: 15;" styleClass="button" />

                    <!-- Back to Login -->
                    <HBox alignment="CENTER" spacing="6">
                        <Label text="Already have an account?" styleClass="auth-inline-text" />
                        <Hyperlink text="Sign in here" onAction="#handleBackToLogin" styleClass="auth-link" />
                    </HBox>
                </VBox>
            </ScrollPane>
        </HBox>
    </center>
</BorderPane>

