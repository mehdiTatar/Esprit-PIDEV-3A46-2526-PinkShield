<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>

<HBox xmlns="http://javafx.com/javafx/21.0.1"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.AdminLayoutController"
      maxHeight="Infinity" maxWidth="Infinity">

    <!-- Sidebar -->
    <VBox styleClass="admin-sidebar" spacing="6" prefWidth="220" maxHeight="Infinity">
        <Label text="Admin Panel" styleClass="sidebar-title" />

        <Label text="Blog Management" styleClass="sidebar-section-label" />
        <Button fx:id="btnPosts" text="Blog Posts"
                onAction="#showPosts"
                styleClass="sidebar-btn"
                maxWidth="Infinity" />
        <Button fx:id="btnComments" text="Comments"
                onAction="#showComments"
                styleClass="sidebar-btn"
                maxWidth="Infinity" />

    </VBox>

    <!-- Content Area -->
    <StackPane fx:id="adminContent" HBox.hgrow="ALWAYS" maxHeight="Infinity" />

</HBox>
