<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.WishlistUserController" fitToWidth="true" hbarPolicy="NEVER" stylesheets="@style.css" styleClass="module-root">
    <VBox spacing="20" styleClass="module-root" style="-fx-padding: 30;">

            <Label text="Your Wishlist" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ff69b4;"/>
            <Label text="Your saved products and items for future purchase" styleClass="label-subtitle"/>

            <!-- Toolbar with Tabs -->
            <HBox spacing="15" style="-fx-padding: 10; -fx-background-color: #f5f5f5; -fx-border-radius: 8; -fx-border-color: #e0e0e0;">
                <Button fx:id="wishlistTabBtn" text="💳 Wishlist" styleClass="btn-secondary" style="-fx-padding: 10 20; -fx-font-weight: bold;" onAction="#handleWishlistTab"/>
                <Button fx:id="transactionTabBtn" text="📊 Transaction History" styleClass="btn-secondary" style="-fx-padding: 10 20; -fx-font-weight: bold;" onAction="#handleTransactionHistoryTab"/>
            </HBox>

            <!-- Search (only for Wishlist tab) -->
            <TextField fx:id="searchBar" promptText="Search your wishlist..." prefHeight="35" styleClass="text-field"/>

            <!-- Wishlist Items Section (Tab 1) -->
            <VBox fx:id="wishlistTabContent" styleClass="card-pane" spacing="15">
                <Label text="Saved Items" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ff69b4;"/>

                <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="colId" text="Item ID" prefWidth="80"/>
                        <TableColumn fx:id="colParapharmacieId" text="Product" prefWidth="210"/>
                        <TableColumn fx:id="colPrice" text="Price" prefWidth="120"/>
                        <TableColumn fx:id="colAddedAt" text="Added On" prefWidth="150"/>
                        <TableColumn fx:id="colAction" text="Action" prefWidth="100"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="totalPriceLabel" text="Total: 0.00 TND" styleClass="total-price-label"/>
                </HBox>
            </VBox>

            <!-- Transaction History Section (Tab 2) -->
            <VBox fx:id="transactionTabContent" styleClass="card-pane" spacing="15" managed="false" visible="false">
                <Label text="Transaction History" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ff69b4;"/>

                <TableView fx:id="transactionTable" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="transactionColId" text="Transaction ID" prefWidth="100"/>
                        <TableColumn fx:id="transactionColDate" text="Date" prefWidth="150"/>
                        <TableColumn fx:id="transactionColPrice" text="Amount (TND)" prefWidth="150"/>
                        <TableColumn fx:id="transactionColStatus" text="Status" prefWidth="120"/>
                    </columns>
                </TableView>

                <HBox alignment="CENTER_RIGHT">
                    <Label fx:id="totalTransactionsLabel" text="Total Spent: 0.00 TND" styleClass="total-price-label"/>
                </HBox>
            </VBox>

            <!-- Action Button -->
            <HBox fx:id="actionButtonsBox" spacing="15">
                <Button text="Remove Selected Item" onAction="#handleSupprimer" styleClass="btn-danger"/>
                <Button text="Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label text="Tip: Save items from the Parapharmacie section to add to your wishlist!" styleClass="label-subtitle"/>
            </HBox>

            <!-- ===== CHECKOUT / PAYMENT SECTION ===== -->
            <VBox fx:id="checkoutBox" styleClass="card-pane" spacing="15" style="-fx-border-color: #e84393; -fx-border-width: 2; -fx-padding: 20; -fx-border-radius: 12; -fx-background-color: #f9f9f9;">
                <Label text="💳 Secure Checkout" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #e84393;"/>
                <Label text="Complete your payment to proceed with your order" styleClass="label-subtitle"/>

                <!-- Payment Form Grid -->
                <GridPane hgap="20" vgap="15" style="-fx-padding: 15;">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <!-- Cardholder Name -->
                    <Label text="Cardholder Name" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="cardholderNameField" promptText="John Doe" GridPane.columnIndex="0" GridPane.rowIndex="1" styleClass="text-field"/>

                    <!-- Card Number -->
                    <Label text="Card Number" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="cardNumberField" promptText="XXXX-XXXX-XXXX-XXXX" GridPane.columnIndex="1" GridPane.rowIndex="1" styleClass="text-field"/>

                    <!-- Expiry Date -->
                    <Label text="Expiry Date" style="-fx-font-weight: bold;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="expiryDateField" promptText="MM/YY" GridPane.columnIndex="0" GridPane.rowIndex="3" styleClass="text-field"/>

                    <!-- CVV -->
                    <Label text="CVV" style="-fx-font-weight: bold;" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <TextField fx:id="cvvField" promptText="123" GridPane.columnIndex="1" GridPane.rowIndex="3" styleClass="text-field"/>
                </GridPane>

                <!-- Order Summary -->
                <VBox spacing="8" style="-fx-background-color: white; -fx-padding: 15; -fx-border-radius: 8; -fx-border-color: #e0e0e0;">
                    <Label text="Order Summary" style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
                    <HBox spacing="10">
                        <Label text="Items:" style="-fx-font-size: 12px;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="orderItemsLabel" text="0 items" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                    </HBox>
                    <HBox spacing="10">
                        <Label text="Total Amount:" style="-fx-font-size: 12px; -fx-font-weight: bold;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="orderTotalLabel" text="0.00 TND" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #e84393;"/>
                    </HBox>
                </VBox>

                <!-- Pay Button -->
                <HBox spacing="15" alignment="CENTER">
                    <Button text="💰 Pay Securely" onAction="#handlePayment" prefHeight="45" prefWidth="200" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #0984e3; -fx-text-fill: white; -fx-padding: 12 30; -fx-border-radius: 8; -fx-cursor: hand;"/>
                    <Button fx:id="downloadReceiptBtn" text="📄 Download Receipt" onAction="#handleDownloadReceipt" prefHeight="45" prefWidth="200" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 12 30; -fx-border-radius: 8; -fx-cursor: hand;"/>
                </HBox>
            </VBox>

    </VBox>
</ScrollPane>

