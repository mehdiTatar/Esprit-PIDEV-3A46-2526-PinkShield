<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.WishlistController" spacing="20" stylesheets="@style.css" style="-fx-padding: 30; -fx-background-color: #f5f6fa;">

    <Label text="❤️ Your Wishlist" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-text-fill: #ff69b4;"/>
    <Label text="Your saved products and items for future purchase" style="-fx-font-size: 14; -fx-text-fill: #666;"/>

    <!-- Search -->
    <TextField fx:id="searchBar" promptText="🔍 Search your wishlist..." prefHeight="35" styleClass="text-field"/>

    <!-- Wishlist Items -->
    <VBox styleClass="card-pane" spacing="15">
        <Label text="📦 Saved Items" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #ff69b4;"/>

        <TableView fx:id="table" VBox.vgrow="ALWAYS" styleClass="table-view" prefHeight="350">
            <columns>
                <TableColumn fx:id="colId" text="Item ID" prefWidth="80"/>
                <TableColumn fx:id="colParapharmacieId" text="📦 Product" prefWidth="200"/>
                <TableColumn fx:id="colAddedAt" text="📅 Added On" prefWidth="150"/>
                <TableColumn fx:id="colAction" text="❌ Action" prefWidth="100"/>
            </columns>
        </TableView>
    </VBox>

    <!-- Action Button -->
    <HBox spacing="15">
        <Button text="🗑️ Remove Selected Item" onAction="#handleSupprimer" styleClass="btn-danger"/>
        <Button text="🔄 Refresh" onAction="#handleRefresh" styleClass="btn-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="💡 Tip: Save items from the Parapharmacie section to add to your wishlist!" style="-fx-text-fill: #666; -fx-font-size: 12;"/>
    </HBox>

</VBox>

