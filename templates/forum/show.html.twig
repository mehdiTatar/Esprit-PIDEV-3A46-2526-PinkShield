{% extends 'base.html.twig' %}

{% block title %}{{ post.title }} - Medical Forum{% endblock %}

{% block body %}
<div class="container py-4">
    <a href="{{ path('forum_index') }}" class="btn btn-sm btn-outline-secondary mb-3">
        <i class="fas fa-arrow-left me-1"></i> Forum
    </a>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type in ['danger', 'warning'] ? type : 'success' }}">{{ message }}</div>
        {% endfor %}
    {% endfor %}

    <article class="card border-0 shadow-sm {{ post.doctorPost ? 'border-start border-4 border-info' : '' }}">
        <div class="card-body">
            <div class="d-flex align-items-center gap-2 mb-3">
                {% if post.doctorPost %}
                    <span class="badge text-bg-info"><i class="fas fa-user-md me-1"></i> Doctor Post</span>
                {% else %}
                    <span class="badge text-bg-secondary">Patient Post</span>
                {% endif %}
                {% if not post.allowsComments %}
                    <span class="badge text-bg-warning">Comments closed</span>
                {% endif %}
            </div>
            <h1 class="h3">{{ post.title }}</h1>
            <div class="text-muted small mb-3">{{ post.authorName }} &middot; {{ post.createdAt|date('M d, Y H:i') }}</div>
            {% if post.imagePath %}
                <img src="{{ asset(post.imagePath) }}" alt="{{ post.title }}" class="img-fluid rounded mb-3" style="max-height: 520px; width: 100%; object-fit: cover;">
            {% endif %}
            <p class="fs-6" style="white-space: pre-line;">{{ post.content }}</p>
            <div class="d-flex flex-wrap gap-2 align-items-center">
                {% if app.user %}
                    <button class="btn {{ liked ? 'btn-danger' : 'btn-outline-danger' }} forum-like-btn"
                            data-like-url="{{ path('forum_like', {id: post.id}) }}"
                            data-like-token="{{ csrf_token('forum_like_' ~ post.id) }}">
                        <i class="fas fa-heart me-1"></i>
                        <span class="like-count">{{ post.likes|length }}</span>
                    </button>
                {% else %}
                    <a class="btn btn-outline-danger" href="{{ path('login') }}">
                        <i class="fas fa-heart me-1"></i>
                        <span class="like-count">{{ post.likes|length }}</span>
                    </a>
                {% endif %}
                {% if canManage %}
                    <a class="btn btn-outline-secondary" href="{{ path('forum_edit', {id: post.id}) }}">
                        <i class="fas fa-pen me-1"></i> Edit
                    </a>
                    <form method="post" action="{{ path('forum_delete', {id: post.id}) }}" onsubmit="return confirm('Delete this forum post?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('forum_delete_' ~ post.id) }}">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="fas fa-trash me-1"></i> Delete
                        </button>
                    </form>
                {% endif %}
            </div>
        </div>
    </article>

    <section class="card border-0 shadow-sm mt-4">
        <div class="card-header bg-white">
            <h2 class="h5 mb-0">Comments</h2>
        </div>
        <div class="card-body">
            {% if app.user and post.allowsComments %}
                <form method="post" action="{{ path('forum_comment', {id: post.id}) }}" class="mb-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('forum_comment_' ~ post.id) }}">
                    <label for="content" class="form-label">Add a comment</label>
                    <textarea name="content" id="content" class="form-control mb-2" rows="3" required></textarea>
                    <button type="submit" class="btn btn-primary">Post Comment</button>
                </form>
            {% elseif not post.allowsComments %}
                <div class="alert alert-warning">This doctor post is closed for comments.</div>
            {% endif %}

            {% if comments|length > 0 %}
                {% for comment in comments %}
                    {% include 'forum/_comment.html.twig' with {comment: comment, post: post, depth: 0} %}
                {% endfor %}
            {% else %}
                <div class="text-center py-4 text-muted">No comments yet.</div>
            {% endif %}
        </div>
    </section>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
document.querySelectorAll('.reply-toggle').forEach(button => {
    button.addEventListener('click', () => {
        document.getElementById(button.dataset.target)?.classList.toggle('d-none');
    });
});

document.querySelectorAll('.forum-like-btn').forEach(button => {
    button.addEventListener('click', async () => {
        const response = await fetch(button.dataset.likeUrl, {
            method: 'POST',
            headers: {
                'X-Requested-With': 'XMLHttpRequest',
                'X-CSRF-TOKEN': button.dataset.likeToken
            }
        });
        if (!response.ok) return;
        const data = await response.json();
        button.classList.toggle('btn-danger', data.liked);
        button.classList.toggle('btn-outline-danger', !data.liked);
        button.querySelector('.like-count').textContent = data.count;
    });
});
</script>
{% endblock %}
