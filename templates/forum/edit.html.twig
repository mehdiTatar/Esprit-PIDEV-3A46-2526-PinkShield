{% extends 'base.html.twig' %}

{% block title %}Edit Forum Post - PinkShield{% endblock %}

{% block body %}
<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-header bg-white">
                    <h1 class="h4 mb-0">Edit Forum Post</h1>
                </div>
                <div class="card-body">
                    {% for type, messages in app.flashes %}
                        {% for message in messages %}
                            <div class="alert alert-{{ type in ['danger', 'warning'] ? type : 'success' }}">{{ message }}</div>
                        {% endfor %}
                    {% endfor %}
                    <form method="post" enctype="multipart/form-data">
                        <input type="hidden" name="_token" value="{{ csrf_token('forum_edit_' ~ post.id) }}">
                        <div class="mb-3">
                            <label for="title" class="form-label">Title</label>
                            <input type="text" name="title" id="title" class="form-control" minlength="5" value="{{ post.title }}" required>
                        </div>
                        <div class="mb-3">
                            <label for="content" class="form-label">Content</label>
                            <textarea name="content" id="content" class="form-control" rows="8" minlength="10" required>{{ post.content }}</textarea>
                        </div>

                        {% if post.imagePath %}
                            <div class="mb-3">
                                <label class="form-label">Current image</label>
                                <img src="{{ asset(post.imagePath) }}" alt="{{ post.title }}" class="img-fluid rounded d-block mb-2" style="max-height: 320px; object-fit: cover;">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="remove_image" id="remove_image" value="1">
                                    <label class="form-check-label" for="remove_image">Remove image</label>
                                </div>
                            </div>
                        {% endif %}

                        <div class="mb-3">
                            <label for="image" class="form-label">{{ post.imagePath ? 'Replace image' : 'Image' }}</label>
                            <input type="file" name="image" id="image" class="form-control" accept="image/*">
                            <div class="form-text">Optional. JPG, PNG, GIF, or WebP up to 5 MB.</div>
                        </div>

                        {% if is_granted('ROLE_DOCTOR') and post.doctorPost %}
                            <div class="form-check form-switch mb-4">
                                <input class="form-check-input" type="checkbox" role="switch" name="allow_comments" id="allow_comments" value="1" {{ post.allowsComments ? 'checked' : '' }}>
                                <label class="form-check-label" for="allow_comments">Allow patient comments</label>
                            </div>
                        {% endif %}

                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ path('forum_show', {id: post.id}) }}" class="btn btn-outline-secondary">Cancel</a>
                            <button type="submit" class="btn btn-primary">Save Changes</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
