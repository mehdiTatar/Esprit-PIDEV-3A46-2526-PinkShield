<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="csrf-token" content="{{ csrf_token('') }}">
        <title>{% block title %}PinkShield — Medical Management System{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/colored-logo.png') }}">

        {# Fonts #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=Orbitron:wght@400;700;900&display=swap" rel="stylesheet">

        {# Bootstrap & Icons #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        {% block stylesheets %}{% endblock %}

        <style>
            /* ─── Design Tokens ─────────────────────────────────────────── */
            :root {
                /* Colors */
                --primary:        #c0396b;
                --primary-dark:   #9b2553;
                --primary-light:  rgba(192, 57, 107, 0.12);
                --secondary:      #fce4ec;
                --light-bg:       #060e1c;
                --border:         rgba(192,57,107,0.2);
                --text-dark:      #e8eaf6;
                --text-gray:      #8aa4c8;
                --text-muted:     #526a82;

                /* Dimensions */
                --navbar-height:  64px;
                --sidebar-width:  260px;
                --container-max:  1140px; /* Reduced from 1240 to fit better on 1366px screens */
                --card-radius:    12px;

                /* Appearance */
                --sidebar-bg:     #060e1c;
                --sidebar-bg2:    #0a1525;
                --shadow-sm:      0 2px 8px rgba(0,0,0,0.3);
                --shadow-md:      0 6px 24px rgba(0,0,0,0.4);
                --shadow-lg:      0 12px 40px rgba(0,0,0,0.5);
                --transition:     all 0.22s ease;
                --glass:          rgba(255,255,255,0.03);
                --glass-border:   rgba(255,255,255,0.07);
            }

            /* ─── Reset & Base ──────────────────────────────────────────── */
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

            html, body { min-height: 100%; }

            body {
                background: #060e1c;
                background-image:
                    radial-gradient(ellipse at 10% 0%, rgba(192,57,107,0.07) 0%, transparent 50%),
                    radial-gradient(ellipse at 90% 100%, rgba(59,130,246,0.05) 0%, transparent 50%);
                background-attachment: fixed;
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                color: var(--text-dark);
                line-height: 1.6;
                display: flex;
                flex-direction: column;
                font-size: 0.95rem;
            }

            /* ─── Accessibility ─────────────────────────────────────────── */
            .skip-link {
                position: absolute;
                top: -100%;
                left: 1rem;
                background: var(--primary);
                color: #fff;
                padding: 0.5rem 1rem;
                border-radius: 0 0 8px 8px;
                font-weight: 600;
                z-index: 9999;
                text-decoration: none;
                transition: top 0.2s;
            }
            .skip-link:focus { top: 0; }

            /* ─── Navbar ──────────────────────────────────────────── */
            .navbar {
                background: rgba(6,14,28,0.95);
                backdrop-filter: blur(20px);
                -webkit-backdrop-filter: blur(20px);
                box-shadow: 0 1px 0 rgba(192,57,107,0.15), 0 4px 24px rgba(0,0,0,0.4);
                border-bottom: 1px solid rgba(192,57,107,0.2);
                height: var(--navbar-height);
                padding: 0; position: sticky; top: 0; z-index: 1030;
                position: relative;
            }
            .navbar::after {
                content: '';
                position: absolute; bottom: 0; left: 0; right: 0; height: 2px;
                background: linear-gradient(90deg, transparent, #c0396b 30%, #ff6ba8 50%, #c0396b 70%, transparent);
                animation: navLineGlow 4s ease-in-out infinite;
            }
            @keyframes navLineGlow { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

            .navbar-brand {
                display: flex; align-items: center; gap: 10px;
                font-family: 'Orbitron', sans-serif;
                font-weight: 700; color: #fff !important;
                font-size: 1rem; letter-spacing: 1px; text-decoration: none;
            }
            .navbar-brand img {
                height: 34px; width: auto;
                filter: drop-shadow(0 0 8px rgba(192,57,107,0.6)) brightness(1.1);
            }
            .navbar-brand span { color: #fff; }

            .nav-link {
                color: rgba(255,255,255,0.55) !important;
                font-weight: 500; font-size: 0.88rem;
                padding: 0.45rem 0.9rem !important;
                border-radius: 8px; transition: var(--transition);
                display: flex; align-items: center; gap: 6px;
            }
            .nav-link:hover  { color: #fff !important; background: rgba(192,57,107,0.1); }
            .nav-link.active { color: #ff6ba8 !important; background: rgba(192,57,107,0.15); font-weight: 600; }

            .navbar-toggler       { border: none; }
            .navbar-toggler:focus { box-shadow: none; }

            /* ─── Dropdown ────────────────────────────────────────── */
            .dropdown-menu {
                background: rgba(8,16,30,0.97);
                border: 1px solid rgba(192,57,107,0.2);
                box-shadow: 0 16px 48px rgba(0,0,0,0.6);
                border-radius: var(--card-radius);
                margin-top: 8px; padding: 6px;
                backdrop-filter: blur(20px);
            }
            .dropdown-item {
                color: rgba(255,255,255,0.6);
                font-weight: 500; padding: 0.65rem 0.9rem;
                border-radius: 8px; transition: var(--transition);
                display: flex; align-items: center; gap: 8px; font-size: 0.88rem;
            }
            .dropdown-item:hover { background: rgba(192,57,107,0.12); color: #fff; }
            .dropdown-divider { border-color: rgba(255,255,255,0.06); }

            /* ─── Buttons ───────────────────────────────────────── */
            .btn-primary {
                background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%);
                border: none; color: #fff; font-weight: 600;
                padding: 0.5rem 1.25rem; border-radius: 9px;
                transition: var(--transition); letter-spacing: 0.01em;
            }
            .btn-primary:hover, .btn-primary:focus {
                background: linear-gradient(135deg, #9b2553 0%, #c0396b 100%);
                color: #fff; transform: translateY(-2px);
                box-shadow: 0 8px 24px rgba(192,57,107,0.45);
            }
            .btn-primary:active { transform: translateY(0); box-shadow: none; }

            .btn-outline-primary {
                color: #c0396b; border: 1.5px solid rgba(192,57,107,0.45);
                background: rgba(192,57,107,0.06); font-weight: 600;
                border-radius: 9px; transition: var(--transition);
            }
            .btn-outline-primary:hover, .btn-outline-primary:focus {
                background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%);
                border-color: transparent; color: #fff;
                transform: translateY(-1px); box-shadow: 0 6px 18px rgba(192,57,107,0.4);
            }

            .btn-danger {
                background: linear-gradient(135deg, #dc2626, #ef4444);
                border: none; font-weight: 600; border-radius: 9px;
                transition: var(--transition);
            }
            .btn-danger:hover {
                background: linear-gradient(135deg, #b91c1c, #dc2626);
                transform: translateY(-1px); box-shadow: 0 6px 18px rgba(220,38,38,0.4);
            }

            .btn-secondary {
                background: rgba(255,255,255,0.06);
                border: 1px solid rgba(255,255,255,0.1);
                color: var(--text-gray); font-weight: 600;
                border-radius: 9px; transition: var(--transition);
            }
            .btn-secondary:hover {
                background: rgba(255,255,255,0.1);
                border-color: rgba(255,255,255,0.15); color: #fff;
            }

            /* ─── Role Badge ────────────────────────────────────────────── */
            .role-badge {
                display: inline-block; padding: 0.18rem 0.6rem;
                border-radius: 20px; font-size: 0.66rem;
                font-weight: 700; text-transform: uppercase; letter-spacing: 0.6px;
                margin-left: 6px;
            }
            .role-admin  { background: rgba(192,57,107,0.2); color: #ff6ba8; border: 1px solid rgba(192,57,107,0.3); }
            .role-doctor { background: rgba(20,184,166,0.15); color: #2dd4bf; border: 1px solid rgba(20,184,166,0.3); }
            .role-user   { background: rgba(59,130,246,0.15); color: #60a5fa; border: 1px solid rgba(59,130,246,0.3); }

            /* ─── Notification Bell ─────────────────────────────────────── */
            .notification-badge {
                position: relative;
                display: flex;
                align-items: center;
                cursor: pointer;
                font-size: 1.15rem;
                color: var(--text-gray);
                transition: var(--transition);
                padding: 8px 10px;
                border-radius: 10px;
                border: 1.5px solid transparent;
            }

            .notification-badge:hover {
                color: var(--primary);
                background: var(--primary-light);
                border-color: var(--border);
            }

            .notification-badge .badge {
                position: absolute;
                top: 2px;
                right: 2px;
                background: linear-gradient(135deg, var(--primary), #e8557a);
                color: #fff;
                font-size: 0.6rem;
                padding: 0.2rem 0.4rem;
                border-radius: 10px;
                font-weight: 700;
                min-width: 18px;
                text-align: center;
                display: none;
                animation: pulse 2s infinite;
            }

            @keyframes pulse {
                0%, 100% { opacity: 1; transform: scale(1); }
                50%       { opacity: 0.75; transform: scale(1.1); }
            }

            .notification-dropdown { min-width: 370px !important; }

            .notification-dropdown .dropdown-header {
                background: var(--primary-light);
                color: var(--primary-dark);
                font-weight: 700;
                padding: 0.9rem 1rem;
                border-radius: 8px 8px 0 0;
                font-size: 0.9rem;
            }

            .notification-dropdown .dropdown-item {
                padding: 0.85rem 1rem;
                border-bottom: 1px solid var(--border);
                white-space: normal;
                border-radius: 0;
            }

            .notification-dropdown .dropdown-item:last-child {
                border-bottom: none;
                border-radius: 0 0 8px 8px;
            }

            .notification-item { display: flex; align-items: flex-start; gap: 10px; }

            .notification-icon {
                font-size: 1rem;
                color: var(--primary);
                flex-shrink: 0;
                margin-top: 3px;
            }

            .notification-content { flex: 1; }
            .notification-content small { display: block; line-height: 1.4; }

            /* ─── Sidebar Toggle Button ─────────────────────────────────── */
            .sidebar-toggle-btn {
                position: fixed;
                top: calc(var(--navbar-height) + 12px);
                left: 12px;
                z-index: 2000;
                background: linear-gradient(135deg, var(--primary) 0%, #e8557a 100%);
                color: #fff;
                border: none;
                border-radius: 50%;
                width: 38px;
                height: 38px;
                box-shadow: 0 3px 12px rgba(192, 57, 107, 0.35);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: var(--transition);
                cursor: pointer;
            }

            .sidebar-toggle-btn:hover {
                background: linear-gradient(135deg, var(--primary-dark) 0%, var(--primary) 100%);
                transform: scale(1.1) rotate(90deg);
                box-shadow: 0 6px 20px rgba(192, 57, 107, 0.45);
            }

            /* ─── Sidebar ───────────────────────────────────────────────── */
            .sidebar {
                background: linear-gradient(180deg, var(--sidebar-bg) 0%, var(--sidebar-bg2) 100%);
                border-right: none;
                position: fixed;
                left: 0;
                top: var(--navbar-height);
                width: var(--sidebar-width);
                height: calc(100vh - var(--navbar-height));
                overflow-y: auto;
                overflow-x: hidden;
                padding: 0;
                z-index: 1020;
                transform: translateX(0);
                transition: transform 0.35s cubic-bezier(0.77, 0, 0.175, 1);
                box-shadow: 4px 0 24px rgba(0,0,0,0.25);
                display: flex;
                flex-direction: column;
            }

            /* Custom scrollbar for dark sidebar */
            .sidebar::-webkit-scrollbar { width: 4px; }
            .sidebar::-webkit-scrollbar-track { background: transparent; }
            .sidebar::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.12); border-radius: 4px; }
            .sidebar::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

            .sidebar-logo {
                padding: 22px 20px 18px;
                border-bottom: 1px solid rgba(255,255,255,0.05);
                background: rgba(192,57,107,0.03);
                flex-shrink: 0;
            }
            .sidebar-logo a { display: flex; align-items: center; gap: 11px; text-decoration: none; }
            .sidebar-logo img {
                height: 34px; width: auto;
                filter: drop-shadow(0 0 8px rgba(192,57,107,0.5)) brightness(1.1);
            }
            .sidebar-logo span {
                font-family: 'Orbitron', sans-serif;
                font-size: 0.9rem; font-weight: 700; color: #fff; letter-spacing: 0.5px;
            }
            .sidebar-logo .logo-subtitle {
                font-size: 0.58rem; font-weight: 500;
                color: rgba(255,255,255,0.25);
                text-transform: uppercase; letter-spacing: 1.5px;
                display: block; margin-top: 1px; font-family: 'Inter', sans-serif;
            }

            .sidebar-section { padding: 16px 0 6px; flex-shrink: 0; }
            .sidebar-section-title {
                padding: 0 18px; margin-bottom: 6px;
                font-size: 0.58rem; font-weight: 700;
                text-transform: uppercase; letter-spacing: 1.8px;
                color: rgba(255,255,255,0.18);
            }

            .sidebar-nav { display: flex; flex-direction: column; gap: 2px; padding: 0 10px; }

            .sidebar-link {
                display: flex; align-items: center; gap: 10px;
                padding: 10px 13px; color: rgba(255,255,255,0.4);
                text-decoration: none; font-weight: 500;
                font-size: 0.84rem; transition: var(--transition);
                border-radius: 10px; border-left: 2px solid transparent;
                position: relative;
            }
            .sidebar-link:hover {
                color: #fff; background: rgba(192,57,107,0.1);
                border-left-color: rgba(192,57,107,0.6);
            }
            .sidebar-link.active {
                color: #fff; background: rgba(192,57,107,0.15);
                border-left-color: #c0396b; font-weight: 600;
            }
            .sidebar-link.active::after {
                content: ''; position: absolute; right: 10px;
                width: 5px; height: 5px; border-radius: 50%;
                background: #c0396b; box-shadow: 0 0 8px #c0396b;
            }
            .sidebar-link i { width: 20px; text-align: center; font-size: 0.88rem; opacity: 0.7; }
            .sidebar-link:hover i, .sidebar-link.active i { opacity: 1; }

            /* Role-specific sidebar colors */
            [data-sidebar-role='admin'] .sidebar-link:hover { background: rgba(59,130,246,0.1); border-left-color: #3b82f6; }
            [data-sidebar-role='admin'] .sidebar-link.active { background: rgba(59,130,246,0.15); border-left-color: #3b82f6; }
            [data-sidebar-role='admin'] .sidebar-link.active::after { background: #3b82f6; box-shadow: 0 0 8px #3b82f6; }
            [data-sidebar-role='admin'] .sidebar-section-title { color: rgba(59,130,246,0.3); }
            [data-sidebar-role='doctor'] .sidebar-link:hover { background: rgba(20,184,166,0.1); border-left-color: #14b8a6; }
            [data-sidebar-role='doctor'] .sidebar-link.active { background: rgba(20,184,166,0.15); border-left-color: #14b8a6; }
            [data-sidebar-role='doctor'] .sidebar-link.active::after { background: #14b8a6; box-shadow: 0 0 8px #14b8a6; }
            [data-sidebar-role='doctor'] .sidebar-section-title { color: rgba(20,184,166,0.3); }

            /* Sidebar footer — pinned user info */
            .sidebar-footer {
                margin-top: auto;
                padding: 14px 14px;
                border-top: 1px solid rgba(255,255,255,0.08);
                background: rgba(0,0,0,0.15);
                flex-shrink: 0;
            }

            .sidebar-footer-inner {
                display: flex;
                align-items: center;
                gap: 10px;
            }

            .sidebar-user-avatar {
                width: 34px; height: 34px;
                border-radius: 50%;
                background: linear-gradient(135deg, var(--primary), #e8557a);
                color: #fff;
                display: flex; align-items: center; justify-content: center;
                font-weight: 700; font-size: 0.85rem;
                flex-shrink: 0;
            }

            .sidebar-user-info { flex: 1; min-width: 0; }

            .sidebar-user-name {
                font-size: 0.8rem; font-weight: 700;
                color: rgba(255,255,255,0.9);
                white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
            }

            .sidebar-user-role {
                font-size: 0.68rem; font-weight: 500;
                color: rgba(255,255,255,0.38);
                text-transform: uppercase; letter-spacing: 0.6px;
            }

            .sidebar-logout {
                width: 28px; height: 28px;
                border-radius: 8px;
                background: rgba(239,68,68,0.15);
                color: rgba(239,68,68,0.8);
                display: flex; align-items: center; justify-content: center;
                font-size: 0.75rem;
                text-decoration: none;
                transition: var(--transition);
                flex-shrink: 0;
            }

            .sidebar-logout:hover {
                background: rgba(239,68,68,0.3);
                color: #ef4444;
            }

            /* ─── Main Content ──────────────────────────────────────────── */
            main {
                flex: 1 0 auto;
                margin-left: var(--sidebar-width);
                margin-top: 0;
                width: calc(100% - var(--sidebar-width));
                transition: margin-left 0.35s cubic-bezier(0.77, 0, 0.175, 1), width 0.35s cubic-bezier(0.77, 0, 0.175, 1);
                position: relative;
                z-index: 1;
            }

            .container-desktop {
                max-width: var(--container-max);
                margin: 0 auto;
                padding: 40px 24px;
                width: 100%;
            }

            /* ─── Form Controls ───────────────────────────────── */
            .form-control, .form-select {
                border-radius: 10px;
                border: 1px solid rgba(255,255,255,0.08);
                padding: 0.6rem 0.9rem;
                font-size: 0.9rem;
                color: #fff;
                transition: var(--transition);
                background: rgba(255,255,255,0.04);
            }
            .form-control::placeholder { color: rgba(255,255,255,0.22); }
            .form-select option { background: #0a1525; color: #fff; }
            .form-control:focus, .form-select:focus {
                border-color: rgba(192,57,107,0.5);
                box-shadow: 0 0 0 3px rgba(192,57,107,0.12);
                background: rgba(255,255,255,0.06);
                outline: none; color: #fff;
            }
            .form-label {
                font-weight: 600; font-size: 0.8rem;
                color: var(--text-gray); margin-bottom: 0.4rem;
                text-transform: uppercase; letter-spacing: 0.5px;
            }

            /* ─── Alerts ────────────────────────────────────────────────── */
            .alert {
                border: none;
                border-radius: var(--card-radius);
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 12px;
                border-left: 4px solid;
                padding: 0.9rem 1rem;
            }

            .alert-success { background: rgba(34,197,94,0.1); color: #4ade80; border-left-color: #22c55e; }
            .alert-danger  { background: rgba(239,68,68,0.1); color: #f87171; border-left-color: #ef4444; }
            .alert-warning { background: rgba(245,158,11,0.1); color: #fbbf24; border-left-color: #f59e0b; }
            .alert-info    { background: rgba(192,57,107,0.1); color: #f9a8d4; border-left-color: #c0396b; }

            /* ─── Form Validation ───────────────────────────────────────── */
            .form-control.is-invalid {
                border-color: #dc3545;
                box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.12);
            }

            .form-control.is-valid {
                border-color: #22c55e;
                box-shadow: 0 0 0 3px rgba(34, 197, 94, 0.12);
            }

            .ajax-error {
                color: #dc3545;
                font-size: 0.82em;
                margin-top: 0.25rem;
                display: none;
            }

            .ajax-error.d-block { display: block !important; }

            /* Hide Symfony default form errors — using AJAX validation */
            .form-text.text-danger,
            .invalid-feedback,
            .form-group .alert-danger { display: none !important; }

            /* ─── Footer ────────────────────────────────────────── */
            footer {
                flex-shrink: 0;
                background: rgba(6,14,28,0.98);
                border-top: 1px solid rgba(192,57,107,0.1);
                padding: 1.2rem 2rem; text-align: center;
                font-size: 0.82rem; color: var(--text-muted);
                margin-left: var(--sidebar-width);
                width: calc(100% - var(--sidebar-width));
                transition: margin-left 0.35s cubic-bezier(0.77, 0, 0.175, 1), width 0.35s cubic-bezier(0.77, 0, 0.175, 1);
            }
            footer a { color: #c0396b; text-decoration: none; font-weight: 500; }
            footer a:hover { color: #ff6ba8; }

            /* ─── Rich Site Footer ───────────────────────────────── */
            .site-footer {
                flex-shrink: 0;
                background: linear-gradient(180deg, #080f1e 0%, #050d1a 100%);
                border-top: 1px solid rgba(192,57,107,0.08);
                color: rgba(255,255,255,0.45);
                margin-left: var(--sidebar-width);
                padding: 0; font-size: 0.88rem;
                width: calc(100% - var(--sidebar-width));
                transition: margin-left 0.35s cubic-bezier(0.77, 0, 0.175, 1), width 0.35s cubic-bezier(0.77, 0, 0.175, 1);
            }

            .footer-inner {
                display: grid;
                grid-template-columns: 2fr 1fr 1fr;
                gap: 40px;
                padding: 48px 52px 36px;
                border-bottom: 1px solid rgba(255,255,255,0.07);
            }

            .footer-brand {}

            .footer-logo-link {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
                margin-bottom: 14px;
            }

            .footer-logo-img { height: 36px; width: auto; filter: brightness(1.1); }

            .footer-logo-text {
                font-size: 1.2rem;
                font-weight: 800;
                color: #fff;
                letter-spacing: -0.3px;
            }

            .footer-tagline {
                color: rgba(255,255,255,0.48);
                font-size: 0.84rem;
                line-height: 1.6;
                margin-bottom: 20px;
                max-width: 300px;
            }

            .footer-socials {
                display: flex;
                gap: 10px;
            }

            .footer-social-btn {
                width: 36px; height: 36px;
                border-radius: 50%;
                background: rgba(255,255,255,0.07);
                color: rgba(255,255,255,0.65);
                display: flex; align-items: center; justify-content: center;
                font-size: 0.85rem;
                text-decoration: none;
                transition: var(--transition);
                border: 1px solid rgba(255,255,255,0.10);
            }

            .footer-social-btn:hover {
                background: linear-gradient(135deg, var(--primary), #e8557a);
                color: #fff;
                border-color: transparent;
                transform: translateY(-2px);
            }

            .footer-col-title {
                font-weight: 700;
                font-size: 0.78rem;
                text-transform: uppercase;
                letter-spacing: 1.2px;
                color: rgba(255,255,255,0.9);
                margin-bottom: 16px;
            }

            .footer-links {
                list-style: none;
                padding: 0;
                margin: 0;
                display: flex;
                flex-direction: column;
                gap: 10px;
            }

            .footer-links a {
                color: rgba(255,255,255,0.5);
                text-decoration: none;
                transition: var(--transition);
                font-size: 0.85rem;
            }

            .footer-links a:hover {
                color: #e8557a;
                padding-left: 4px;
            }

            .footer-bottom {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 14px 52px;
                font-size: 0.78rem;
                color: rgba(255,255,255,0.28);
                flex-wrap: wrap;
                gap: 8px;
            }

            .footer-bottom strong { color: var(--primary); }

            .footer-bottom-links {
                display: flex;
                gap: 16px;
            }

            .footer-bottom-links a {
                color: rgba(255,255,255,0.3);
                text-decoration: none;
                transition: color 0.2s;
            }

            .footer-bottom-links a:hover { color: rgba(255,255,255,0.65); }

            @media (max-width: 991px) {
                .site-footer { margin-left: 0; }
                .footer-inner { grid-template-columns: 1fr; gap: 28px; padding: 32px 24px 24px; }
                .footer-bottom { padding: 12px 24px; flex-direction: column; text-align: center; }
                .footer-bottom-links { justify-content: center; }
            }

            /* ─── Responsive ────────────────────────────────────────────── */
            @media (max-width: 1300px) {
                :root { --sidebar-width: 240px; }
            }

            @media (max-width: 991px) {
                .sidebar { transform: translateX(-100%); }
                .sidebar.show { transform: translateX(0); }
                main, footer, .site-footer { margin-left: 0; width: 100%; transition: none; }
            }

            @media (max-width: 768px) {
                .container-desktop { padding: 20px 16px; }
                .navbar-brand span { display: none; }
            }

            /* ─── Utility ────────────────────────────────────────── */
            .text-primary { color: #c0396b !important; }
            .text-muted { color: var(--text-muted) !important; }
            .bg-primary   { background: linear-gradient(135deg, #c0396b, #e8557a) !important; }

            /* Tables */
            .table { color: var(--text-dark); }
            .table th { color: var(--text-gray); font-size: 0.72rem; font-weight: 700;
                text-transform: uppercase; letter-spacing: 0.8px;
                border-color: rgba(255,255,255,0.07); background: rgba(255,255,255,0.02); }
            .table td { border-color: rgba(255,255,255,0.05); vertical-align: middle; }
            .table-striped > tbody > tr:nth-of-type(odd) > * { background: rgba(255,255,255,0.015); }
            .table-hover > tbody > tr:hover > * { background: rgba(192,57,107,0.06); }

            /* Cards */
            .card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.07); border-radius: var(--card-radius); }
            .card:hover { border-color: rgba(192,57,107,0.2); }
            .card-header { background: rgba(255,255,255,0.04); border-bottom: 1px solid rgba(255,255,255,0.07); color: #fff; font-weight: 600; }
            .card-body { color: var(--text-dark); }

            /* Status badges */
            .badge.bg-success { background: rgba(34,197,94,0.15) !important; color: #4ade80 !important; border: 1px solid rgba(34,197,94,0.25); }
            .badge.bg-danger  { background: rgba(239,68,68,0.15) !important; color: #f87171 !important; border: 1px solid rgba(239,68,68,0.25); }
            .badge.bg-warning { background: rgba(245,158,11,0.15) !important; color: #fbbf24 !important; border: 1px solid rgba(245,158,11,0.25); }
            .badge.bg-info    { background: rgba(59,130,246,0.15) !important; color: #60a5fa !important; border: 1px solid rgba(59,130,246,0.25); }

            /* Glass panel utility */
            .glass-panel {
                background: rgba(255,255,255,0.03);
                border: 1px solid rgba(255,255,255,0.07);
                border-radius: var(--card-radius);
                backdrop-filter: blur(12px);
            }

            /* Smooth card hover lift */
            .card, .adm-panel, .kpi-card, .doc-panel, .panel-card {
                transition: box-shadow 0.22s ease, transform 0.22s ease, border-color 0.22s ease;
            }
        </style>
    </head>
