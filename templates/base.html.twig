<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}PinkShield - Medical Management System{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/logo.png') }}">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
        {% block stylesheets %}
        {% endblock %}

        {% block javascripts %}
        {% endblock %}
        <style>
            :root {
                --primary-red: #C41E3A;
                --primary-dark: #8B1428;
                --light-bg: #fdfdfd;
                --text-dark: #2C3E50;
                --sidebar-width: 260px;
            }

            body {
                background-color: var(--light-bg);
                font-family: 'Inter', 'Segoe UI', Roboto, sans-serif;
                color: var(--text-dark);
                overflow-x: hidden;
            }

            /* Desktop Optimized Navbar */
            .navbar {
                background: white;
                box-shadow: 0 2px 15px rgba(0,0,0,0.05);
                padding: 0.75rem 0;
                border-bottom: 1px solid rgba(0,0,0,0.05);
            }

            .navbar-brand {
                display: flex;
                align-items: center;
                gap: 12px;
                font-weight: 800;
                color: var(--primary-red) !important;
                font-size: 1.6rem;
                letter-spacing: -0.5px;
            }

            .logo-img {
                height: 45px;
                width: auto;
                object-fit: contain;
            }

            .container-desktop {
                max-width: 1400px;
                margin: 0 auto;
                padding: 0 30px;
            }

            .main-content {
                padding-top: 40px;
                padding-bottom: 60px;
                min-height: calc(100vh - 160px);
            }

            /* Desktop Navigation */
            .nav-link {
                color: #5a6a85 !important;
                font-weight: 600;
                padding: 0.5rem 1.2rem !important;
                border-radius: 8px;
                transition: all 0.2s ease;
            }

            .nav-link:hover {
                background: rgba(196, 30, 58, 0.05);
                color: var(--primary-red) !important;
            }

            .nav-link.active {
                background: rgba(196, 30, 58, 0.1);
                color: var(--primary-red) !important;
            }

            .navbar-nav .dropdown-toggle::after {
                border-color: var(--primary-red);
            }

            .dropdown-item.active {
                background-color: var(--primary-red);
                color: white !important;
            }

            .dropdown-item.active:hover {
                background-color: var(--primary-dark);
            }

            /* Button Styling */
            .btn-primary {
                background-color: var(--primary-red);
                border-color: var(--primary-red);
                font-weight: 600;
                transition: all 0.3s ease;
            }

            .btn-primary:hover {
                background-color: var(--primary-dark);
                border-color: var(--primary-dark);
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(196, 30, 58, 0.3);
            }

            .btn-primary:active {
                transform: translateY(0);
            }

            .btn-outline-primary {
                color: var(--primary-red);
                border-color: var(--primary-red);
            }

            .btn-outline-primary:hover {
                background-color: var(--primary-red);
                border-color: var(--primary-red);
            }

            /* Alert Styling */
            .alert-success {
                background-color: #d4edda;
                border-color: #c3e6cb;
                color: #155724;
            }

            .alert-danger {
                background-color: #f8d7da;
                border-color: #f5c6cb;
                color: #721c24;
            }

            .alert-warning {
                background-color: #fff3cd;
                border-color: #ffeaa7;
                color: #856404;
            }

            /* Ensure Symfony Debug Toolbar is always visible on top */
            .sf-toolbar {
                z-index: 999999 !important;
            }
        </style>
    </head>
    <body>
        <nav class="navbar navbar-expand-lg sticky-top">
            <div class="container-desktop d-flex justify-content-between align-items-center w-100">
                <a class="navbar-brand" href="{{ path('home') }}">
                    <img src="{{ asset('images/logo.png') }}" alt="PinkShield" class="logo-img">
                    <span>PinkShield</span>
                </a>
                
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center">
                        {% if app.user %}
                            {% if is_granted('ROLE_ADMIN') %}
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}" href="{{ path('admin_dashboard') }}">
                                        <i class="fas fa-chart-line me-1"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-users-cog me-1"></i> Management
                                    </a>
                                    <ul class="dropdown-menu shadow-sm border-0">
                                        <li><a class="dropdown-item" href="{{ path('user_index') }}">Users</a></li>
                                        <li><a class="dropdown-item" href="{{ path('doctor_index') }}">Doctors</a></li>
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="{{ path('blog_index') }}">Blog & Forum</a></li>
                                        <li><a class="dropdown-item" href="{{ path('appointment_index') }}">Appointments</a></li>
                                    </ul>
                                </li>
                            {% elseif is_granted('ROLE_DOCTOR') %}
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') == 'doctor_dashboard' %}active{% endif %}" href="{{ path('doctor_dashboard') }}">
                                        <i class="fas fa-user-md me-1"></i> Dashboard
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'appointment_' %}active{% endif %}" href="{{ path('appointment_index') }}">
                                        <i class="fas fa-calendar-check me-1"></i> Appointments
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'blog_' %}active{% endif %}" href="{{ path('blog_index') }}">
                                        <i class="fas fa-comments me-1"></i> Forum
                                    </a>
                                </li>
                            {% elseif is_granted('ROLE_USER') %}
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') == 'user_dashboard' %}active{% endif %}" href="{{ path('user_dashboard') }}">
                                        <i class="fas fa-home me-1"></i> Home
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'appointment_' %}active{% endif %}" href="{{ path('appointment_index') }}">
                                        <i class="fas fa-calendar-alt me-1"></i> Appointments
                                    </a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link {% if app.request.attributes.get('_route') starts with 'blog_' %}active{% endif %}" href="{{ path('blog_index') }}">
                                        <i class="fas fa-newspaper me-1"></i> Blog & Forum
                                    </a>
                                </li>
                            {% endif %}

                            <li class="nav-item ms-lg-3">
                                <div class="dropdown">
                                    <button class="btn btn-outline-danger dropdown-toggle d-flex align-items-center gap-2 py-2" type="button" data-bs-toggle="dropdown">
                                        <i class="fas fa-user-circle fa-lg"></i>
                                        <span class="d-none d-xl-inline">{{ app.user.userIdentifier }}</span>
                                    </button>
                                    <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0 mt-2">
                                        {% if is_granted('ROLE_ADMIN') %}
                                            <li><a class="dropdown-item" href="{{ path('admin_edit', {id: app.user.id}) }}"><i class="fas fa-user-edit me-2"></i> Edit Profile</a></li>
                                        {% elseif is_granted('ROLE_DOCTOR') %}
                                            <li><a class="dropdown-item" href="{{ path('doctor_edit', {id: app.user.id}) }}"><i class="fas fa-user-edit me-2"></i> Edit Profile</a></li>
                                        {% elseif is_granted('ROLE_USER') %}
                                            <li><a class="dropdown-item" href="{{ path('user_edit', {id: app.user.id}) }}"><i class="fas fa-user-edit me-2"></i> Edit Profile</a></li>
                                        {% endif %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item text-danger" href="{{ path('logout') }}"><i class="fas fa-sign-out-alt me-2"></i> Logout</a></li>
                                    </ul>
                                </div>
                            </li>
                        {% else %}
                            <li class="nav-item ms-lg-3">
                                <a href="{{ path('login') }}" class="btn btn-primary px-4 py-2 fw-bold shadow-sm">
                                    <i class="fas fa-sign-in-alt me-1"></i> Login
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <div class="main-content">
            <div class="container-desktop">
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : 'warning') }} alert-dismissible fade show shadow-sm border-0 mb-4" role="alert">
                            {{ message }}
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            // Close navbar collapse when a link is clicked
            document.querySelectorAll('.navbar-collapse a:not(.dropdown-toggle)').forEach(link => {
                link.addEventListener('click', function() {
                    const navbarCollapse = document.querySelector('.navbar-collapse');
                    if (navbarCollapse && navbarCollapse.classList.contains('show')) {
                        const bsCollapse = new bootstrap.Collapse(navbarCollapse, {toggle: false});
                        bsCollapse.hide();
                    }
                });
            });

            // Smooth page transitions with loading bar
            document.querySelectorAll('a[href^="/"]').forEach(link => {
                link.addEventListener('click', function(e) {
                    // Only prevent default for same-origin navigation
                    const href = this.getAttribute('href');
                    if (href && !href.startsWith('javascript:') && !this.getAttribute('target')) {
                        const loadingBar = document.createElement('div');
                        loadingBar.style.cssText = `
                            position: fixed;
                            top: 0;
                            left: 0;
                            height: 3px;
                            background: linear-gradient(to right, #C41E3A, #8B1428);
                            width: 100%;
                            z-index: 9998;
                            animation: slideIn 0.3s ease;
                        `;
                        document.body.appendChild(loadingBar);
                        
                        setTimeout(() => {
                            loadingBar.remove();
                        }, 500);
                    }
                });
            });

            // Add CSS animation for loading bar
            const style = document.createElement('style');
            style.textContent = `
                @keyframes slideIn {
                    from { width: 0; }
                    to { width: 100%; }
                }
            `;
            document.head.appendChild(style);
        </script>
    </body>
</html>

