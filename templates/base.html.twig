<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <meta name="csrf-token" content="{{ csrf_token('') }}">
        <title>{% block title %}PinkShield — Medical Management System{% endblock %}</title>
        <link rel="icon" href="{{ asset('images/colored-logo.png') }}">

        {# Fonts #}
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

        {# Bootstrap & Icons #}
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

        {% block stylesheets %}{% endblock %}

        <style>
            /* ─── Design Tokens ─────────────────────────────────────────── */
            :root {
                --primary:        #4CAF87;
                --primary-dark:   #3a8f6f;
                --primary-light:  rgba(76, 175, 135, 0.12);
                --secondary:      #B8E6DB;
                --light-bg:       #f4fdf8;
                --border:         #d1ede5;
                --text-dark:      #1a2332;
                --text-gray:      #6b7280;
                --text-muted:     #9ca3af;
                --navbar-height:  64px;
                --sidebar-width:  260px;
                --card-radius:    12px;
                --shadow-sm:      0 1px 3px rgba(0,0,0,0.06);
                --shadow-md:      0 4px 16px rgba(0,0,0,0.08);
                --shadow-lg:      0 8px 32px rgba(0,0,0,0.10);
                --transition:     all 0.22s ease;
            }

            /* ─── Reset & Base ──────────────────────────────────────────── */
            *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

            html, body { height: 100%; }

            body {
                background-color: var(--light-bg);
                font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
                color: var(--text-dark);
                line-height: 1.6;
                display: flex;
                flex-direction: column;
                font-size: 0.95rem;
            }

            /* ─── Accessibility ─────────────────────────────────────────── */
            .skip-link {
                position: absolute;
                top: -100%;
                left: 1rem;
                background: var(--primary);
                color: #fff;
                padding: 0.5rem 1rem;
                border-radius: 0 0 8px 8px;
                font-weight: 600;
                z-index: 9999;
                text-decoration: none;
                transition: top 0.2s;
            }
            .skip-link:focus { top: 0; }

            /* ─── Navbar ────────────────────────────────────────────────── */
            .navbar {
                background: rgba(184, 230, 219, 0.92);
                backdrop-filter: blur(12px);
                -webkit-backdrop-filter: blur(12px);
                box-shadow: var(--shadow-sm);
                border-bottom: 2px solid var(--primary);
                height: var(--navbar-height);
                padding: 0;
                position: sticky;
                top: 0;
                z-index: 1030;
            }

            .navbar-brand {
                display: flex;
                align-items: center;
                gap: 10px;
                font-weight: 800;
                color: var(--primary-dark) !important;
                font-size: 1.2rem;
                letter-spacing: -0.4px;
                text-decoration: none;
            }

            .navbar-brand img { height: 30px; width: auto; }

            .nav-link {
                color: var(--text-gray) !important;
                font-weight: 500;
                font-size: 0.9rem;
                padding: 0.45rem 0.9rem !important;
                border-radius: 8px;
                transition: var(--transition);
                display: flex;
                align-items: center;
                gap: 6px;
            }

            .nav-link:hover  { color: var(--primary) !important; background: var(--primary-light); }
            .nav-link.active { color: var(--primary) !important; background: var(--primary-light); font-weight: 600; }

            .navbar-toggler       { border: none; }
            .navbar-toggler:focus { box-shadow: none; }

            /* ─── Dropdown ──────────────────────────────────────────────── */
            .dropdown-menu {
                border: 1px solid var(--border);
                box-shadow: var(--shadow-lg);
                border-radius: var(--card-radius);
                margin-top: 6px;
                padding: 6px;
            }

            .dropdown-item {
                color: var(--text-dark);
                font-weight: 500;
                padding: 0.65rem 0.9rem;
                border-radius: 8px;
                transition: var(--transition);
                display: flex;
                align-items: center;
                gap: 8px;
                font-size: 0.9rem;
            }

            .dropdown-item:hover { background: var(--primary-light); color: var(--primary); }

            /* ─── Buttons ───────────────────────────────────────────────── */
            .btn-primary {
                background: var(--primary);
                border-color: var(--primary);
                font-weight: 600;
                padding: 0.5rem 1.2rem;
                border-radius: 8px;
                transition: var(--transition);
            }

            .btn-primary:hover {
                background: var(--primary-dark);
                border-color: var(--primary-dark);
                transform: translateY(-1px);
                box-shadow: 0 4px 14px rgba(76, 175, 135, 0.3);
            }

            .btn-outline-primary {
                color: var(--primary);
                border-color: var(--primary);
                font-weight: 600;
                border-radius: 8px;
                transition: var(--transition);
            }

            .btn-outline-primary:hover {
                background: var(--primary);
                border-color: var(--primary);
                transform: translateY(-1px);
            }

            /* ─── Role Badge ────────────────────────────────────────────── */
            .role-badge {
                display: inline-block;
                padding: 0.2rem 0.6rem;
                border-radius: 6px;
                font-size: 0.7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.5px;
                margin-left: 6px;
            }

            .role-admin  { background: rgba(76, 175, 135, 0.15); color: var(--primary); }
            .role-doctor { background: rgba(34, 197, 94, 0.15);  color: #16a34a; }
            .role-user   { background: rgba(59, 130, 246, 0.15); color: #3b82f6; }

            /* ─── Notification Bell ─────────────────────────────────────── */
            .notification-badge {
                position: relative;
                display: flex;
                align-items: center;
                cursor: pointer;
                font-size: 1.2rem;
                color: var(--text-gray);
                transition: var(--transition);
                padding: 8px 10px;
                border-radius: 8px;
            }

            .notification-badge:hover { color: var(--primary); background: var(--primary-light); }

            .notification-badge .badge {
                position: absolute;
                top: 2px;
                right: 2px;
                background: var(--primary);
                color: #fff;
                font-size: 0.6rem;
                padding: 0.2rem 0.4rem;
                border-radius: 10px;
                font-weight: 700;
                min-width: 18px;
                text-align: center;
                display: none; /* hidden until JS loads a real count */
                animation: pulse 2s infinite;
            }

            @keyframes pulse {
                0%, 100% { opacity: 1; }
                50%       { opacity: 0.6; }
            }

            .notification-dropdown { min-width: 370px !important; }

            .notification-dropdown .dropdown-header {
                background: var(--primary-light);
                color: var(--primary-dark);
                font-weight: 700;
                padding: 0.9rem 1rem;
                border-radius: 8px 8px 0 0;
                font-size: 0.9rem;
            }

            .notification-dropdown .dropdown-item {
                padding: 0.85rem 1rem;
                border-bottom: 1px solid var(--border);
                white-space: normal;
                border-radius: 0;
            }

            .notification-dropdown .dropdown-item:last-child {
                border-bottom: none;
                border-radius: 0 0 8px 8px;
            }

            .notification-item { display: flex; align-items: flex-start; gap: 10px; }

            .notification-icon {
                font-size: 1rem;
                color: var(--primary);
                flex-shrink: 0;
                margin-top: 3px;
            }

            .notification-content { flex: 1; }
            .notification-content small { display: block; line-height: 1.4; }

            /* ─── Sidebar Toggle Button ─────────────────────────────────── */
            .sidebar-toggle-btn {
                position: fixed;
                top: calc(var(--navbar-height) + 10px);
                left: 10px;
                z-index: 2000;
                background: var(--primary);
                color: #fff;
                border: none;
                border-radius: 50%;
                width: 38px;
                height: 38px;
                box-shadow: 0 2px 10px rgba(76, 175, 135, 0.3);
                display: flex;
                align-items: center;
                justify-content: center;
                transition: var(--transition);
                cursor: pointer;
            }

            .sidebar-toggle-btn:hover {
                background: var(--primary-dark);
                transform: scale(1.08);
            }

            /* ─── Sidebar ───────────────────────────────────────────────── */
            .sidebar {
                background: #fff;
                border-right: 1px solid var(--border);
                position: fixed;
                left: 0;
                top: var(--navbar-height);
                width: var(--sidebar-width);
                height: calc(100vh - var(--navbar-height));
                overflow-y: auto;
                overflow-x: hidden;
                padding: 0;
                z-index: 1020;
                transform: translateX(0);
                transition: transform 0.35s cubic-bezier(0.77, 0, 0.175, 1);
                box-shadow: 2px 0 16px rgba(76, 175, 135, 0.06);
            }

            .sidebar-logo {
                padding: 20px;
                border-bottom: 1px solid var(--border);
                background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
            }

            .sidebar-logo a {
                display: flex;
                align-items: center;
                gap: 10px;
                text-decoration: none;
            }

            .sidebar-logo img { height: 32px; width: auto; }

            .sidebar-logo span {
                font-size: 1rem;
                font-weight: 800;
                color: #fff;
                letter-spacing: -0.3px;
            }

            .sidebar-section { padding: 16px 0 8px; }

            .sidebar-section-title {
                padding: 0 18px;
                margin-bottom: 8px;
                font-size: 0.7rem;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: 0.8px;
                color: var(--text-muted);
            }

            .sidebar-nav { display: flex; flex-direction: column; gap: 2px; padding: 0 8px; }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 12px;
                color: var(--text-gray);
                text-decoration: none;
                font-weight: 500;
                font-size: 0.9rem;
                transition: var(--transition);
                border-radius: 8px;
                border-left: 3px solid transparent;
            }

            .sidebar-link:hover {
                color: var(--primary);
                background: var(--primary-light);
                border-left-color: var(--primary);
            }

            .sidebar-link.active {
                color: var(--primary);
                background: var(--primary-light);
                border-left-color: var(--primary);
                font-weight: 600;
            }

            .sidebar-link i { width: 18px; text-align: center; font-size: 0.95rem; }

            /* ─── Main Content ──────────────────────────────────────────── */
            main {
                flex: 1;
                margin-left: var(--sidebar-width);
                margin-top: var(--navbar-height);
                overflow-y: auto;
            }

            .container-desktop {
                max-width: 1200px;
                margin: 0 auto;
                padding: 36px 28px;
                width: 100%;
            }

            /* ─── Alerts ────────────────────────────────────────────────── */
            .alert {
                border: none;
                border-radius: var(--card-radius);
                font-weight: 500;
                display: flex;
                align-items: center;
                gap: 12px;
                border-left: 4px solid;
                padding: 0.85rem 1rem;
            }

            .alert-success { background: #dcfce7; color: #166534; border-left-color: #22c55e; }
            .alert-danger  { background: #fee2e2; color: #b91c1c; border-left-color: #ef4444; }
            .alert-warning { background: #fef3c7; color: #b45309; border-left-color: #f59e0b; }
            .alert-info    { background: #dbeafe; color: #1e40af; border-left-color: #3b82f6; }

            /* ─── Form Validation ───────────────────────────────────────── */
            .form-control.is-invalid {
                border-color: #dc3545;
                box-shadow: 0 0 0 0.2rem rgba(220, 53, 69, 0.15);
            }

            .form-control.is-valid {
                border-color: #28a745;
                box-shadow: 0 0 0 0.2rem rgba(40, 167, 69, 0.15);
            }

            .ajax-error {
                color: #dc3545;
                font-size: 0.82em;
                margin-top: 0.25rem;
                display: none;
            }

            .ajax-error.d-block { display: block !important; }

            /* Hide Symfony default form errors — using AJAX validation */
            .form-text.text-danger,
            .invalid-feedback,
            .form-group .alert-danger { display: none !important; }

            /* ─── Footer ────────────────────────────────────────────────── */
            footer {
                background: #fff;
                border-top: 1px solid var(--border);
                padding: 1.2rem 2rem;
                text-align: center;
                font-size: 0.82rem;
                color: var(--text-muted);
                margin-left: var(--sidebar-width);
            }

            footer a { color: var(--primary); text-decoration: none; font-weight: 500; }
            footer a:hover { text-decoration: underline; }

            /* ─── Responsive ────────────────────────────────────────────── */
            @media (max-width: 991px) {
                .sidebar { transform: translateX(-100%); }
                .sidebar.show { transform: translateX(0); }
                main   { margin-left: 0; }
                footer { margin-left: 0; }
            }

            @media (max-width: 768px) {
                .container-desktop { padding: 20px 16px; }
                .navbar-brand span { display: none; }
            }
        </style>
    </head>
    <body>
        {# Accessibility: skip to main content #}
        <a href="#main-content" class="skip-link">Skip to main content</a>

        {# ── Navbar ──────────────────────────────────────────────────────── #}
        <nav class="navbar navbar-expand-lg" aria-label="Main navigation">
            <div class="container-fluid px-4">
                <a class="navbar-brand" href="{{ path('home') }}">
                    <img src="{{ asset('images/colored-logo.png') }}" alt="PinkShield logo">
                    <span>PinkShield</span>
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarNav" aria-controls="navbarNav"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <i class="fas fa-bars"></i>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-center gap-1">
                        {% if app.user %}
                            {# Notification Bell #}
                            <li class="nav-item dropdown">
                                <button class="btn btn-link nav-link notification-badge p-0"
                                        type="button" data-bs-toggle="dropdown"
                                        aria-expanded="false" aria-label="Notifications"
                                        id="notificationBell">
                                    <i class="fas fa-bell"></i>
                                    <span class="badge" id="notificationBadge" aria-live="polite">0</span>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end notification-dropdown" id="notificationDropdown">
                                    <li class="dropdown-header">
                                        <i class="fas fa-bell me-2"></i>Notifications
                                        <span class="badge bg-danger float-end" id="unreadCount"></span>
                                    </li>
                                    <li id="notificationsContainer"></li>
                                    <li><hr class="dropdown-divider m-0"></li>
                                    <li>
                                        <a class="dropdown-item text-center" href="{{ path('notifications_index') }}" style="color: var(--primary);">
                                            <small><i class="fas fa-list me-1"></i>View all notifications</small>
                                        </a>
                                    </li>
                                </ul>
                            </li>

                            {# Profile Dropdown #}
                            <li class="nav-item dropdown">
                                <button class="btn btn-outline-primary dropdown-toggle d-flex align-items-center gap-2"
                                        type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle"></i>
                                    <span class="d-none d-md-inline">{{ app.user.userIdentifier }}</span>
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <span class="role-badge role-admin">Admin</span>
                                    {% elseif is_granted('ROLE_DOCTOR') %}
                                        <span class="role-badge role-doctor">Doctor</span>
                                    {% elseif is_granted('ROLE_USER') %}
                                        <span class="role-badge role-user">Patient</span>
                                    {% endif %}
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <li><a class="dropdown-item" href="{{ path('admin_edit', {id: app.user.id}) }}">
                                            <i class="fas fa-cog"></i> Settings
                                        </a></li>
                                    {% elseif is_granted('ROLE_DOCTOR') %}
                                        <li><a class="dropdown-item" href="{{ path('doctor_edit', {id: app.user.id}) }}">
                                            <i class="fas fa-cog"></i> Settings
                                        </a></li>
                                    {% elseif is_granted('ROLE_USER') %}
                                        <li><a class="dropdown-item" href="{{ path('user_edit', {id: app.user.id}) }}">
                                            <i class="fas fa-cog"></i> Settings
                                        </a></li>
                                    {% endif %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item text-danger" href="{{ path('logout') }}">
                                        <i class="fas fa-sign-out-alt"></i> Logout
                                    </a></li>
                                </ul>
                            </li>

                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('login') }}">
                                    <i class="fas fa-sign-in-alt"></i> <span>Login</span>
                                </a>
                            </li>
                            <li class="nav-item">
                                <a href="{{ path('register') }}" class="btn btn-primary btn-sm">
                                    <i class="fas fa-user-plus me-1"></i> Register
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        {# ── Sidebar (authenticated users only) ──────────────────────────── #}
        {% if app.user %}
        <button class="sidebar-toggle-btn" id="sidebarToggle" aria-label="Toggle sidebar">
            <i class="fas fa-bars"></i>
        </button>

        <aside class="sidebar" id="sidebar" aria-label="Sidebar navigation">
            <div class="sidebar-logo">
                <a href="{{ path('home') }}">
                    <img src="{{ asset('images/colored-logo.png') }}" alt="PinkShield">
                    <span>PinkShield</span>
                </a>
            </div>

            {% if is_granted('ROLE_ADMIN') %}
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Administration</div>
                    <nav class="sidebar-nav" aria-label="Admin navigation">
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}"
                           href="{{ path('admin_dashboard') }}">
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') starts with 'blog_' %}active{% endif %}"
                           href="{{ path('blog_index') }}">
                            <i class="fas fa-newspaper"></i> Blog
                        </a>
                    </nav>
                </div>

            {% elseif is_granted('ROLE_DOCTOR') %}
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Doctor Portal</div>
                    <nav class="sidebar-nav" aria-label="Doctor navigation">
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'doctor_dashboard' %}active{% endif %}"
                           href="{{ path('doctor_dashboard') }}">
                            <i class="fas fa-chart-line"></i> Dashboard
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'parapharmacy_index' %}active{% endif %}"
                           href="{{ path('parapharmacy_index') }}">
                            <i class="fas fa-pills"></i> Parapharmacy
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') starts with 'blog_' %}active{% endif %}"
                           href="{{ path('blog_index') }}">
                            <i class="fas fa-comments"></i> Forum
                        </a>
                    </nav>
                </div>

            {% elseif is_granted('ROLE_USER') %}
                <div class="sidebar-section">
                    <div class="sidebar-section-title">Patient Portal</div>
                    <nav class="sidebar-nav" aria-label="Patient navigation">
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'user_dashboard' %}active{% endif %}"
                           href="{{ path('user_dashboard') }}">
                            <i class="fas fa-home"></i> Home
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'notifications_index' %}active{% endif %}"
                           href="{{ path('notifications_index') }}">
                            <i class="fas fa-bell"></i> Notifications
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'tracking_index' %}active{% endif %}"
                           href="{{ path('tracking_index') }}">
                            <i class="fas fa-heartbeat"></i> Health Tracking
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'parapharmacy_index' %}active{% endif %}"
                           href="{{ path('parapharmacy_index') }}">
                            <i class="fas fa-pills"></i> Pharmacy
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') == 'wishlist_index' %}active{% endif %}"
                           href="{{ path('wishlist_index') }}">
                            <i class="fas fa-heart"></i> My Wishlist
                        </a>
                        <a class="sidebar-link {% if app.request.attributes.get('_route') starts with 'blog_' %}active{% endif %}"
                           href="{{ path('blog_index') }}">
                            <i class="fas fa-book-open"></i> Blog
                        </a>
                    </nav>
                </div>
            {% endif %}
        </aside>
        {% endif %}

        {# ── Main Content ────────────────────────────────────────────────── #}
        <main id="main-content">
            <div class="container-desktop">
                {# Flash Messages #}
                {% for label, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="alert alert-{{ label == 'error' ? 'danger' : (label == 'success' ? 'success' : (label == 'warning' ? 'warning' : 'info')) }} alert-dismissible fade show mb-4" role="alert">
                            <div>
                                {% if label == 'error' or label == 'danger' %}
                                    <i class="fas fa-exclamation-circle"></i>
                                {% elseif label == 'success' %}
                                    <i class="fas fa-check-circle"></i>
                                {% elseif label == 'warning' %}
                                    <i class="fas fa-exclamation-triangle"></i>
                                {% else %}
                                    <i class="fas fa-info-circle"></i>
                                {% endif %}
                            </div>
                            <div>{{ message }}</div>
                            <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    {% endfor %}
                {% endfor %}

                {% block body %}{% endblock %}
            </div>
        </main>

        {# ── Footer ──────────────────────────────────────────────────────── #}
        <footer>
            &copy; {{ "now"|date("Y") }} <strong>PinkShield</strong> — Medical Management System &nbsp;·&nbsp;
            Built with <a href="https://symfony.com" target="_blank" rel="noopener">Symfony 7</a>
        </footer>

        {# ── Scripts ─────────────────────────────────────────────────────── #}
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

        {# Collapse navbar on mobile link click #}
        <script>
            document.querySelectorAll('.navbar-collapse a:not(.dropdown-toggle)').forEach(link => {
                link.addEventListener('click', () => {
                    const collapse = document.querySelector('.navbar-collapse');
                    if (collapse?.classList.contains('show')) {
                        bootstrap.Collapse.getInstance(collapse)?.hide();
                    }
                });
            });
        </script>

        {# Sidebar toggle logic #}
        {% if app.user %}
        <script>
            (function () {
                const sidebar       = document.getElementById('sidebar');
                const toggleBtn     = document.getElementById('sidebarToggle');
                const MOBILE_BP     = 992;
                let isVisible       = window.innerWidth >= MOBILE_BP;

                function applyState() {
                    sidebar.classList.toggle('show', isVisible);
                }

                toggleBtn.addEventListener('click', () => {
                    isVisible = !isVisible;
                    applyState();
                });

                window.addEventListener('resize', () => {
                    isVisible = window.innerWidth >= MOBILE_BP;
                    applyState();
                });

                applyState();
            })();
        </script>
        {% endif %}

        {# Notification loader #}
        {% if app.user %}
        <script>
            function loadNotifications() {
                const badgeEl = document.getElementById('notificationBadge');
                if (!badgeEl) return;

                fetch('{{ path('notifications_api_list') }}')
                    .then(r => { if (!r.ok) throw new Error(); return r.json(); })
                    .then(data => {
                        if (!data?.notifications) return;

                        const unreadEl    = document.getElementById('unreadCount');
                        const containerEl = document.getElementById('notificationsContainer');
                        const count       = data.unreadCount ?? 0;

                        // Only show badge when there are unread notifications
                        if (count > 0) {
                            badgeEl.textContent = count;
                            badgeEl.style.display = 'block';
                        } else {
                            badgeEl.style.display = 'none';
                        }

                        if (unreadEl) {
                            unreadEl.textContent = count > 0 ? `${count} New` : '';
                        }

                        if (containerEl) {
                            if (data.notifications.length === 0) {
                                containerEl.innerHTML = '<li class="dropdown-item text-center text-muted"><small><i class="fas fa-check-circle me-1"></i>No new notifications</small></li>';
                            } else {
                                containerEl.innerHTML = data.notifications.slice(0, 5).map(n => `
                                    <li class="dropdown-item ${n.isRead ? '' : 'fw-semibold'}">
                                        <div class="notification-item">
                                            <div class="notification-icon"><i class="${n.icon}"></i></div>
                                            <div class="notification-content">
                                                <small><strong>${n.title}</strong></small>
                                                <small class="text-muted d-block">${n.createdAt}</small>
                                            </div>
                                        </div>
                                    </li>
                                `).join('');
                            }
                        }
                    })
                    .catch(() => {}); // Silently fail — non-critical
            }

            document.addEventListener('DOMContentLoaded', loadNotifications);
            setInterval(loadNotifications, 30000);
        </script>
        {% endif %}

        {# Form Validation Script #}
        <script src="{{ asset('js/form-validation.js') }}"></script>

        {% block javascripts %}{% endblock %}
    </body>
</html>
