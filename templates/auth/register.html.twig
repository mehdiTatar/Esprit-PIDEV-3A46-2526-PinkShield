{% extends "base.html.twig" %}

{% block title %}Register - PinkShield{% endblock %}

{% block stylesheets %}
<style>
    .register-container {
        margin-top: -80px;
        min-height: 100vh;
        background: linear-gradient(135deg, #C41E3A 0%, #8B1428 100%);
        background-attachment: fixed;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 20px 0;
    }

    .register-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0, 0, 0, 0.2);
        overflow: hidden;
        background: white;
    }

    .register-header {
        background: linear-gradient(135deg, #C41E3A 0%, #8B1428 100%);
        color: white;
        padding: 40px 20px;
        text-align: center;
    }

    .register-header .logo-large {
        font-size: 3rem;
        margin-bottom: 15px;
    }

    .register-header h1 {
        font-size: 2rem;
        font-weight: 700;
        margin: 0;
    }

    .register-header p {
        margin: 10px 0 0 0;
        font-size: 0.95rem;
        opacity: 0.9;
    }

    .register-body {
        padding: 40px 35px;
    }

    .register-body h5 {
        color: #2C3E50;
        margin-bottom: 10px;
        font-weight: 700;
    }

    .register-body p {
        color: #666;
        margin-bottom: 25px;
        font-size: 0.95rem;
    }

    .user-type-options {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
        margin-bottom: 25px;
    }

    .user-type-btn {
        border: 2px solid #e0e0e0;
        border-radius: 12px;
        padding: 20px;
        text-align: center;
        transition: all 0.3s ease;
        background: white;
        cursor: pointer;
        font-weight: 600;
    }

    .user-type-btn:hover {
        border-color: #C41E3A;
        background-color: #fff5f5;
        transform: translateY(-3px);
        box-shadow: 0 5px 20px rgba(196, 30, 58, 0.15);
    }

    .user-type-btn i {
        font-size: 2rem;
        color: #C41E3A;
        display: block;
        margin-bottom: 10px;
    }

    .user-type-btn .btn {
        width: 100%;
        margin-top: 10px;
        font-weight: 600;
    }

    .benefits-section {
        background-color: #F5F5F5;
        padding: 20px;
        border-radius: 10px;
        margin: 25px 0;
    }

    .benefits-section h6 {
        color: #2C3E50;
        font-weight: 700;
        margin-bottom: 15px;
        font-size: 0.95rem;
    }

    .benefit-item {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        color: #555;
        font-size: 0.9rem;
    }

    .benefit-item i {
        color: #C41E3A;
        font-weight: bold;
    }

    .login-link {
        text-align: center;
        padding-top: 20px;
        border-top: 1px solid #f0f0f0;
        color: #666;
    }

    .login-link a {
        color: #C41E3A;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .login-link a:hover {
        color: #8B1428;
    }
</style>
{% endblock %}

{% block body %}
<div class="register-container">
    <div class="col-md-6 col-lg-5">
        <div class="register-card">
            <div class="register-header">
                <div class="logo-large">❤️</div>
                <h1>PinkShield</h1>
                <p>Join Our Healthcare Community</p>
            </div>

            <div class="register-body">
                <h5><i class="fas fa-user-check" style="color: #C41E3A; margin-right: 10px;"></i>Choose Account Type</h5>
                <p>Select the type of account that best suits your role:</p>

                <div class="user-type-options">
                    <form method="post" action="{{ path('register') }}" class="w-100">
                        <input type="hidden" name="user_type" value="patient">
                        <button type="submit" class="user-type-btn w-100">
                            <i class="fas fa-heartbeat"></i>
                            Patient
                            <div class="btn btn-sm btn-primary" style="pointer-events: none; font-size: 0.8rem;">Register</div>
                        </button>
                    </form>

                    <form method="post" action="{{ path('register') }}" class="w-100">
                        <input type="hidden" name="user_type" value="doctor">
                        <button type="submit" class="user-type-btn w-100">
                            <i class="fas fa-stethoscope"></i>
                            Doctor
                            <div class="btn btn-sm btn-primary" style="pointer-events: none; font-size: 0.8rem;">Register</div>
                        </button>
                    </form>
                </div>

                <div class="benefits-section">
                    <h6><i class="fas fa-check-circle" style="margin-right: 8px;"></i>Why Join PinkShield?</h6>
                    <div class="benefit-item">
                        <i class="fas fa-lock"></i>
                        <span>Secure & Encrypted Health Records</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-calendar-check"></i>
                        <span>Easy Appointment Scheduling</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-comments"></i>
                        <span>Professional Community Forum</span>
                    </div>
                    <div class="benefit-item">
                        <i class="fas fa-mobile-alt"></i>
                        <span>Access Anywhere, Anytime</span>
                    </div>
                </div>

                <div class="login-link">
                    Already have an account? 
                    <a href="{{ path('login') }}">
                        <i class="fas fa-sign-in-alt"></i> Sign In Here
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
