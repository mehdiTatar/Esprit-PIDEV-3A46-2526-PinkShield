{% extends 'base.html.twig' %}

{% block title %}Book an Appointment{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h2 class="mb-0">Book an Appointment</h2>
                </div>
                <div class="card-body">

                    {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'appointmentForm'}}) }}
                        {{ form_widget(form._token) }}

                        {% set specialities = [] %}
                        {% for doctor in doctorsForBooking|default([]) %}
                            {% if doctor.speciality not in specialities %}
                                {% set specialities = specialities|merge([doctor.speciality]) %}
                            {% endif %}
                        {% endfor %}

                        <div class="mb-3">
                            <label for="appointment_speciality" class="form-label">Select Speciality</label>
                            <select id="appointment_speciality" class="form-select" required>
                                <option value="">Choose a speciality...</option>
                                {% for speciality in specialities %}
                                    <option value="{{ speciality }}">{{ speciality }}</option>
                                {% endfor %}
                            </select>
                            <small class="form-text text-muted d-block mt-2">
                                <i class="fas fa-stethoscope"></i> Pick a speciality first to see matching doctors.
                            </small>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.doctorEmail, 'Select Doctor', {'label_attr': {'class': 'form-label'}}) }}
                            <select name="{{ form.doctorEmail.vars.full_name }}"
                                    id="{{ form.doctorEmail.vars.id }}"
                                    class="form-select"
                                    data-ajax-validate="doctorEmail"
                                    disabled>
                                <option value="">Choose a speciality first...</option>
                            </select>
                            {{ form_errors(form.doctorEmail) }}
                            <small class="form-text text-muted d-block mt-2">
                                <i class="fas fa-info-circle"></i> Doctors are loaded from the shared database.
                            </small>
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.appointmentDate, null, {'label_attr': {'class': 'form-label'}}) }}
                            <input type="datetime-local"
                                   name="{{ form.appointmentDate.vars.full_name }}"
                                   id="{{ form.appointmentDate.vars.id }}"
                                   class="form-control"
                                   value="{{ form.appointmentDate.vars.value }}"
                                   data-ajax-validate="appointmentDate">
                        </div>

                        <div class="mb-3">
                            {{ form_label(form.notes, null, {'label_attr': {'class': 'form-label'}}) }}
                            {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'data-ajax-validate': 'notes'}}) }}
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Book Appointment</button>
                            <a href="{{ path('appointment_index') }}" class="btn btn-secondary">Cancel</a>
                        </div>
                    {{ form_end(form, {'render_rest': false}) }}

                </div>
            </div>
        </div>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('appointmentForm');
    if (!form) return;

    const doctors = {{ doctorsForBooking|default([])|json_encode|raw }};
    const selectedDoctorEmail = {{ selectedDoctorEmail|default('')|json_encode|raw }};
    const specialitySelect = document.getElementById('appointment_speciality');
    const doctorSelect = document.getElementById('{{ form.doctorEmail.vars.id }}');

    function renderDoctorsForSpeciality(speciality, selectedEmail = '') {
        const matchingDoctors = doctors.filter(doctor => doctor.speciality === speciality);

        doctorSelect.innerHTML = '';

        if (!speciality) {
            doctorSelect.disabled = true;
            doctorSelect.append(new Option('Choose a speciality first...', ''));
            return;
        }

        if (matchingDoctors.length === 0) {
            doctorSelect.disabled = true;
            doctorSelect.append(new Option('No doctors found for this speciality', ''));
            return;
        }

        doctorSelect.disabled = false;
        doctorSelect.append(new Option('Choose a doctor...', ''));

        matchingDoctors.forEach(doctor => {
            const option = new Option(doctor.name, doctor.email);
            option.selected = doctor.email === selectedEmail;
            doctorSelect.append(option);
        });
    }

    specialitySelect.addEventListener('change', function () {
        renderDoctorsForSpeciality(this.value);
    });

    if (selectedDoctorEmail) {
        const selectedDoctor = doctors.find(doctor => doctor.email === selectedDoctorEmail);
        if (selectedDoctor) {
            specialitySelect.value = selectedDoctor.speciality;
            renderDoctorsForSpeciality(selectedDoctor.speciality, selectedDoctorEmail);
        }
    }

    AjaxValidator.attachBlur(form);
    AjaxValidator.attachSubmit(form);
});
</script>
{% endblock %}
