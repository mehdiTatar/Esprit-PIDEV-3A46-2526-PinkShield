{% extends "base.html.twig" %}

{% block title %}Doctors - PinkShield{% endblock %}

{% block body %}
<div class="row">
    <div class="col-12">
        <h1 class="mb-4">Doctors Management</h1>
        <a href="{{ path('doctor_new') }}" class="btn btn-primary mb-3">Add New Doctor</a>
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Email</th>
                <th>Full Name</th>
                <th>Speciality</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for doctor in doctors %}
                <tr>
                    <td>{{ doctor.id }}</td>
                    <td>{{ doctor.email }}</td>
                    <td>{{ doctor.fullName }}</td>
                    <td>{{ doctor.speciality }}</td>
                    <td>
                        <a href="{{ path('doctor_show', {id: doctor.id}) }}" class="btn btn-sm btn-info">View</a>
                        <a href="{{ path('doctor_edit', {id: doctor.id}) }}" class="btn btn-sm btn-warning">Edit</a>
                        <a href="{{ path('doctor_delete', {id: doctor.id}) }}" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure?')">Delete</a>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="5" class="text-center">No doctors found</td>
                </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
