{% extends 'base.html.twig' %}

{% block title %}Edit Health Entry — PinkShield{% endblock %}

{% block stylesheets %}
<style>
/* ── Edit Page Styles ─────────────────────────────────── */
.edit-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
}

.back-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 0.5rem 1rem;
    border-radius: 8px;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-gray);
    background: #fff;
    border: 1.5px solid var(--border);
    text-decoration: none;
    transition: var(--transition);
}
.back-btn:hover {
    color: var(--primary);
    border-color: var(--primary);
    background: var(--primary-light);
}

.edit-card {
    background: #fff;
    border: 1px solid var(--border);
    border-radius: var(--card-radius);
    box-shadow: var(--shadow-md);
    overflow: hidden;
    max-width: 820px;
    margin: 0 auto;
}

.edit-card-header {
    padding: 1.25rem 1.5rem;
    border-bottom: 1px solid var(--border);
    background: linear-gradient(135deg, #f0faf7 0%, #e8f5ee 100%);
    display: flex;
    align-items: center;
    gap: 12px;
}

.edit-card-header .header-icon {
    width: 42px;
    height: 42px;
    background: var(--primary);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 1.1rem;
    flex-shrink: 0;
}

.edit-card-header h1 {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text-dark);
    margin: 0;
}

.edit-card-header p {
    font-size: 0.82rem;
    color: var(--text-muted);
    margin: 2px 0 0;
}

.edit-card-body { padding: 1.75rem; }

/* Reuse same form styles from index */
.form-group-custom { margin-bottom: 1.2rem; }

.form-label-custom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--text-dark);
    margin-bottom: 6px;
}

.form-label-custom .value-badge {
    background: var(--primary-light);
    color: var(--primary);
    font-size: 0.8rem;
    font-weight: 700;
    width: 32px;
    height: 28px;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
}

.slider-emoji { font-size: 1rem; margin-right: 6px; }

input[type="range"] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    border-radius: 3px;
    background: linear-gradient(to right, var(--primary) 0%, var(--primary) 50%, #e5e7eb 50%, #e5e7eb 100%);
    outline: none;
    cursor: pointer;
}

input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: #fff;
    border: 2.5px solid var(--primary);
    box-shadow: 0 1px 6px rgba(76,175,135,0.25);
    cursor: pointer;
    transition: var(--transition);
}

input[type="range"]::-webkit-slider-thumb:hover {
    transform: scale(1.2);
}

.form-control-custom {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 0.62rem 0.9rem;
    font-size: 0.88rem;
    font-family: inherit;
    color: var(--text-dark);
    background: #fdfdfd;
    transition: var(--transition);
    resize: vertical;
    outline: none;
}

.form-control-custom:focus {
    border-color: var(--primary);
    background: #fff;
    box-shadow: 0 0 0 3px rgba(76,175,135,0.12);
}

.checkbox-row {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0.7rem 0.9rem;
    background: var(--light-bg);
    border-radius: 8px;
    border: 1.5px solid var(--border);
    cursor: pointer;
    transition: var(--transition);
}

.checkbox-row:hover { border-color: var(--primary); background: var(--primary-light); }

.checkbox-row input[type="checkbox"] {
    width: 18px;
    height: 18px;
    accent-color: var(--primary);
    cursor: pointer;
}

.checkbox-row label {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--text-dark);
    cursor: pointer;
    margin: 0;
}

.section-divider {
    display: flex;
    align-items: center;
    gap: 12px;
    margin: 0.5rem 0 1rem;
    color: var(--text-muted);
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.8px;
}
.section-divider::before, .section-divider::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
}

.two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
@media (max-width: 600px) { .two-col { grid-template-columns: 1fr; } }

.form-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
    flex-wrap: wrap;
}

.btn-save {
    flex: 1;
    min-width: 160px;
    padding: 0.8rem 1.5rem;
    background: linear-gradient(135deg, var(--primary) 0%, var(--primary-dark) 100%);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: var(--transition);
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    letter-spacing: 0.3px;
}
.btn-save:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 20px rgba(76,175,135,0.35);
}

.btn-cancel {
    padding: 0.78rem 1.4rem;
    background: #fff;
    color: var(--text-gray);
    border: 1.5px solid var(--border);
    border-radius: 10px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 7px;
    transition: var(--transition);
}
.btn-cancel:hover {
    border-color: var(--primary);
    color: var(--primary);
    background: var(--primary-light);
}
</style>
{% endblock %}

{% block body %}
<div class="edit-header">
    <a href="{{ path('tracking_index') }}" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back to Dashboard
    </a>
</div>

<div class="edit-card">
    <div class="edit-card-header">
        <div class="header-icon"><i class="fas fa-pen"></i></div>
        <div>
            <h1>Edit Health Entry</h1>
            <p>{{ tracking.date|date('l, d F Y') }}</p>
        </div>
    </div>

    <div class="edit-card-body">
        <form method="POST" action="{{ path('tracking_edit', {id: tracking.id}) }}">

            <div class="section-divider">Core Metrics</div>

            <div class="two-col">
                {# Mood #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">😊</span> Mood</span>
                        <span class="value-badge" id="mood-val">{{ tracking.mood }}</span>
                    </div>
                    <input type="range" name="mood" id="mood" min="1" max="10"
                           value="{{ tracking.mood }}" oninput="updateSlider('mood', this.value)">
                </div>

                {# Stress #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">⚡</span> Stress</span>
                        <span class="value-badge" id="stress-val">{{ tracking.stress }}</span>
                    </div>
                    <input type="range" name="stress" id="stress" min="1" max="10"
                           value="{{ tracking.stress }}" oninput="updateSlider('stress', this.value)">
                </div>
            </div>

            <div class="section-divider">Wellbeing</div>

            <div class="two-col">
                {# Energy #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🔥</span> Energy</span>
                        <span class="value-badge" id="energy_level-val">{{ tracking.energyLevel ?? 5 }}</span>
                    </div>
                    <input type="range" name="energy_level" id="energy_level" min="1" max="10"
                           value="{{ tracking.energyLevel ?? 5 }}" oninput="updateSlider('energy_level', this.value)">
                </div>

                {# Sleep #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🌙</span> Sleep (hrs)</span>
                        <span class="value-badge" id="sleep_hours-val">{{ tracking.sleepHours ?? 7 }}</span>
                    </div>
                    <input type="range" name="sleep_hours" id="sleep_hours" min="0" max="24"
                           value="{{ tracking.sleepHours ?? 7 }}" oninput="updateSlider('sleep_hours', this.value)">
                </div>
            </div>

            <div class="two-col">
                {# Focus #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🎯</span> Focus</span>
                        <span class="value-badge" id="focus_level-val">{{ tracking.focusLevel ?? 5 }}</span>
                    </div>
                    <input type="range" name="focus_level" id="focus_level" min="1" max="10"
                           value="{{ tracking.focusLevel ?? 5 }}" oninput="updateSlider('focus_level', this.value)">
                </div>

                {# Appetite #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🍽️</span> Appetite</span>
                        <span class="value-badge" id="appetite_level-val">{{ tracking.appetiteLevel ?? 5 }}</span>
                    </div>
                    <input type="range" name="appetite_level" id="appetite_level" min="1" max="10"
                           value="{{ tracking.appetiteLevel ?? 5 }}" oninput="updateSlider('appetite_level', this.value)">
                </div>
            </div>

            <div class="section-divider">Mental Health</div>

            <div class="two-col">
                {# Anxiety #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🧠</span> Anxiety</span>
                        <span class="value-badge" id="anxiety_level-val">{{ tracking.anxietyLevel ?? 3 }}</span>
                    </div>
                    <input type="range" name="anxiety_level" id="anxiety_level" min="1" max="10"
                           value="{{ tracking.anxietyLevel ?? 3 }}" oninput="updateSlider('anxiety_level', this.value)">
                </div>

                {# Motivation #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">⭐</span> Motivation</span>
                        <span class="value-badge" id="motivation_level-val">{{ tracking.motivationLevel ?? 5 }}</span>
                    </div>
                    <input type="range" name="motivation_level" id="motivation_level" min="1" max="10"
                           value="{{ tracking.motivationLevel ?? 5 }}" oninput="updateSlider('motivation_level', this.value)">
                </div>
            </div>

            <div class="two-col">
                {# Social #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🤝</span> Social</span>
                        <span class="value-badge" id="social_interaction_level-val">{{ tracking.socialInteractionLevel ?? 5 }}</span>
                    </div>
                    <input type="range" name="social_interaction_level" id="social_interaction_level" min="1" max="10"
                           value="{{ tracking.socialInteractionLevel ?? 5 }}" oninput="updateSlider('social_interaction_level', this.value)">
                </div>

                {# Physical Activity #}
                <div class="form-group-custom">
                    <div class="form-label-custom">
                        <span><span class="slider-emoji">🏃</span> Activity</span>
                        <span class="value-badge" id="physical_activity_level-val">{{ tracking.physicalActivityLevel ?? 3 }}</span>
                    </div>
                    <input type="range" name="physical_activity_level" id="physical_activity_level" min="1" max="10"
                           value="{{ tracking.physicalActivityLevel ?? 3 }}" oninput="updateSlider('physical_activity_level', this.value)">
                </div>
            </div>

            <div class="section-divider">Lifestyle</div>

            {# Water intake - full width #}
            <div class="form-group-custom">
                <div class="form-label-custom">
                    <span><span class="slider-emoji">💧</span> Water Intake (cl)</span>
                    <span class="value-badge" id="water_intake-val">{{ tracking.waterIntake ?? 150 }}</span>
                </div>
                <input type="range" name="water_intake" id="water_intake" min="0" max="500" step="10"
                       value="{{ tracking.waterIntake ?? 150 }}" oninput="updateSlider('water_intake', this.value)">
            </div>

            {# Medication #}
            <div class="form-group-custom">
                <div class="checkbox-row" onclick="this.querySelector('input').click();">
                    <input type="checkbox" name="medication_taken" id="medication_taken" value="1"
                           {{ tracking.medicationTaken ? 'checked' : '' }} onclick="event.stopPropagation();">
                    <label for="medication_taken"><i class="fas fa-pills me-2" style="color:var(--primary);"></i>Medication taken on this day</label>
                </div>
            </div>

            <div class="section-divider">Notes</div>

            <div class="two-col">
                <div class="form-group-custom">
                    <label class="form-label-custom" style="margin-bottom:6px;" for="activities">
                        <span><i class="fas fa-running me-1" style="color:var(--primary);"></i> Activities</span>
                    </label>
                    <textarea name="activities" id="activities" class="form-control-custom" rows="3"
                              placeholder="e.g. walked, yoga, reading...">{{ tracking.activities }}</textarea>
                </div>
                <div class="form-group-custom">
                    <label class="form-label-custom" style="margin-bottom:6px;" for="symptoms">
                        <span><i class="fas fa-notes-medical me-1" style="color:#ef4444;"></i> Symptoms / Notes</span>
                    </label>
                    <textarea name="symptoms" id="symptoms" class="form-control-custom" rows="3"
                              placeholder="e.g. headache, fatigue...">{{ tracking.symptoms }}</textarea>
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('tracking_index') }}" class="btn-cancel">
                    <i class="fas fa-times"></i> Cancel
                </a>
                <button type="submit" class="btn-save">
                    <i class="fas fa-save"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
function updateSlider(name, value) {
    const badge = document.getElementById(name + '-val');
    if (badge) badge.textContent = value;

    const input = document.getElementById(name);
    if (input) {
        const min = parseFloat(input.min) || 0;
        const max = parseFloat(input.max) || 10;
        const pct = ((parseFloat(value) - min) / (max - min)) * 100;
        input.style.background =
            `linear-gradient(to right, var(--primary) 0%, var(--primary) ${pct}%, #e5e7eb ${pct}%, #e5e7eb 100%)`;
    }
}

/* Init all sliders on load */
document.querySelectorAll('input[type="range"]').forEach(input => {
    updateSlider(input.name, input.value);
});
</script>
{% endblock %}
