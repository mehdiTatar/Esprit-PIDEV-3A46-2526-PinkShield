{% extends 'base.html.twig' %}

{% block title %}Verify Your Identity - PinkShield{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="card shadow-lg border-0 rounded-lg overflow-hidden" style="max-width: 450px; width: 100%;">
        <div class="card-header bg-primary text-white text-center py-4" style="background: linear-gradient(135deg, #c0396b 0%, #e8557a 100%) !important;">
            <h3 class="font-weight-light my-1"><i class="fas fa-user-shield me-2"></i>Security Check</h3>
        </div>
        <div class="card-body p-5">
            <div class="text-center mb-4">
                <div class="display-1 text-primary mb-3">
                    <i class="fas fa-envelope-open-text" style="color: #c0396b;"></i>
                </div>
                <h4 class="h5">Check your email</h4>
                <p class="text-muted smaill">We've sent a 6-digit verification code to your email address. Please enter it below to continue.</p>
            </div>

            {% if authenticationError %}
                <div class="alert alert-danger border-0 shadow-sm mb-4" role="alert">
                    <i class="fas fa-exclamation-circle me-2"></i>{{ authenticationError|trans(authenticationErrorData, 'SchebTwoFactorBundle') }}
                </div>
            {% endif %}

            <form action="{{ checkPathRoute ? path(checkPathRoute) : checkPathUrl }}" method="post" class="needs-validation">
                {% if isCsrfProtectionEnabled is defined and isCsrfProtectionEnabled %}
                    <input type="hidden" name="{{ csrfParameterName }}" value="{{ csrf_token(csrfTokenId) }}">
                {% endif %}
                <div class="form-floating mb-4">
                    <input type="text" 
                           id="_auth_code" 
                           name="_auth_code" 
                           autocomplete="one-time-code" 
                           autofocus 
                           inputmode="numeric" 
                           pattern="[0-9]*"
                           class="form-control text-center fs-2 fw-bold tracking-widest" 
                           placeholder="000000" 
                           required
                           style="letter-spacing: 0.5rem; height: 80px;">
                    <label for="_auth_code">Verification Code</label>
                </div>

                <div class="d-grid gap-2">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm py-3" style="background: #c0396b; border: none;">
                        Verify & Login
                    </button>
                    <a href="{{ path('2fa_skip') }}" class="btn btn-outline-warning btn-lg py-2">
                        <i class="fas fa-forward me-2"></i>Skip 2FA (Dev Mode)
                    </a>
                    <a href="{{ path('logout') }}" class="btn btn-link text-muted mt-2">Cancel and Logout</a>
                </div>
            </form>
        </div>
        <div class="card-footer text-center py-3 bg-light border-0">
            <div class="small text-muted">Didn't receive the code? <a href="#" onclick="location.reload(); return false;" style="color: #c0396b;">Resend Code</a></div>
        </div>
    </div>
</div>

<style>
    body {
        background-color: #f8f9fa;
    }
    .tracking-widest {
        letter-spacing: 0.5rem !important;
    }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: #c0396b;
        transform: scale(.85) translateY(-.5rem) translateX(.15rem);
    }
    .form-control:focus {
        border-color: #e8557a;
        box-shadow: 0 0 0 0.25rem rgba(192, 57, 107, 0.25);
    }
</style>
{% endblock %}
