{% extends 'base.html.twig' %}

{% block title %}Health Blog & Community - PinkShield{% endblock %}

{% block stylesheets %}
<style>
    .blog-hero {
        background: linear-gradient(135deg, #C41E3A 0%, #8B1428 100%);
        color: white;
        padding: 60px 0;
        margin-bottom: 40px;
        border-radius: 0 0 30px 30px;
        box-shadow: 0 10px 30px rgba(196, 30, 58, 0.2);
    }

    .blog-hero h1 {
        font-size: 3rem;
        font-weight: 700;
        margin-bottom: 15px;
    }

    .blog-hero p {
        font-size: 1.2rem;
        opacity: 0.95;
    }

    .search-bar-container {
        background: white;
        padding: 25px;
        border-radius: 15px;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.1);
        margin-bottom: 40px;
    }

    .search-input {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 12px 20px;
        font-size: 1rem;
        transition: all 0.3s ease;
    }

    .search-input:focus {
        border-color: #C41E3A;
        box-shadow: 0 0 0 0.2rem rgba(196, 30, 58, 0.15);
    }

    .sort-select {
        border: 2px solid #e0e0e0;
        border-radius: 10px;
        padding: 10px 15px;
        transition: all 0.3s ease;
    }

    .sort-select:focus {
        border-color: #C41E3A;
        box-shadow: 0 0 0 0.2rem rgba(196, 30, 58, 0.15);
    }

    .blog-card {
        border: none;
        border-radius: 20px;
        overflow: hidden;
        transition: all 0.4s ease;
        box-shadow: 0 5px 20px rgba(0, 0, 0, 0.08);
        height: 100%;
        background: white;
    }

    .blog-card:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(196, 30, 58, 0.2);
    }

    .blog-card-image {
        height: 250px;
        object-fit: cover;
        width: 100%;
        transition: transform 0.4s ease;
    }

    .blog-card:hover .blog-card-image {
        transform: scale(1.05);
    }

    .blog-card-placeholder {
        height: 250px;
        background: linear-gradient(135deg, #f5f5f5 0%, #e0e0e0 100%);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .blog-card-body {
        padding: 25px;
    }

    .blog-card-title {
        font-size: 1.4rem;
        font-weight: 700;
        color: #2C3E50;
        margin-bottom: 12px;
        line-height: 1.3;
    }

    .blog-card-meta {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-bottom: 15px;
        font-size: 0.9rem;
        color: #7f8c8d;
    }

    .blog-card-meta i {
        color: #C41E3A;
    }

    .blog-card-excerpt {
        color: #555;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .blog-card-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding-top: 15px;
        border-top: 1px solid #f0f0f0;
    }

    .read-more-btn {
        background: linear-gradient(135deg, #C41E3A 0%, #8B1428 100%);
        color: white;
        padding: 10px 25px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .read-more-btn:hover {
        transform: translateX(5px);
        box-shadow: 0 5px 15px rgba(196, 30, 58, 0.3);
        color: white;
    }

    .comment-badge {
        background: #f8f9fa;
        color: #C41E3A;
        padding: 8px 15px;
        border-radius: 20px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 5px;
    }

    .author-badge {
        background: linear-gradient(135deg, #C41E3A 0%, #8B1428 100%);
        color: white;
        padding: 4px 12px;
        border-radius: 15px;
        font-size: 0.75rem;
        font-weight: 600;
        text-transform: uppercase;
    }

    .admin-actions {
        display: flex;
        gap: 8px;
        margin-top: 10px;
    }

    .admin-btn {
        padding: 6px 12px;
        border-radius: 8px;
        font-size: 0.85rem;
        transition: all 0.3s ease;
    }

    .new-post-btn {
        background: white;
        color: #C41E3A;
        padding: 12px 30px;
        border-radius: 25px;
        text-decoration: none;
        font-weight: 600;
        transition: all 0.3s ease;
        display: inline-flex;
        align-items: center;
        gap: 10px;
        box-shadow: 0 5px 15px rgba(255, 255, 255, 0.3);
    }

    .new-post-btn:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 20px rgba(255, 255, 255, 0.4);
        color: white;
        background: rgba(255, 255, 255, 0.2);
    }

    @media (max-width: 768px) {
        .blog-hero h1 {
            font-size: 2rem;
        }
        
        .blog-card-image,
        .blog-card-placeholder {
            height: 200px;
        }
    }

    /* Pagination Styling */
    .pagination {
        gap: 5px;
    }

    .pagination .page-link {
        border: 2px solid #e0e0e0;
        border-radius: 8px;
        color: #C41E3A;
        font-weight: 600;
        padding: 10px 16px;
        transition: all 0.3s ease;
        margin: 0 3px;
    }

    .pagination .page-link:hover {
        background-color: #C41E3A;
        border-color: #C41E3A;
        color: white;
        transform: translateY(-2px);
        box-shadow: 0 4px 12px rgba(196, 30, 58, 0.2);
    }

    .pagination .page-item.active .page-link {
        background-color: #C41E3A;
        border-color: #C41E3A;
        color: white;
        box-shadow: 0 4px 12px rgba(196, 30, 58, 0.3);
    }

    .pagination .page-item.disabled .page-link {
        background-color: #f5f5f5;
        border-color: #e0e0e0;
        color: #999;
    }
</style>
{% endblock %}

{% block body %}
<!-- Hero Section -->
<div class="blog-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-8">
                <h1><i class="fas fa-heartbeat"></i> Health Blog & Community</h1>
                <p>Discover health tips, medical insights, and join our community discussions</p>
            </div>
            <div class="col-lg-4 text-lg-end">
                {% if is_granted('ROLE_ADMIN') %}
                    <a href="{{ path('blog_new') }}" class="new-post-btn">
                        <i class="fas fa-plus-circle"></i> Create New Post
                    </a>
                {% endif %}
            </div>
        </div>
    </div>
</div>

<div class="container">
    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    <!-- Search and Filter Section -->
    <div class="search-bar-container">
        <div class="row g-3 align-items-center">
            <div class="col-lg-8">
                <form method="get" action="{{ path('blog_index') }}" class="d-flex gap-2">
                    <input type="text" name="q" value="{{ q|default('') }}" class="form-control search-input" placeholder="🔍 Search articles by title, content, or author...">
                    <input type="hidden" name="sortBy" value="{{ sortBy|default('') }}">
                    <button type="submit" class="btn btn-danger px-4" style="border-radius: 10px;">
                        <i class="fas fa-search"></i> Search
                    </button>
                </form>
            </div>
            <div class="col-lg-4">
                <form method="get" action="{{ path('blog_index') }}" class="d-flex align-items-center gap-2">
                    {% if q %}
                        <input type="hidden" name="q" value="{{ q }}">
                    {% endif %}
                    <label for="sortBy" class="mb-0 text-muted" style="white-space: nowrap;">
                        <i class="fas fa-sort"></i> Sort:
                    </label>
                    <select name="sortBy" id="sortBy" class="form-select sort-select" onchange="this.form.submit()">
                        <option value="latest" {{ (sortBy|default('latest')) == 'latest' ? 'selected' : '' }}>Latest First</option>
                        <option value="oldest" {{ sortBy == 'oldest' ? 'selected' : '' }}>Oldest First</option>
                        <option value="title_asc" {{ sortBy == 'title_asc' ? 'selected' : '' }}>Title A-Z</option>
                        <option value="title_desc" {{ sortBy == 'title_desc' ? 'selected' : '' }}>Title Z-A</option>
                        <option value="author" {{ sortBy == 'author' ? 'selected' : '' }}>By Author</option>
                        <option value="comments_desc" {{ sortBy == 'comments_desc' ? 'selected' : '' }}>Most Discussed</option>
                        <option value="comments_asc" {{ sortBy == 'comments_asc' ? 'selected' : '' }}>Least Discussed</option>
                    </select>
                </form>
            </div>
        </div>
    </div>

    <!-- Blog Posts Grid -->
    <div class="row g-4 mb-5">
        {% for post in pagination %}
            <div class="col-lg-6 col-xl-4">
                <div class="blog-card">
                    <div style="overflow: hidden;">
                        {% if post.imagePath %}
                            <img src="{{ post.imagePath }}" alt="{{ post.title }}" class="blog-card-image">
                        {% else %}
                            <div class="blog-card-placeholder">
                                <i class="fas fa-notes-medical text-secondary" style="font-size: 4rem; opacity: 0.3;"></i>
                            </div>
                        {% endif %}
                    </div>
                    
                    <div class="blog-card-body">
                        <h5 class="blog-card-title">{{ post.title }}</h5>
                        
                        <div class="blog-card-meta">
                            <span><i class="fas fa-user"></i> {{ post.authorName }}</span>
                            <span class="author-badge">{{ post.authorRole }}</span>
                        </div>
                        
                        <div class="blog-card-meta">
                            <span><i class="fas fa-calendar-alt"></i> {{ post.createdAt|date('M d, Y') }}</span>
                        </div>
                        
                        <p class="blog-card-excerpt">
                            {{ post.content|length > 120 ? post.content|slice(0, 120) ~ '...' : post.content }}
                        </p>
                        
                        <div class="blog-card-footer">
                            <a href="{{ path('blog_show', {'id': post.id}) }}" class="read-more-btn">
                                Read More <i class="fas fa-arrow-right"></i>
                            </a>
                            <span class="comment-badge">
                                <i class="fas fa-comments"></i> {{ post.comments|length }}
                            </span>
                        </div>
                        
                        {% if is_granted('ROLE_ADMIN') %}
                            <div class="admin-actions">
                                <a href="{{ path('blog_edit', {'id': post.id}) }}" class="btn btn-warning btn-sm admin-btn">
                                    <i class="fas fa-edit"></i> Edit
                                </a>
                                <a href="{{ path('blog_delete', {'id': post.id}) }}" class="btn btn-danger btn-sm admin-btn" onclick="return confirm('Delete this post?')">
                                    <i class="fas fa-trash"></i> Delete
                                </a>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12">
                <div class="text-center py-5">
                    <i class="fas fa-inbox" style="font-size: 5rem; color: #e0e0e0; margin-bottom: 20px;"></i>
                    <h3 class="text-muted">No Posts Found</h3>
                    <p class="text-muted">
                        {% if q %}
                            No results for "{{ q }}". Try a different search term.
                        {% else %}
                            Be the first to share something with the community!
                        {% endif %}
                    </p>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('blog_new') }}" class="btn btn-danger mt-3">
                            <i class="fas fa-plus"></i> Create First Post
                        </a>
                    {% endif %}
                </div>
            </div>
        {% endfor %}
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-center mb-5">
        {{ knp_pagination_render(pagination) }}
    </div>
</div>
{% endblock %}
