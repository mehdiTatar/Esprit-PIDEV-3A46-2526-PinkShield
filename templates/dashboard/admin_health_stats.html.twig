{% extends 'base.html.twig' %}

{% block title %}Health Statistics — Admin{% endblock %}

{% block stylesheets %}
<style>
    .hs-hero {
        background: linear-gradient(135deg, #1e1b34 0%, #2d1b3d 100%);
        border-radius: 16px;
        padding: 32px 40px;
        color: #fff;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        flex-wrap: wrap;
        margin-bottom: 28px;
        box-shadow: 0 8px 30px rgba(30,27,52,0.28);
    }

    .hs-hero h2 { font-size: 1.75rem; font-weight: 800; margin: 0 0 4px; }
    .hs-hero p  { margin: 0; color: rgba(255,255,255,0.65); font-size: 0.9rem; }

    .stats-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 20px;
        margin-bottom: 28px;
    }

    .hs-kpi {
        background: #fff;
        border-radius: 14px;
        padding: 28px 24px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid var(--border);
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        border-top: 4px solid var(--primary);
        transition: all 0.22s ease;
    }

    .hs-kpi:hover { transform: translateY(-4px); box-shadow: 0 10px 28px rgba(192,57,107,0.14); }

    .hs-kpi-icon {
        width: 56px; height: 56px;
        border-radius: 50%;
        background: var(--primary-light);
        color: var(--primary);
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        margin-bottom: 16px;
    }

    .hs-kpi-val {
        font-size: 2.2rem;
        font-weight: 900;
        color: var(--text-dark);
        line-height: 1;
        margin-bottom: 6px;
    }

    .hs-kpi-val small {
        font-size: 0.9rem;
        font-weight: 600;
        color: var(--text-muted);
    }

    .hs-kpi-label {
        font-size: 0.82rem;
        font-weight: 600;
        color: var(--text-muted);
        text-transform: uppercase;
        letter-spacing: 0.6px;
    }

    .hs-kpi-sub {
        font-size: 0.76rem;
        color: var(--text-muted);
        margin-top: 8px;
    }

    .insight-card {
        background: #fff;
        border-radius: 14px;
        padding: 28px;
        box-shadow: 0 2px 12px rgba(0,0,0,0.06);
        border: 1px solid var(--border);
        margin-bottom: 24px;
    }

    .insight-card-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1rem;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 18px;
        padding-bottom: 14px;
        border-bottom: 1px solid var(--border);
    }

    .insight-card-title i { color: var(--primary); font-size: 1.1rem; }

    .insight-row {
        display: flex;
        align-items: flex-start;
        gap: 12px;
        padding: 10px 0;
        font-size: 0.9rem;
        color: var(--text-dark);
        border-bottom: 1px solid #f8f4f6;
    }

    .insight-row:last-child { border-bottom: none; }

    .insight-icon {
        width: 28px; height: 28px;
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 0.8rem;
        flex-shrink: 0;
    }

    .insight-icon.ok     { background: #dcfce7; color: #166534; }
    .insight-icon.warn   { background: #fef3c7; color: #92400e; }
    .insight-icon.alert  { background: #fee2e2; color: #b91c1c; }

    .action-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 4px; }
</style>
{% endblock %}

{% block body %}
<div>
    {# Hero #}
    <div class="hs-hero">
        <div>
            <h2><i class="fas fa-chart-bar me-2" style="opacity:0.8;"></i>Health Statistics & Insights</h2>
            <p>Aggregate analytics from all user health tracking entries</p>
        </div>
        <div class="d-flex gap-10">
            <a href="{{ path('admin_health_logs') }}" class="btn btn-primary d-flex align-items-center gap-2">
                <i class="fas fa-list"></i> View Logs
            </a>
        </div>
    </div>

    {# KPI Cards #}
    <div class="stats-grid">
        <div class="hs-kpi">
            <div class="hs-kpi-icon"><i class="fas fa-database"></i></div>
            <div class="hs-kpi-val">{{ total }}</div>
            <div class="hs-kpi-label">Total Entries</div>
            <div class="hs-kpi-sub">Health log entries recorded</div>
        </div>

        <div class="hs-kpi">
            <div class="hs-kpi-icon" style="background:rgba(251,191,36,0.12);color:#d97706;"><i class="fas fa-smile"></i></div>
            <div class="hs-kpi-val" style="color:{% if avgMood >= 4 %}#166534{% elseif avgMood >= 3 %}#92400e{% else %}#b91c1c{% endif %};">
                {{ avgMood }}<small>/5</small>
            </div>
            <div class="hs-kpi-label">Avg Mood</div>
            <div class="hs-kpi-sub">
                {% if avgMood >= 4 %}Generally positive😊
                {% elseif avgMood >= 3 %}Neutral baseline 😐
                {% else %}Below average ⚠️{% endif %}
            </div>
        </div>

        <div class="hs-kpi">
            <div class="hs-kpi-icon" style="background:rgba(239,68,68,0.12);color:#dc2626;"><i class="fas fa-gauge-high"></i></div>
            <div class="hs-kpi-val" style="color:{% if avgStress >= 4 %}#b91c1c{% elseif avgStress >= 3 %}#92400e{% else %}#166534{% endif %};">
                {{ avgStress }}<small>/5</small>
            </div>
            <div class="hs-kpi-label">Avg Stress</div>
            <div class="hs-kpi-sub">
                {% if avgStress >= 4 %}High — consider outreach 🚨
                {% elseif avgStress >= 3 %}Moderate stress levels 🙁
                {% else %}Low stress — great! ✅{% endif %}
            </div>
        </div>
    </div>

    {# Insights Panel #}
    <div class="insight-card">
        <div class="insight-card-title">
            <i class="fas fa-lightbulb"></i> Key Insights
        </div>

        {% if total == 0 %}
            <div style="text-align:center;padding:32px;color:var(--text-muted);">
                <i class="fas fa-inbox" style="font-size:2.5rem;opacity:0.3;display:block;margin-bottom:12px;"></i>
                No health data available yet. Users can start logging from their dashboard.
            </div>
        {% else %}
            <div class="insight-row">
                <div class="insight-icon {% if avgMood >= 4 %}ok{% elseif avgMood >= 3 %}warn{% else %}alert{% endif %}">
                    <i class="fas fa-{% if avgMood >= 4 %}check{% elseif avgMood >= 3 %}minus{% else %}exclamation{% endif %}"></i>
                </div>
                <div>
                    <strong>Mood:</strong>
                    {% if avgMood >= 4 %}
                        Users report <strong>positive mood levels</strong> ({{ avgMood }}/5) — platform is supporting patient wellbeing.
                    {% elseif avgMood >= 3 %}
                        Users report <strong>neutral mood</strong> ({{ avgMood }}/5) — room for improvement in engagement.
                    {% else %}
                        Users report <strong>lower mood levels</strong> ({{ avgMood }}/5) — consider a proactive wellness outreach.
                    {% endif %}
                </div>
            </div>
            <div class="insight-row">
                <div class="insight-icon {% if avgStress >= 4 %}alert{% elseif avgStress >= 3 %}warn{% else %}ok{% endif %}">
                    <i class="fas fa-{% if avgStress >= 4 %}exclamation-triangle{% elseif avgStress >= 3 %}minus{% else %}check{% endif %}"></i>
                </div>
                <div>
                    <strong>Stress:</strong>
                    {% if avgStress >= 4 %}
                        Average stress is <strong>high</strong> ({{ avgStress }}/5) — consider wellness programs or stress-reduction resources.
                    {% elseif avgStress >= 3 %}
                        Users report <strong>moderate stress</strong> ({{ avgStress }}/5) — monitor over coming weeks.
                    {% else %}
                        Users report <strong>low stress levels</strong> ({{ avgStress }}/5) — excellent overall wellness signal.
                    {% endif %}
                </div>
            </div>
            <div class="insight-row">
                <div class="insight-icon ok"><i class="fas fa-database"></i></div>
                <div>
                    <strong>Volume:</strong> {{ total }} total health log entries recorded by patients on the platform.
                </div>
            </div>
        {% endif %}
    </div>

    {# Actions #}
    <div class="action-row">
        <a href="{{ path('admin_health_logs') }}" class="btn btn-primary d-flex align-items-center gap-2">
            <i class="fas fa-list"></i> View All Health Logs
        </a>
        <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary d-flex align-items-center gap-2">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>
</div>
{% endblock %}
